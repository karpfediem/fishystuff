import "sys"
import "modules/fishystuff-resident-bootstrap/"

$hostname = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_HOSTNAME", "")
$mgmt_exec = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_MGMT_EXEC", "/usr/local/bin/mgmt")
$mgmt_exec_source = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_MGMT_EXEC_SOURCE", $mgmt_exec)
$service_name = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_SERVICE_NAME", "fishystuff-mgmt")
$state_root = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_STATE_ROOT", "/var/lib/fishystuff/mgmt")
$unit_dir = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_UNIT_DIR", "/etc/systemd/system")
$client_urls = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_CLIENT_URLS", "")
$server_urls = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_SERVER_URLS", "")
$advertise_client_urls = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_ADVERTISE_CLIENT_URLS", $client_urls)
$advertise_server_urls = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_ADVERTISE_SERVER_URLS", $server_urls)
$seeds = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_SEEDS", "")
$ssh_url = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_SSH_URL", "")
$ssh_hostkey = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_SSH_HOSTKEY", "")
$ssh_id = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_SSH_ID", "")
$ssh_id_dir = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_SSH_ID_DIR", "/root/.ssh")
$ssh_id_content = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_SSH_ID_CONTENT", "")
$startup_mode = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_STARTUP_MODE", "enabled")
$environment_dir = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_ENVIRONMENT_DIR", "/etc/fishystuff")
$environment_file = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_ENVIRONMENT_FILE", "")
$environment_file_content = sys.defaultenv("FISHYSTUFF_MGMT_BOOTSTRAP_ENVIRONMENT_FILE_CONTENT", "")

panic($hostname == "", "missing resident mgmt hostname; set FISHYSTUFF_MGMT_BOOTSTRAP_HOSTNAME")

include fishystuff_resident_bootstrap.resident(struct {
	hostname => $hostname,
	mgmt_exec => $mgmt_exec,
	mgmt_exec_source => $mgmt_exec_source,
	service_name => $service_name,
	state_root => $state_root,
	unit_dir => $unit_dir,
	client_urls => $client_urls,
	server_urls => $server_urls,
	advertise_client_urls => $advertise_client_urls,
	advertise_server_urls => $advertise_server_urls,
	seeds => $seeds,
	ssh_url => $ssh_url,
	ssh_hostkey => $ssh_hostkey,
	ssh_id => $ssh_id,
	ssh_id_dir => $ssh_id_dir,
	ssh_id_content => $ssh_id_content,
	startup_mode => $startup_mode,
	environment_dir => $environment_dir,
	environment_file => $environment_file,
	environment_file_content => $environment_file_content,
})
