{
  "devDependencies": {
    "@iconify-json/mingcute": "^1.2.7",
    "@iconify/utils": "^3.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.204.0",
    "@opentelemetry/instrumentation": "^0.204.0",
    "@opentelemetry/instrumentation-fetch": "^0.204.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-trace-base": "^2.1.0",
    "@opentelemetry/sdk-trace-web": "^2.1.0",
    "@opentelemetry/semantic-conventions": "^1.37.0",
    "@starfederation/datastar": "github:starfederation/datastar#v1.0.0-RC.8",
    "@tailwindcss/cli": "^4.1.14",
    "@tailwindcss/typography": "^0.5.19",
    "d3": "^7.9.0",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.1.14"
  },
  "scripts": {
    "test": "bun test",
    "content-shells:build": "bun run ./scripts/build-shell-pages.mjs",
    "i18n:build": "bun run ./scripts/build-i18n.mjs",
    "d3:build": "bun run ./scripts/build-d3.mjs",
    "datastar:build": "bun run ./scripts/build-datastar.mjs",
    "embed:build": "bun run ./scripts/build-embed-images.mjs",
    "fonts:build": "bash ./scripts/build-web-fonts.sh",
    "images:build": "bun run ./scripts/build-responsive-images.mjs",
    "icons:build": "bun run ./scripts/build-icon-sprite.mjs",
    "otel:build": "bun run ./scripts/build-otel.mjs",
    "assets:finalize": "bun run ./scripts/finalize-assets.mjs",
    "tailwind:scan": "bun run ./scripts/write-tailwind-scan.mjs",
    "tailwind:build": "bun run icons:build && bun run tailwind:scan && bun --bun ./node_modules/@tailwindcss/cli/dist/index.mjs -i tailwind.input.css -o assets/css/site.css",
    "pre-build": "bun run content-shells:build && bun run i18n:build && bun run datastar:build && bun run d3:build && bun run otel:build && bun run images:build && bun run tailwind:build && bun run embed:build",
    "build": "bash ./scripts/build-public-release.sh"
  }
}
