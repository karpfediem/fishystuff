calculator.breakdown.formula.total_time.active = Average total = Average bite time + Active catch time.
calculator.breakdown.formula.total_time.afk = Average total = Average bite time + Auto-Fishing Time + AFK catch time.
calculator.breakdown.formula.catch_time.active = Catch time = Active catch time.
calculator.breakdown.formula.catch_time.afk = Catch time = AFK catch time.
calculator.breakdown.formula.time_saved = Time saved = Average unoptimized time - Average total fishing time.; Saved share = Time saved / Average unoptimized time.
calculator.breakdown.formula.raw_prize_rate = Raw rate = resolved mastery prize-curve entry.
calculator.breakdown.formula.bite_time = Average bite time = Zone average bite time × Level factor × Abundance factor.
calculator.breakdown.formula.auto_fish_time = Auto-Fishing Time = max(180 × (1 - AFR), 60).
calculator.breakdown.formula.auto_fish_time_reduction = AFR (uncapped) = highest pet AFR + additive item AFR; Applied AFR = min(AFR, 66.67%).
calculator.breakdown.formula.casts_average = Average casts = Session seconds / Average total fishing time.
calculator.breakdown.formula.item_drr = Item DRR = sum of additive DRR sources.
calculator.breakdown.formula.chance_to_consume_durability = Chance = Brandstone factor × (1 - Item DRR) × (1 - Lifeskill DRR).
calculator.breakdown.formula.durability_loss_average = Average loss = Average casts × Chance to consume durability.
calculator.breakdown.formula.zone_bite_min = Zone Bite Min = selected zone minimum bite-time entry.
calculator.breakdown.formula.zone_bite_avg = Zone Bite Average = (Zone Bite Min + Zone Bite Max) / 2.
calculator.breakdown.formula.zone_bite_max = Zone Bite Max = selected zone maximum bite-time entry.
calculator.breakdown.formula.effective_bite_min = Effective Bite Min = Zone Bite Min × Level factor × Abundance factor.
calculator.breakdown.formula.effective_bite_avg = Effective Bite Average = Zone Bite Average × Level factor × Abundance factor.
calculator.breakdown.formula.effective_bite_max = Effective Bite Max = Zone Bite Max × Level factor × Abundance factor.
calculator.breakdown.formula.loot_total_catches = Expected catches = Average casts × Applied fish multiplier.
calculator.breakdown.formula.loot_fish_per_hour = Catches / hour = (3600 / Average total fishing time) × Applied fish multiplier.
calculator.breakdown.formula.loot_total_profit = Expected profit = Σ(Group expected silver).
calculator.breakdown.formula.loot_profit_per_hour = Profit / hour = Expected profit / Session hours.
calculator.breakdown.formula.target_expected_count = Expected count = Σ(Expected catches × Group share × In-group rate).
calculator.breakdown.formula.target_time_to_target = Time to target = Target amount / Expected catches per day.
calculator.breakdown.formula.target_probability = Probability = 1 - PoissonCDF(Target amount - 1, λ).

