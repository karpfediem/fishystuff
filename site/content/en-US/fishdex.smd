## Fishdex

Track your caught fish locally in the browser. The page fetches the fish catalog from `/api/v1/fish` at runtime, then uses Datastar signals for filtering, prize toggles, and local-only progress.

```=html
<style>
  #pokedex-app {
    --dex-shell: color-mix(in oklab, var(--color-error, #d64545) 72%, var(--color-primary, #e07a5f) 28%);
    --dex-shell-border: color-mix(in oklab, var(--dex-shell) 74%, var(--color-neutral, #1f2937) 26%);
    --dex-screen: color-mix(in oklab, var(--color-base-100, #fffdf4) 82%, var(--color-base-200, #efe7d6) 18%);
    --dex-screen-border: color-mix(in oklab, var(--color-base-content, #1f2937) 18%, transparent);
    --dex-line: color-mix(in oklab, var(--color-base-content, #1f2937) 24%, transparent);
    --dex-highlight: color-mix(in oklab, var(--color-warning, #f4b942) 58%, var(--color-base-100, #fffdf4) 42%);
    --dex-prize: color-mix(in oklab, var(--color-error, #d64545) 74%, var(--color-base-100, #fffdf4) 26%);
    --dex-prize-surface: color-mix(in oklab, var(--color-error, #d64545) 18%, var(--color-base-200, #efe7d6) 82%);
    --dex-grade-rare: color-mix(in oklab, var(--color-warning, #f59e0b) 72%, var(--color-base-100, #fffdf4) 28%);
    --dex-grade-rare-surface: color-mix(in oklab, var(--color-warning, #f59e0b) 22%, var(--dex-surface-strong) 78%);
    --dex-grade-highquality: color-mix(in oklab, var(--color-info, #6b8afd) 76%, var(--color-base-100, #fffdf4) 24%);
    --dex-grade-highquality-surface: color-mix(in oklab, var(--color-info, #6b8afd) 22%, var(--dex-surface-strong) 78%);
    --dex-grade-general: color-mix(in oklab, var(--color-success, #2f855a) 72%, var(--color-base-100, #fffdf4) 28%);
    --dex-grade-general-surface: color-mix(in oklab, var(--color-success, #2f855a) 22%, var(--dex-surface-strong) 78%);
    --dex-grade-trash: color-mix(in oklab, var(--color-base-content, #1f2937) 18%, var(--color-base-100, #fffdf4) 82%);
    --dex-grade-trash-surface: color-mix(in oklab, var(--color-base-300, #d8d0c0) 54%, var(--color-base-100, #fffdf4) 46%);
    --dex-grade-unknown: color-mix(in oklab, var(--color-neutral, #1f2937) 46%, var(--color-base-100, #fffdf4) 54%);
    --dex-grade-unknown-surface: color-mix(in oklab, var(--color-neutral, #1f2937) 18%, var(--dex-surface-strong) 82%);
    --dex-caught: color-mix(in oklab, var(--color-success, #2f855a) 72%, var(--color-base-200, #111827) 28%);
    --dex-surface: color-mix(in oklab, var(--color-base-200, #efe7d6) 62%, var(--color-base-100, #fffdf4) 38%);
    --dex-surface-strong: color-mix(in oklab, var(--color-base-100, #fffdf4) 78%, var(--color-base-200, #efe7d6) 22%);
    --dex-surface-soft: color-mix(in oklab, var(--color-base-200, #efe7d6) 76%, var(--color-base-300, #d8d0c0) 24%);
    --dex-field: color-mix(in oklab, var(--color-base-100, #fffdf4) 60%, var(--color-base-200, #efe7d6) 40%);
    --dex-focus: color-mix(in oklab, var(--color-primary, #e07a5f) 60%, var(--color-base-100, #fffdf4) 40%);
    --dex-button: color-mix(in oklab, var(--color-primary, #e07a5f) 76%, var(--color-secondary, #6b8afd) 24%);
    --dex-button-secondary: color-mix(in oklab, var(--color-secondary, #6b8afd) 72%, var(--color-accent, #1f2937) 28%);
    --dex-button-line: color-mix(in oklab, var(--color-base-content, #1f2937) 18%, transparent);
    --dex-text-muted: color-mix(in oklab, var(--color-base-content, #1f2937) 68%, transparent);
    color-scheme: light dark;
    display: grid;
    gap: 1.5rem;
    color: var(--color-base-content, #1f2937);
  }

  .pokedex-shell {
    border: 4px solid var(--dex-shell-border);
    border-radius: 2rem;
    background: var(--dex-shell);
    overflow: hidden;
  }

  .pokedex-top {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: minmax(0, 1.2fr) minmax(16rem, 0.8fr);
    padding: 1.5rem;
  }

  .pokedex-screen,
  .pokedex-stats {
    border-radius: 1.35rem;
    border: 3px solid var(--dex-screen-border);
    background: var(--dex-screen);
  }

  .pokedex-screen {
    padding: 1.25rem;
  }

  .pokedex-heading {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .pokedex-heading h3,
  .pokedex-stats h3,
  .pokedex-group-title {
    margin: 0;
    font-family: "Modak", "Trebuchet MS", sans-serif;
    font-weight: 400;
    letter-spacing: 0.03em;
  }

  .pokedex-heading h3,
  .pokedex-stats h3 {
    font-size: clamp(1.25rem, 2vw, 1.9rem);
  }

  .pokedex-subtle {
    color: var(--dex-text-muted);
    font-size: 0.95rem;
  }

  .pokedex-controls {
    display: grid;
    gap: 0.9rem;
  }

  .pokedex-search {
    appearance: none;
    width: 100%;
    border-radius: 999px;
    border: 2px solid var(--dex-line);
    background: var(--dex-field);
    color: var(--color-base-content, #1f2937);
    font: inherit;
    padding: 0.9rem 1rem;
    font-size: 1rem;
    transition: border-color 120ms ease, outline-color 120ms ease;
  }

  .pokedex-search::placeholder {
    color: var(--dex-text-muted);
    opacity: 1;
  }

  .pokedex-search:hover {
    border-color: color-mix(in oklab, var(--color-base-content, #1f2937) 34%, transparent);
  }

  .pokedex-search:focus,
  .pokedex-search:focus-visible {
    border-color: color-mix(in oklab, var(--color-primary, #e07a5f) 56%, var(--color-base-content, #1f2937) 44%);
    outline: 3px solid var(--dex-focus);
    outline-offset: 2px;
  }

  .pokedex-search:focus:not(:focus-visible) {
    outline: none;
  }

  .pokedex-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
  }

  .pokedex-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    border-radius: 999px;
    border: 2px solid var(--dex-line);
    background: var(--dex-field);
    color: var(--color-base-content, #1f2937);
    padding: 0.5rem 0.85rem;
    font-weight: 700;
    transition: border-color 120ms ease, outline-color 120ms ease;
  }

  .pokedex-toggle:hover {
    border-color: color-mix(in oklab, var(--color-base-content, #1f2937) 34%, transparent);
  }

  .pokedex-toggle:focus-within {
    border-color: color-mix(in oklab, var(--color-primary, #e07a5f) 56%, var(--color-base-content, #1f2937) 44%);
    outline: 3px solid var(--dex-focus);
    outline-offset: 2px;
  }

  .pokedex-toggle input {
    margin: 0;
    inline-size: 1rem;
    block-size: 1rem;
    flex: none;
    accent-color: var(--color-primary, #e07a5f);
  }

  .pokedex-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .pokedex-button {
    --dex-button-tone: var(--dex-button);
    --dex-button-content: var(--color-primary-content, white);
    appearance: none;
    border: 1px solid var(--dex-button-line);
    border-radius: 999px;
    background: var(--dex-button-tone);
    color: var(--dex-button-content);
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    padding: 0.65rem 1rem;
    transition: transform 120ms ease, border-color 120ms ease, background 120ms ease, outline-color 120ms ease;
  }

  .pokedex-button-secondary {
    --dex-button-tone: var(--dex-button-secondary);
    --dex-button-content: var(--color-secondary-content, white);
  }

  .pokedex-button:hover {
    background: color-mix(in oklab, var(--dex-button-tone) 72%, var(--dex-highlight) 28%);
    border-color: color-mix(in oklab, var(--dex-button-tone) 56%, var(--color-base-content, #1f2937) 44%);
    transform: translateY(-1px);
  }

  .pokedex-button:focus-visible {
    background: color-mix(in oklab, var(--dex-button-tone) 72%, var(--dex-highlight) 28%);
    border-color: color-mix(in oklab, var(--dex-button-tone) 56%, var(--color-base-content, #1f2937) 44%);
    outline: 3px solid var(--dex-focus);
    outline-offset: 2px;
    transform: translateY(-1px);
  }

  .pokedex-stats {
    display: grid;
    gap: 0.85rem;
    align-content: start;
    padding: 1.25rem;
  }

  .pokedex-stat-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .pokedex-stat {
    border-radius: 1rem;
    border: 1px solid var(--dex-line);
    background: var(--dex-surface-soft);
    padding: 0.9rem;
  }

  .pokedex-stat-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.72;
  }

  .pokedex-stat-value {
    display: block;
    font-size: clamp(1.3rem, 2vw, 2rem);
    font-weight: 800;
  }

  .pokedex-status,
  .pokedex-error {
    border-radius: 1rem;
    padding: 0.85rem 1rem;
  }

  .pokedex-status {
    background: color-mix(in oklab, var(--color-info, #6b8afd) 12%, var(--dex-surface-strong) 88%);
    border: 1px solid color-mix(in oklab, var(--color-info, #6b8afd) 30%, var(--dex-line) 70%);
  }

  .pokedex-error {
    background: color-mix(in oklab, var(--color-error, #d64545) 14%, var(--dex-surface-strong) 86%);
    border: 1px solid color-mix(in oklab, var(--color-error, #d64545) 34%, var(--dex-line) 66%);
  }

  .pokedex-status strong {
    color: color-mix(in oklab, var(--color-info, #6b8afd) 54%, var(--color-base-content, #1f2937) 46%);
  }

  .pokedex-error strong {
    color: color-mix(in oklab, var(--color-error, #d64545) 60%, var(--color-base-content, #1f2937) 40%);
  }

  .pokedex-grid-shell {
    padding: 0 1.5rem 1.5rem;
  }

  .pokedex-groups {
    display: grid;
    gap: 1rem;
  }

  .pokedex-group {
    border-radius: 1.4rem;
    border: 2px solid var(--dex-line);
    background: var(--dex-surface);
    color: var(--color-base-content, #1f2937);
    padding: 1rem;
  }

  .pokedex-group-header {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: baseline;
    margin-bottom: 0.9rem;
  }

  .pokedex-group-count {
    color: var(--dex-text-muted);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .pokedex-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(12rem, 1fr));
    gap: 0.85rem;
  }

  .pokedex-card {
    display: grid;
    min-height: 12.5rem;
    border: 2px solid var(--dex-line);
    border-radius: 1.25rem;
    background: var(--dex-surface-strong);
    color: var(--color-base-content, #1f2937);
    overflow: hidden;
    padding: 0.95rem;
    position: relative;
    transition: transform 120ms ease, border-color 120ms ease, background 120ms ease, outline-color 120ms ease;
  }

  .pokedex-card:hover {
    border-color: color-mix(in oklab, var(--dex-highlight) 62%, var(--color-base-content, #1f2937) 38%);
    background: var(--dex-surface);
    transform: translateY(-2px);
  }

  .pokedex-card:focus-within {
    border-color: color-mix(in oklab, var(--dex-highlight) 62%, var(--color-base-content, #1f2937) 38%);
    background: var(--dex-surface);
    outline: 3px solid var(--dex-focus);
    outline-offset: 2px;
    transform: translateY(-2px);
  }

  .pokedex-card.is-caught {
    border-color: color-mix(in oklab, var(--dex-caught) 70%, var(--color-base-content, #1f2937) 30%);
  }

  .pokedex-card.is-prize {
    background: var(--dex-prize-surface);
    border-color: color-mix(in oklab, var(--dex-prize) 44%, var(--dex-line) 56%);
  }

  .pokedex-card-top {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 0.65rem;
  }

  .pokedex-card-toggle {
    appearance: none;
    position: absolute;
    inset: 0;
    border: 0;
    background: transparent;
    border-radius: inherit;
    cursor: pointer;
    margin: 0;
    padding: 0;
  }

  .pokedex-card-toggle:focus-visible {
    outline: none;
  }

  .pokedex-card-content {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.75rem;
    pointer-events: none;
  }

  .pokedex-card-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: start;
    gap: 0.45rem;
  }

  .pokedex-inspect-button {
    appearance: none;
    pointer-events: auto;
    border: 1px solid var(--dex-line);
    border-radius: 999px;
    background: var(--dex-field);
    color: var(--color-base-content, #1f2937);
    cursor: pointer;
    font: inherit;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    line-height: 1;
    padding: 0.3rem 0.6rem;
    text-transform: uppercase;
    transition: border-color 120ms ease, background 120ms ease, outline-color 120ms ease;
    white-space: nowrap;
  }

  .pokedex-inspect-button:hover {
    border-color: color-mix(in oklab, var(--dex-highlight) 56%, var(--color-base-content, #1f2937) 44%);
    background: var(--dex-surface);
  }

  .pokedex-inspect-button:focus-visible {
    border-color: color-mix(in oklab, var(--dex-highlight) 56%, var(--color-base-content, #1f2937) 44%);
    background: var(--dex-surface);
    outline: 3px solid var(--dex-focus);
    outline-offset: 2px;
  }

  .pokedex-grade,
  .pokedex-caught {
    align-self: start;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    line-height: 1;
    padding: 0.3rem 0.6rem;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .pokedex-grade {
    background: color-mix(in oklab, var(--color-base-content, #1f2937) 10%, var(--dex-surface-soft) 90%);
    color: var(--color-base-content, #1f2937);
  }

  .pokedex-grade.grade-prize {
    background: color-mix(in oklab, var(--dex-prize) 38%, var(--dex-surface-strong) 62%);
    color: color-mix(in oklab, var(--color-error, #d64545) 62%, var(--color-base-content, #1f2937) 38%);
  }

  .pokedex-grade.grade-rare {
    background: var(--dex-grade-rare-surface);
    color: color-mix(in oklab, var(--dex-grade-rare) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .pokedex-grade.grade-highquality {
    background: var(--dex-grade-highquality-surface);
    color: color-mix(in oklab, var(--dex-grade-highquality) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .pokedex-grade.grade-general {
    background: var(--dex-grade-general-surface);
    color: color-mix(in oklab, var(--dex-grade-general) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .pokedex-grade.grade-trash {
    background: var(--dex-grade-trash-surface);
    color: color-mix(in oklab, var(--dex-grade-trash) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .pokedex-grade.grade-unknown {
    background: var(--dex-grade-unknown-surface);
    color: color-mix(in oklab, var(--dex-grade-unknown) 68%, var(--color-base-content, #1f2937) 32%);
  }

  .pokedex-caught {
    background: color-mix(in oklab, var(--dex-caught) 24%, var(--dex-surface-strong) 76%);
    color: color-mix(in oklab, var(--color-success, #2f855a) 62%, var(--color-base-content, #1f2937) 38%);
  }

  .pokedex-caught-placeholder {
    visibility: hidden;
  }

  .pokedex-card-main {
    display: grid;
    justify-items: center;
    gap: 0.65rem;
    min-height: 7.8rem;
  }

  .pokedex-icon-wrap {
    display: grid;
    place-items: center;
    width: 4.75rem;
    height: 4.75rem;
    border-radius: 1.2rem;
    border: 1px solid var(--dex-line);
    background: var(--dex-surface-soft);
  }

  .pokedex-icon {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    margin: 0;
    object-fit: contain;
    image-rendering: auto;
  }

  .pokedex-placeholder {
    color: var(--dex-text-muted);
    font-size: 2rem;
  }

  .pokedex-name {
    font-weight: 800;
    line-height: 1.25;
    text-align: center;
  }

  .pokedex-empty {
    border: 2px dashed var(--dex-line);
    border-radius: 1.4rem;
    background: var(--dex-surface);
    color: var(--color-base-content, #1f2937);
    padding: 1.25rem;
    text-align: center;
  }

  .pokedex-details-modal[hidden] {
    display: none;
  }

  .pokedex-details-modal {
    position: fixed;
    inset: 0;
    z-index: 40;
    display: grid;
    place-items: center;
    padding: 1rem;
  }

  .pokedex-details-backdrop {
    appearance: none;
    position: absolute;
    inset: 0;
    border: 0;
    background: color-mix(in oklab, var(--color-base-content, #1f2937) 36%, transparent);
    cursor: pointer;
    margin: 0;
    padding: 0;
  }

  .pokedex-details-panel {
    position: relative;
    z-index: 1;
    width: min(42rem, 100%);
    max-height: min(90vh, 46rem);
    overflow: auto;
    border-radius: 1.5rem;
    border: 3px solid var(--dex-screen-border);
    background: var(--dex-screen);
    color: var(--color-base-content, #1f2937);
    padding: 1.2rem;
  }

  .pokedex-details-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: start;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .pokedex-details-header-main {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
    min-width: 0;
  }

  .pokedex-details-title {
    margin: 0;
    font-family: "Modak", "Trebuchet MS", sans-serif;
    font-size: clamp(1.25rem, 2.2vw, 1.85rem);
    font-weight: 400;
    letter-spacing: 0.03em;
  }

  .pokedex-details-close {
    flex: none;
  }

  .pokedex-details-icon-wrap {
    display: grid;
    place-items: center;
    width: 5.5rem;
    height: 5.5rem;
    border-radius: 1.4rem;
    border: 2px solid var(--dex-line);
    background: var(--dex-surface-soft);
  }

  .pokedex-details-icon-wrap.grade-prize {
    border-color: color-mix(in oklab, var(--dex-prize) 64%, var(--dex-line) 36%);
    background: var(--dex-prize-surface);
  }

  .pokedex-details-icon-wrap.grade-rare {
    border-color: color-mix(in oklab, var(--dex-grade-rare) 64%, var(--dex-line) 36%);
    background: var(--dex-grade-rare-surface);
  }

  .pokedex-details-icon-wrap.grade-highquality {
    border-color: color-mix(in oklab, var(--dex-grade-highquality) 64%, var(--dex-line) 36%);
    background: var(--dex-grade-highquality-surface);
  }

  .pokedex-details-icon-wrap.grade-general {
    border-color: color-mix(in oklab, var(--dex-grade-general) 64%, var(--dex-line) 36%);
    background: var(--dex-grade-general-surface);
  }

  .pokedex-details-icon-wrap.grade-trash {
    border-color: color-mix(in oklab, var(--dex-grade-trash) 64%, var(--dex-line) 36%);
    background: var(--dex-grade-trash-surface);
  }

  .pokedex-details-icon-wrap.grade-unknown {
    border-color: color-mix(in oklab, var(--dex-grade-unknown) 64%, var(--dex-line) 36%);
    background: var(--dex-grade-unknown-surface);
  }

  .pokedex-details-icon {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .pokedex-details-copy {
    display: grid;
    gap: 0.75rem;
    min-width: 0;
  }

  .pokedex-details-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .pokedex-details-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
    gap: 0.75rem;
  }

  .pokedex-details-guide {
    margin-bottom: 1rem;
  }

  .pokedex-details-guide-frame {
    display: grid;
    place-items: center;
    min-height: 14rem;
    border-radius: 1.35rem;
    border: 1px solid var(--dex-line);
    background: var(--dex-surface);
    padding: 1rem;
  }

  .pokedex-details-guide-image {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 16rem;
    object-fit: contain;
  }

  .pokedex-details-meta-card,
  .pokedex-details-section {
    border-radius: 1rem;
    border: 1px solid var(--dex-line);
    background: var(--dex-surface);
    padding: 0.85rem 0.95rem;
  }

  .pokedex-details-meta-card dt {
    margin: 0 0 0.35rem;
    color: var(--dex-text-muted);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .pokedex-details-meta-card dd {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
  }

  .pokedex-details-stack {
    display: grid;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .pokedex-details-section h4 {
    margin: 0 0 0.45rem;
    font-size: 1rem;
  }

  .pokedex-details-note {
    margin: 0.6rem 0 0;
    color: var(--dex-text-muted);
    font-size: 0.92rem;
  }

  .pokedex-details-note.is-error {
    color: color-mix(in oklab, var(--color-error, #d64545) 62%, var(--color-base-content, #1f2937) 38%);
  }

  @media (max-width: 900px) {
    .pokedex-top {
      grid-template-columns: 1fr;
    }

    .pokedex-details-header {
      grid-template-columns: 1fr;
    }

    .pokedex-details-header-main {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    #content {
      padding: 1rem;
    }

    .pokedex-top,
    .pokedex-grid-shell {
      padding: 1rem;
    }

    .pokedex-stat-grid {
      grid-template-columns: 1fr 1fr;
    }

    .pokedex-card-grid {
      grid-template-columns: repeat(auto-fill, minmax(9.75rem, 1fr));
    }
  }
</style>

<script>
  (() => {
    const STORAGE_KEY = "fishystuff.fishdex.caught.v1";
    const DATASTAR_EVENT = "datastar-sse";
    const DATASTAR_MERGE_SIGNALS = "datastar-merge-signals";
    const GRADE_ORDER = ["Prize", "Rare", "HighQuality", "General", "Trash", "Unknown"];
    const state = {
      currentCaughtIds: [],
      fishById: new Map(),
      detailCache: new Map(),
      detailsFishId: null,
      detailsBound: false,
      renderKey: "",
      gridBound: false,
      pendingViewportRestore: null,
      pendingViewportFrame: 0,
    };

    function mergeSignals(patch) {
      document.dispatchEvent(new CustomEvent(DATASTAR_EVENT, {
        detail: {
          type: DATASTAR_MERGE_SIGNALS,
          argsRaw: {
            signals: JSON.stringify(patch),
          },
        },
      }));
    }

    function normalizeFishPayload(payload) {
      const fish = Array.isArray(payload && payload.fish) ? payload.fish : [];
      const count = Number(payload && payload.count);
      return {
        revision: typeof (payload && payload.revision) === "string" ? payload.revision : "",
        count: Number.isFinite(count) ? count : fish.length,
        fish,
        loading: false,
        status_message: typeof (payload && payload.status_message) === "string" ? payload.status_message : "",
        api_error_message: typeof (payload && payload.api_error_message) === "string" ? payload.api_error_message : "",
        api_error_hint: typeof (payload && payload.api_error_hint) === "string" ? payload.api_error_hint : "",
      };
    }

    function parseDatastarSignalsStream(streamText) {
      const lines = streamText.split(/\r?\n/);
      let eventType = "";
      let dataLines = [];

      function decodePatch() {
        if (eventType !== DATASTAR_MERGE_SIGNALS) {
          return null;
        }
        for (const rawLine of dataLines) {
          const line = rawLine.trim();
          if (!line.startsWith("signals ")) {
            continue;
          }
          return normalizeFishPayload(JSON.parse(line.slice("signals ".length)));
        }
        return null;
      }

      for (const line of lines) {
        if (line.startsWith("event:")) {
          eventType = line.slice("event:".length).trim();
          continue;
        }
        if (line.startsWith("data:")) {
          dataLines.push(line.slice("data:".length).trimStart());
          continue;
        }
        if (line.trim() === "") {
          const patch = decodePatch();
          if (patch) {
            return patch;
          }
          eventType = "";
          dataLines = [];
        }
      }

      const patch = decodePatch();
      if (patch) {
        return patch;
      }
      throw new Error("Fish API did not return a Datastar signal patch.");
    }

    async function loadFish() {
      mergeSignals({
        loading: true,
        api_error_message: "",
        api_error_hint: "",
        status_message: "",
      });

      let response;
      try {
        response = await fetch(fishApiUrl(), {
          headers: {
            Accept: "text/event-stream, application/json",
            "Datastar-Request": "true",
          },
          credentials: "same-origin",
        });
      } catch (_error) {
        mergeSignals({
          loading: false,
          api_error_message: "Fish API request failed.",
          api_error_hint: "If this page is on a different origin than the API, confirm the API CORS allowlist includes this site.",
        });
        return;
      }

      if (!response.ok) {
        mergeSignals({
          loading: false,
          api_error_message: `Fish API request failed (HTTP ${response.status}).`,
          api_error_hint: "If this page is on a different origin than the API, confirm the API CORS allowlist includes this site.",
        });
        return;
      }

      try {
        const contentType = response.headers.get("content-type") || "";
        if (contentType.includes("text/event-stream")) {
          mergeSignals(parseDatastarSignalsStream(await response.text()));
          return;
        }
        mergeSignals(normalizeFishPayload(await response.json()));
      } catch (_error) {
        mergeSignals({
          loading: false,
          api_error_message: "Fish API response could not be parsed.",
          api_error_hint: "Confirm the API is serving either Datastar SSE or JSON fish data.",
        });
      }
    }

    function normalizeCaughtIds(value) {
      let ids = [];
      if (Array.isArray(value)) {
        ids = value;
      } else if (value && typeof value === "object") {
        ids = Object.entries(value)
          .filter(([, enabled]) => enabled)
          .map(([fishId]) => fishId);
      }

      const unique = new Set();
      for (const raw of ids) {
        const fishId = Number.parseInt(String(raw), 10);
        if (Number.isInteger(fishId) && fishId > 0) {
          unique.add(fishId);
        }
      }
      return Array.from(unique).sort((left, right) => left - right);
    }

    function parseCaughtJson(raw) {
      return normalizeCaughtIds(JSON.parse(raw));
    }

    function persistCaughtIds(caughtIds) {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(caughtIds));
      } catch (_error) {
        mergeSignals({ status_message: "localStorage is unavailable; progress is not persisted." });
      }
    }

    function resetFilters() {
      mergeSignals({ search_draft: "", search_query: "", prize_only: false });
    }

    function restoreCaught() {
      let caughtIds = [];
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (raw) {
          try {
            caughtIds = parseCaughtJson(raw);
          } catch (_error) {
            localStorage.removeItem(STORAGE_KEY);
            mergeSignals({ status_message: "Reset corrupted local fishdex progress." });
          }
        }
      } catch (_error) {
        mergeSignals({ status_message: "localStorage is unavailable; progress is not persisted." });
      }
      state.currentCaughtIds = caughtIds;
      mergeSignals({ caught_ids: caughtIds });
    }

    function toggleCaught(fishId) {
      const next = new Set(state.currentCaughtIds);
      if (next.has(fishId)) {
        next.delete(fishId);
      } else {
        next.add(fishId);
      }
      const caughtIds = Array.from(next).sort((left, right) => left - right);
      state.currentCaughtIds = caughtIds;
      persistCaughtIds(caughtIds);
      mergeSignals({ caught_ids: caughtIds, status_message: "" });
    }

    function rememberViewport(card) {
      if (!(card instanceof HTMLElement)) {
        state.pendingViewportRestore = null;
        return;
      }
      const fishId = Number.parseInt(card.dataset.fishId || "", 10);
      if (!Number.isInteger(fishId)) {
        state.pendingViewportRestore = null;
        return;
      }
      const activeElement = document.activeElement;
      let restoreFocusSelector = "";
      if (activeElement instanceof Element && card.contains(activeElement)) {
        restoreFocusSelector = activeElement.closest("[data-action='inspect']")
          ? "[data-action='inspect']"
          : ".pokedex-card-toggle";
      }
      state.pendingViewportRestore = {
        fishId,
        layoutTop: card.offsetTop + (card.offsetParent instanceof HTMLElement
          ? card.offsetParent.getBoundingClientRect().top
          : 0),
        scrollX: window.scrollX,
        scrollY: window.scrollY,
        restoreFocusSelector,
      };
    }

    function scheduleViewportRestore() {
      if (!state.pendingViewportRestore) {
        return;
      }
      if (state.pendingViewportFrame) {
        window.cancelAnimationFrame(state.pendingViewportFrame);
      }
      state.pendingViewportFrame = window.requestAnimationFrame(() => {
        state.pendingViewportFrame = 0;
        const pending = state.pendingViewportRestore;
        state.pendingViewportRestore = null;
        if (!pending) {
          return;
        }

        const nextCard = document.querySelector(`[data-fish-id="${pending.fishId}"]`);
        if (!(nextCard instanceof HTMLElement)) {
          window.scrollTo(pending.scrollX, pending.scrollY);
          return;
        }

        const nextLayoutTop = nextCard.offsetTop + (nextCard.offsetParent instanceof HTMLElement
          ? nextCard.offsetParent.getBoundingClientRect().top
          : 0);
        const delta = nextLayoutTop - pending.layoutTop;
        if (Math.abs(delta) > 0.5) {
          window.scrollBy(0, delta);
        }
        if (pending.restoreFocusSelector) {
          const nextFocus = nextCard.matches(pending.restoreFocusSelector)
            ? nextCard
            : nextCard.querySelector(pending.restoreFocusSelector);
          if (nextFocus instanceof HTMLElement) {
            nextFocus.focus({ preventScroll: true });
          }
        }
      });
    }

    function downloadJson(filename, text) {
      const blob = new Blob([text], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = filename;
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(url);
    }

    async function exportCaught(caughtIds) {
      const normalized = normalizeCaughtIds(caughtIds);
      const text = JSON.stringify(normalized, null, 2);
      try {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          await navigator.clipboard.writeText(text);
          mergeSignals({ status_message: `Copied ${normalized.length} caught fish IDs.` });
          return;
        }
      } catch (_error) {
      }
      downloadJson("fishystuff-fishdex-caught.json", text);
      mergeSignals({ status_message: `Downloaded ${normalized.length} caught fish IDs.` });
    }

    function importCaught() {
      const raw = window.prompt("Paste caught fish JSON (array of IDs or an id:true map).");
      if (raw === null) {
        return;
      }
      try {
        const caughtIds = parseCaughtJson(raw);
        state.currentCaughtIds = caughtIds;
        persistCaughtIds(caughtIds);
        mergeSignals({
          caught_ids: caughtIds,
          status_message: `Imported ${caughtIds.length} caught fish IDs.`,
        });
      } catch (_error) {
        mergeSignals({
          status_message: "Import failed. Paste a JSON array of fish IDs or a map like {\"8474\": true}.",
        });
      }
    }

    function slugifyGrade(value) {
      return String(value || "unknown").toLowerCase();
    }

    function createElement(tagName, className, textContent) {
      const element = document.createElement(tagName);
      if (className) {
        element.className = className;
      }
      if (textContent !== undefined) {
        element.textContent = textContent;
      }
      return element;
    }

    function fishRenderSignature(fish) {
      let hash = 2166136261;
      for (const entry of fish) {
        const raw = entry
          ? `${entry.fish_id || 0}|${entry.grade || ""}|${entry.is_prize === true ? 1 : 0}|${entry.name || ""}`
          : "null";
        for (let index = 0; index < raw.length; index += 1) {
          hash ^= raw.charCodeAt(index);
          hash = Math.imul(hash, 16777619);
        }
      }
      return `${fish.length}:${(hash >>> 0).toString(16)}`;
    }

    function renderEmptyState(searchQuery, prizeOnly) {
      const empty = createElement("div", "pokedex-empty");
      const title = createElement("h3", "pokedex-group-title", "No fish match this filter.");
      const detail = createElement(
        "p",
        "pokedex-subtle",
        searchQuery || prizeOnly
          ? "Try a broader search or turn off Prize only."
          : "The fish catalog is empty."
      );
      empty.append(title, detail);
      return empty;
    }

    function renderFishCard(fish, caughtSet) {
      const card = createElement("article", "pokedex-card");
      card.dataset.fishId = String(fish.fish_id);
      if (caughtSet.has(fish.fish_id)) {
        card.classList.add("is-caught");
      }
      if (fish.is_prize || fish.grade === "Prize") {
        card.classList.add("is-prize");
      }

      const toggle = createElement("button", "pokedex-card-toggle");
      toggle.type = "button";
      toggle.setAttribute("aria-pressed", caughtSet.has(fish.fish_id) ? "true" : "false");
      toggle.setAttribute(
        "aria-label",
        `Mark ${fish.name || `Fish ${fish.fish_id}`} as ${caughtSet.has(fish.fish_id) ? "not caught" : "caught"}`
      );

      const content = createElement("div", "pokedex-card-content");
      const top = createElement("div", "pokedex-card-top");
      const actions = createElement("div", "pokedex-card-actions");
      const inspectButton = createElement("button", "pokedex-inspect-button", "Info");
      inspectButton.type = "button";
      inspectButton.dataset.action = "inspect";
      inspectButton.dataset.fishId = String(fish.fish_id);
      inspectButton.setAttribute("aria-haspopup", "dialog");
      inspectButton.setAttribute("aria-label", `Inspect ${fish.name || `Fish ${fish.fish_id}`}`);
      actions.appendChild(inspectButton);
      actions.appendChild(createElement(
        "span",
        caughtSet.has(fish.fish_id) ? "pokedex-caught" : "pokedex-caught pokedex-caught-placeholder",
        "Caught"
      ));
      top.appendChild(actions);

      if (fish.grade) {
        const grade = createElement("span", `pokedex-grade grade-${slugifyGrade(fish.grade)}`, fish.grade);
        top.appendChild(grade);
      }

      const main = createElement("div", "pokedex-card-main");
      const iconWrap = createElement("div", "pokedex-icon-wrap");
      if (fish.icon_url) {
        const icon = createElement("img", "pokedex-icon");
        icon.src = fish.icon_url;
        icon.alt = `${fish.name} icon`;
        icon.loading = "lazy";
        iconWrap.appendChild(icon);
      } else {
        iconWrap.appendChild(createElement("div", "pokedex-placeholder", "?"));
      }
      main.appendChild(iconWrap);
      main.appendChild(createElement("div", "pokedex-name", fish.name || `Fish ${fish.fish_id}`));

      content.append(top, main);
      card.append(toggle, content);
      return card;
    }

    function renderGroup(title, fish, caughtSet) {
      if (!fish.length) {
        return null;
      }

      const section = createElement("section", "pokedex-group");
      const header = createElement("div", "pokedex-group-header");
      header.appendChild(createElement("h3", "pokedex-group-title", title));
      header.appendChild(createElement("span", "pokedex-group-count", `${fish.length} fish`));

      const grid = createElement("div", "pokedex-card-grid");
      for (const entry of fish) {
        grid.appendChild(renderFishCard(entry, caughtSet));
      }

      section.append(header, grid);
      return section;
    }

    function bindGridClicks() {
      if (state.gridBound) {
        return;
      }
      const grid = document.getElementById("pokedex-grid");
      if (!grid) {
        return;
      }
      grid.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) {
          return;
        }
        const card = target.closest("[data-fish-id]");
        if (!card) {
          return;
        }
        const fishId = Number.parseInt(card.dataset.fishId || "", 10);
        if (!Number.isInteger(fishId)) {
          return;
        }
        if (target.closest("[data-action='inspect']")) {
          openDetails(fishId);
          return;
        }
        rememberViewport(card);
        toggleCaught(fishId);
      });
      state.gridBound = true;
    }

    function fishMetaById(fishId) {
      if (!Number.isInteger(fishId)) {
        return null;
      }
      const fish = state.fishById.get(fishId);
      if (!fish) {
        return null;
      }
      return {
        fishId,
        name: fish.name || `Fish ${fishId}`,
        grade: fish.grade || "Unknown",
        isPrize: fish.is_prize === true || fish.grade === "Prize",
        iconUrl: fish.icon_url || "",
        caught: state.currentCaughtIds.includes(fishId),
      };
    }

    function fishMapApiUrl(fishId) {
      const url = new URL(apiUrl("/api/v1/fish_map"));
      url.searchParams.set("item_key", String(fishId));
      return url.toString();
    }

    function normalizeFishIconUrl(value) {
      const raw = String(value || "").trim();
      if (!raw || raw.toLowerCase() === "null") {
        return "";
      }
      if (
        raw.startsWith("http://")
        || raw.startsWith("https://")
        || raw.startsWith("data:")
      ) {
        return raw;
      }
      if (raw.startsWith("/")) {
        return apiUrl(raw);
      }

      let file = raw.split("/").pop() || raw;
      if (!file.toLowerCase().endsWith(".png")) {
        file += ".png";
      }
      return apiUrl(`/images/FishIcons/${file}`);
    }

    function setElementText(element, text) {
      if (element) {
        element.textContent = text;
      }
    }

    function renderDetails() {
      const modal = document.getElementById("pokedex-details");
      if (!(modal instanceof HTMLElement)) {
        return;
      }

      const meta = fishMetaById(state.detailsFishId);
      if (!meta) {
        modal.hidden = true;
        return;
      }

      modal.hidden = false;
      const cached = state.detailCache.get(meta.fishId) || { loading: false, error: "", mapping: null };
      const title = document.getElementById("pokedex-details-title");
      const itemKey = document.getElementById("pokedex-details-item-key");
      const encyclopediaKey = document.getElementById("pokedex-details-encyclopedia-key");
      const caught = document.getElementById("pokedex-details-caught");
      const grade = document.getElementById("pokedex-details-grade");
      const prize = document.getElementById("pokedex-details-prize");
      const spotsNote = document.getElementById("pokedex-details-spots-note");
      const icon = document.getElementById("pokedex-details-icon");
      const iconFrame = document.getElementById("pokedex-details-icon-frame");
      const placeholder = document.getElementById("pokedex-details-placeholder");
      const guideImage = document.getElementById("pokedex-details-guide-image");
      const guidePlaceholder = document.getElementById("pokedex-details-guide-placeholder");
      const iconFrameGrade = meta.isPrize ? "prize" : slugifyGrade(meta.grade);
      const itemIconUrl = normalizeFishIconUrl(
        (cached.mapping && cached.mapping.icon)
          || meta.iconUrl
      );
      const guideIconUrl = normalizeFishIconUrl(cached.mapping && cached.mapping.encyclopedia_icon);

      setElementText(title, meta.name);
      setElementText(itemKey, String(meta.fishId));
      setElementText(
        encyclopediaKey,
        cached.mapping && Number.isInteger(cached.mapping.encyclopedia_key)
          ? String(cached.mapping.encyclopedia_key)
          : cached.loading
            ? "Loading..."
            : "Unavailable"
      );
      setElementText(
        spotsNote,
        "Planned input: evidence locations mapped back to fishing zones, then ranked by rarity and bite-time behavior in each zone."
      );

      if (caught instanceof HTMLElement) {
        caught.className = meta.caught ? "pokedex-caught" : "pokedex-grade grade-unknown";
        caught.textContent = meta.caught ? "Caught" : "Not Caught";
      }
      if (grade instanceof HTMLElement) {
        grade.className = `pokedex-grade grade-${slugifyGrade(meta.grade)}`;
        grade.textContent = meta.grade;
      }
      if (prize instanceof HTMLElement) {
        prize.hidden = !meta.isPrize;
        if (meta.isPrize) {
          prize.className = "pokedex-grade grade-prize";
          prize.textContent = "Prize Fish";
        }
      }
      if (icon instanceof HTMLImageElement && placeholder instanceof HTMLElement) {
        if (iconFrame instanceof HTMLElement) {
          iconFrame.className = `pokedex-details-icon-wrap grade-${iconFrameGrade}`;
        }
        if (itemIconUrl) {
          icon.hidden = false;
          icon.src = itemIconUrl;
          icon.alt = `${meta.name} icon`;
          placeholder.hidden = true;
        } else {
          icon.hidden = true;
          icon.removeAttribute("src");
          icon.alt = "";
          placeholder.hidden = false;
        }
      }
      if (guideImage instanceof HTMLImageElement && guidePlaceholder instanceof HTMLElement) {
        if (guideIconUrl) {
          guideImage.hidden = false;
          guideImage.src = guideIconUrl;
          guideImage.alt = `${meta.name} guide image`;
          guidePlaceholder.hidden = true;
        } else {
          guideImage.hidden = true;
          guideImage.removeAttribute("src");
          guideImage.alt = "";
          guidePlaceholder.hidden = false;
        }
      }
    }

    function closeDetails(options = {}) {
      const restoreFocus = options.restoreFocus !== false;
      const fishId = state.detailsFishId;
      state.detailsFishId = null;
      renderDetails();
      if (!restoreFocus || !Number.isInteger(fishId)) {
        return;
      }
      const nextFocus = document.querySelector(`[data-fish-id="${fishId}"] [data-action="inspect"]`);
      if (nextFocus instanceof HTMLElement) {
        nextFocus.focus({ preventScroll: true });
      }
    }

    async function loadDetailsMapping(fishId) {
      const cached = state.detailCache.get(fishId);
      if (cached && (cached.loading || cached.mapping)) {
        return;
      }
      state.detailCache.set(fishId, { loading: true, error: "", mapping: null });
      if (state.detailsFishId === fishId) {
        renderDetails();
      }

      let response;
      try {
        response = await fetch(fishMapApiUrl(fishId), {
          headers: { Accept: "application/json" },
          credentials: "same-origin",
        });
      } catch (_error) {
        state.detailCache.set(fishId, { loading: false, error: "Fish mapping request failed.", mapping: null });
        if (state.detailsFishId === fishId) {
          renderDetails();
        }
        return;
      }

      if (!response.ok) {
        state.detailCache.set(
          fishId,
          {
            loading: false,
            error: response.status === 404
              ? "Fish mapping not found."
              : `Fish mapping request failed (HTTP ${response.status}).`,
            mapping: null,
          }
        );
        if (state.detailsFishId === fishId) {
          renderDetails();
        }
        return;
      }

      try {
        const mapping = await response.json();
        state.detailCache.set(fishId, { loading: false, error: "", mapping });
      } catch (_error) {
        state.detailCache.set(fishId, { loading: false, error: "Fish mapping response could not be parsed.", mapping: null });
      }

      if (state.detailsFishId === fishId) {
        renderDetails();
      }
    }

    function openDetails(fishId) {
      if (!fishMetaById(fishId)) {
        return;
      }
      state.detailsFishId = fishId;
      renderDetails();
      loadDetailsMapping(fishId);
    }

    function bindDetailsControls() {
      if (state.detailsBound) {
        return;
      }
      const modal = document.getElementById("pokedex-details");
      if (!(modal instanceof HTMLElement)) {
        return;
      }
      modal.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) {
          return;
        }
        if (target.closest("[data-action='close-details']")) {
          closeDetails();
        }
      });
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && state.detailsFishId !== null) {
          closeDetails();
        }
      });
      state.detailsBound = true;
    }

    function sync(snapshot) {
      bindGridClicks();
      bindDetailsControls();

      const fish = Array.isArray(snapshot.fish) ? snapshot.fish : [];
      const caughtIds = normalizeCaughtIds(snapshot.caught_ids);
      state.currentCaughtIds = caughtIds;
      state.fishById = new Map(
        fish
          .filter((entry) => entry && Number.isInteger(entry.fish_id))
          .map((entry) => [entry.fish_id, entry])
      );
      const fishSignature = fishRenderSignature(fish);

      const renderKey = [
        snapshot.revision || "",
        fishSignature,
        (snapshot.search_query || "").trim().toLowerCase(),
        snapshot.prize_only ? "1" : "0",
        caughtIds.join(","),
      ].join("|");
      if (renderKey === state.renderKey) {
        renderDetails();
        return;
      }
      state.renderKey = renderKey;

      const supportsPrizeFilter = fish.some((entry) => entry && (entry.is_prize !== null || entry.grade));
      const searchQuery = (snapshot.search_query || "").trim().toLowerCase();
      const caughtSet = new Set(caughtIds);
      const filtered = fish.filter((entry) => {
        if (!entry) {
          return false;
        }
        const haystack = `${entry.fish_id || ""} ${entry.name || ""}`.toLowerCase();
        if (searchQuery && !haystack.includes(searchQuery)) {
          return false;
        }
        if (snapshot.prize_only && supportsPrizeFilter) {
          return entry.is_prize === true || entry.grade === "Prize";
        }
        return true;
      });

      const groups = new Map();
      for (const grade of GRADE_ORDER) {
        groups.set(grade, []);
      }
      for (const entry of filtered) {
        const grade = GRADE_ORDER.includes(entry.grade) ? entry.grade : "Unknown";
        groups.get(grade).push(entry);
      }

      const prizeCaughtCount = fish.filter((entry) => {
        return (entry.is_prize === true || entry.grade === "Prize") && caughtSet.has(entry.fish_id);
      }).length;

      const grid = document.getElementById("pokedex-grid");
      if (grid) {
        const fragment = document.createDocumentFragment();
        for (const grade of GRADE_ORDER) {
          const section = renderGroup(grade, groups.get(grade) || [], caughtSet);
          if (section) {
            fragment.appendChild(section);
          }
        }
        if (!filtered.length) {
          fragment.appendChild(renderEmptyState(searchQuery, snapshot.prize_only));
        }
        grid.replaceChildren(fragment);
      }

      const patch = {
        total_count: fish.length,
        visible_count: filtered.length,
        caught_count: caughtIds.length,
        prize_caught_count: prizeCaughtCount,
        supports_prize_filter: supportsPrizeFilter,
      };
      if (fish.length > 0) {
        patch.api_error_message = "";
        patch.api_error_hint = "";
      }
      mergeSignals(patch);
      renderDetails();
      scheduleViewportRestore();
    }

    function handleDatastarEvent(event) {
      const detail = event && event.detail ? event.detail : null;
      if (!detail) {
        return;
      }
      if (detail.type === "error") {
        const status = detail.argsRaw && detail.argsRaw.status;
        const message = status
          ? `Fish API request failed (HTTP ${status}).`
          : "Fish API request failed.";
        mergeSignals({
          api_error_message: message,
          api_error_hint: "If this page is on a different origin than the API, confirm the API CORS allowlist includes this site.",
        });
      }
      if (detail.type === "retrying") {
        mergeSignals({
          api_error_message: "Fish API request is retrying.",
          api_error_hint: detail.argsRaw && detail.argsRaw.message
            ? String(detail.argsRaw.message)
            : "The request could not be completed cleanly.",
        });
      }
    }

    function apiUrl(pathname) {
      const params = new URLSearchParams(window.location.search);
      const explicitBase = params.get("api_base");
      if (explicitBase) {
        return new URL(pathname, explicitBase).toString();
      }
      const isLocalSite = ["localhost", "127.0.0.1"].includes(window.location.hostname)
        && window.location.port === "1990";
      if (isLocalSite) {
        return new URL(pathname, "http://127.0.0.1:8080").toString();
      }
      return new URL(pathname, window.location.origin).toString();
    }

    function fishApiUrl() {
      return apiUrl("/api/v1/fish");
    }

    document.addEventListener(DATASTAR_EVENT, handleDatastarEvent);

    window.Pokedex = {
      resetFilters,
      restoreCaught,
      loadFish,
      sync,
      exportCaught,
      importCaught,
      fishApiUrl,
      closeDetails,
    };
  })();
</script>

<div id="pokedex-app" class="not-prose"
     data-signals="{
       fish: [],
       revision: '',
       count: 0,
       search_draft: '',
       search_query: '',
       prize_only: false,
       caught_ids: [],
       total_count: 0,
       visible_count: 0,
       caught_count: 0,
       prize_caught_count: 0,
       supports_prize_filter: false,
       loading: true,
       status_message: '',
       api_error_message: '',
       api_error_hint: '',
     }">

  <div data-indicator-loading
       data-on-load="window.Pokedex.resetFilters(); window.Pokedex.restoreCaught(); window.Pokedex.loadFish()"
       data-on-signals-change="window.Pokedex.sync({
         fish: $fish || [],
         revision: $revision || '',
         search_query: $search_query || '',
         prize_only: !!$prize_only,
         caught_ids: $caught_ids || [],
       })"></div>

  <section class="pokedex-shell">
    <div class="pokedex-top">
      <div class="pokedex-screen">
        <div class="pokedex-heading">
          <h3>Catalog Feed</h3>
          <span class="pokedex-subtle">Revision <span data-text="$revision || 'pending'"></span></span>
        </div>

        <div class="pokedex-controls">
          <label>
            <span class="sr-only">Search fish</span>
            <input class="pokedex-search"
                   type="search"
                   autocomplete="off"
                   placeholder="Search by fish name or ID"
                   data-bind-search_draft
                   data-on-input__debounce.125ms="$search_query = ($search_draft || '').trim()">
          </label>

          <div class="pokedex-toolbar">
            <label class="pokedex-toggle" data-show="$supports_prize_filter">
              <input type="checkbox" data-bind-prize_only>
              <span>Prize only</span>
            </label>

            <div class="pokedex-actions">
              <button type="button" class="pokedex-button" data-on-click="window.Pokedex.exportCaught($caught_ids || [])">Export</button>
              <button type="button" class="pokedex-button pokedex-button-secondary" data-on-click="window.Pokedex.importCaught()">Import</button>
            </div>
          </div>

          <div class="pokedex-status" data-show="($status_message || '').length > 0">
            <strong>Status:</strong>
            <span data-text="$status_message"></span>
          </div>

          <div class="pokedex-error" data-show="($api_error_message || '').length > 0">
            <strong data-text="$api_error_message"></strong>
            <div class="pokedex-subtle" data-show="($api_error_hint || '').length > 0" data-text="$api_error_hint"></div>
          </div>
        </div>
      </div>

      <aside class="pokedex-stats">
        <h3>Progress</h3>
        <div class="pokedex-stat-grid">
          <div class="pokedex-stat">
            <span class="pokedex-stat-label">Caught</span>
            <span class="pokedex-stat-value" data-text="$caught_count || 0"></span>
          </div>
          <div class="pokedex-stat">
            <span class="pokedex-stat-label">Prize Caught</span>
            <span class="pokedex-stat-value" data-text="$prize_caught_count || 0"></span>
          </div>
          <div class="pokedex-stat">
            <span class="pokedex-stat-label">Visible</span>
            <span class="pokedex-stat-value" data-text="$visible_count || 0"></span>
          </div>
          <div class="pokedex-stat">
            <span class="pokedex-stat-label">Catalog</span>
            <span class="pokedex-stat-value" data-text="$total_count || $count || 0"></span>
          </div>
        </div>
        <div class="pokedex-status" data-show="$loading">
          <strong>Loading...</strong>
          <div class="pokedex-subtle">Fetching the fish catalog from the Axum API.</div>
        </div>
        <div class="pokedex-status" data-show="!$loading">
          <strong>Interactive locally.</strong>
          <div class="pokedex-subtle">Caught state stays in this browser until you export it.</div>
        </div>
      </aside>
    </div>

    <div class="pokedex-grid-shell">
      <div id="pokedex-grid" class="pokedex-groups"></div>
    </div>
  </section>

  <div id="pokedex-details" class="pokedex-details-modal" hidden>
    <button type="button"
            class="pokedex-details-backdrop"
            data-action="close-details"
            aria-label="Close fish details"></button>

    <section class="pokedex-details-panel" role="dialog" aria-modal="true" aria-labelledby="pokedex-details-title">
      <div class="pokedex-details-header">
        <div class="pokedex-details-header-main">
          <div id="pokedex-details-icon-frame" class="pokedex-details-icon-wrap grade-unknown">
            <img id="pokedex-details-icon" class="pokedex-details-icon" hidden>
            <div id="pokedex-details-placeholder" class="pokedex-placeholder">?</div>
          </div>

          <div class="pokedex-details-copy">
            <div>
              <h3 id="pokedex-details-title" class="pokedex-details-title">Fish</h3>
            </div>

            <div class="pokedex-details-badges">
              <span id="pokedex-details-caught" class="pokedex-caught">Caught</span>
              <span id="pokedex-details-grade" class="pokedex-grade grade-unknown">Unknown</span>
              <span id="pokedex-details-prize" class="pokedex-grade grade-prize" hidden>Prize Fish</span>
            </div>
          </div>
        </div>
        <button type="button"
                class="pokedex-button pokedex-button-secondary pokedex-details-close"
                data-action="close-details">Close</button>
      </div>

      <div class="pokedex-details-guide">
        <div class="pokedex-details-guide-frame">
          <img id="pokedex-details-guide-image" class="pokedex-details-guide-image" hidden>
          <div id="pokedex-details-guide-placeholder" class="pokedex-placeholder">?</div>
        </div>
      </div>

      <dl class="pokedex-details-meta">
        <div class="pokedex-details-meta-card">
          <dt>Item Key</dt>
          <dd id="pokedex-details-item-key"></dd>
        </div>
        <div class="pokedex-details-meta-card">
          <dt>Encyclopedia Key</dt>
          <dd id="pokedex-details-encyclopedia-key"></dd>
        </div>
      </dl>

      <div class="pokedex-details-stack">
        <section class="pokedex-details-section">
          <h4>Best Spots</h4>
          <p id="pokedex-details-spots-note" class="pokedex-details-note"></p>
        </section>
      </div>
    </section>
  </div>
</div>
```
