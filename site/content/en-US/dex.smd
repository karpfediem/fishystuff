## Fishydex

```=html
<style>
  #fishydex-app {
    --dex-shell: color-mix(in oklab, var(--color-error, #d64545) 72%, var(--color-primary, #e07a5f) 28%);
    --dex-shell-border: color-mix(in oklab, var(--dex-shell) 74%, var(--color-neutral, #1f2937) 26%);
    --dex-screen: color-mix(in oklab, var(--color-base-100, #fffdf4) 82%, var(--color-base-200, #efe7d6) 18%);
    --dex-screen-border: color-mix(in oklab, var(--color-base-content, #1f2937) 18%, transparent);
    --dex-line: color-mix(in oklab, var(--color-base-content, #1f2937) 24%, transparent);
    --dex-highlight: color-mix(in oklab, var(--color-warning, #f4b942) 58%, var(--color-base-100, #fffdf4) 42%);
    --dex-prize: color-mix(in oklab, var(--color-error, #d64545) 74%, var(--color-base-100, #fffdf4) 26%);
    --dex-prize-surface: color-mix(in oklab, var(--color-error, #d64545) 18%, var(--color-base-200, #efe7d6) 82%);
    --dex-prize-surface-hover: color-mix(in oklab, var(--color-error, #d64545) 24%, var(--dex-surface) 76%);
    --dex-grade-rare: color-mix(in oklab, var(--color-warning, #f59e0b) 72%, var(--color-base-100, #fffdf4) 28%);
    --dex-grade-rare-surface: color-mix(in oklab, var(--color-warning, #f59e0b) 22%, var(--dex-surface-strong) 78%);
    --dex-grade-highquality: color-mix(in oklab, var(--color-info, #6b8afd) 76%, var(--color-base-100, #fffdf4) 24%);
    --dex-grade-highquality-surface: color-mix(in oklab, var(--color-info, #6b8afd) 22%, var(--dex-surface-strong) 78%);
    --dex-grade-general: color-mix(in oklab, var(--color-success, #2f855a) 72%, var(--color-base-100, #fffdf4) 28%);
    --dex-grade-general-surface: color-mix(in oklab, var(--color-success, #2f855a) 22%, var(--dex-surface-strong) 78%);
    --dex-grade-trash: color-mix(in oklab, var(--color-base-content, #1f2937) 18%, var(--color-base-100, #fffdf4) 82%);
    --dex-grade-trash-surface: color-mix(in oklab, var(--color-base-300, #d8d0c0) 54%, var(--color-base-100, #fffdf4) 46%);
    --dex-grade-unknown: color-mix(in oklab, var(--color-neutral, #1f2937) 46%, var(--color-base-100, #fffdf4) 54%);
    --dex-grade-unknown-surface: color-mix(in oklab, var(--color-neutral, #1f2937) 18%, var(--dex-surface-strong) 82%);
    --dex-caught: color-mix(in oklab, var(--color-success, #2f855a) 72%, var(--color-base-200, #111827) 28%);
    --dex-surface: color-mix(in oklab, var(--color-base-200, #efe7d6) 62%, var(--color-base-100, #fffdf4) 38%);
    --dex-surface-strong: color-mix(in oklab, var(--color-base-100, #fffdf4) 78%, var(--color-base-200, #efe7d6) 22%);
    --dex-surface-soft: color-mix(in oklab, var(--color-base-200, #efe7d6) 76%, var(--color-base-300, #d8d0c0) 24%);
    --dex-field: color-mix(in oklab, var(--color-base-100, #fffdf4) 60%, var(--color-base-200, #efe7d6) 40%);
    --dex-focus: color-mix(in oklab, var(--color-primary, #e07a5f) 60%, var(--color-base-100, #fffdf4) 40%);
    --dex-button: color-mix(in oklab, var(--color-primary, #e07a5f) 76%, var(--color-secondary, #6b8afd) 24%);
    --dex-button-secondary: color-mix(in oklab, var(--color-secondary, #6b8afd) 72%, var(--color-accent, #1f2937) 28%);
    --dex-button-line: color-mix(in oklab, var(--color-base-content, #1f2937) 18%, transparent);
    --dex-text-muted: color-mix(in oklab, var(--color-base-content, #1f2937) 68%, transparent);
    color-scheme: light dark;
    display: grid;
    gap: 1.5rem;
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-shell {
    border: 4px solid var(--dex-shell-border);
    border-radius: 2rem;
    background: var(--dex-shell);
    overflow: hidden;
  }

  .fishydex-top {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: minmax(0, 1.2fr) minmax(16rem, 0.8fr);
    padding: 1.5rem;
  }

  .fishydex-screen,
  .fishydex-stats {
    border-radius: 1.35rem;
    border: 3px solid var(--dex-screen-border);
    background: var(--dex-screen);
  }

  .fishydex-screen {
    padding: 1.25rem;
  }

  .fishydex-heading {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .fishydex-heading h3,
  .fishydex-stats h3,
  .fishydex-group-title {
    margin: 0;
    font-family: "Modak", "Trebuchet MS", sans-serif;
    font-weight: 400;
    letter-spacing: 0.03em;
  }

  .fishydex-heading h3,
  .fishydex-stats h3 {
    font-size: clamp(1.25rem, 2vw, 1.9rem);
  }

  .fishydex-subtle {
    color: var(--dex-text-muted);
    font-size: 0.95rem;
  }

  .fishydex-controls {
    display: grid;
    gap: 0.9rem;
  }

  .fishydex-search {
    appearance: none;
    width: 100%;
    border-radius: 999px;
    border: 2px solid var(--dex-line);
    background: var(--dex-field);
    color: var(--color-base-content, #1f2937);
    font: inherit;
    padding: 0.9rem 1rem;
    font-size: 1rem;
    transition: border-color 120ms ease, outline-color 120ms ease;
  }

  .fishydex-search::placeholder {
    color: var(--dex-text-muted);
    opacity: 1;
  }

  .fishydex-search:hover {
    border-color: color-mix(in oklab, var(--color-base-content, #1f2937) 34%, transparent);
  }

  .fishydex-search:focus,
  .fishydex-search:focus-visible {
    border-color: color-mix(in oklab, var(--color-primary, #e07a5f) 56%, var(--color-base-content, #1f2937) 44%);
    outline: 3px solid var(--dex-focus);
    outline-offset: 2px;
  }

  .fishydex-search:focus:not(:focus-visible) {
    outline: none;
  }

  .fishydex-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .fishydex-filter-stack {
    display: grid;
    gap: 0.85rem;
  }

  .fishydex-filter-group {
    display: grid;
    gap: 0.45rem;
  }

  .fishydex-filter-label {
    color: var(--dex-text-muted);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .fishydex-filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .fishydex-filter-chip {
    white-space: nowrap;
  }

  .fishydex-filter-chip.is-active {
    border-color: color-mix(in oklab, var(--dex-highlight) 56%, var(--color-base-content, #1f2937) 44%);
    background: color-mix(in oklab, var(--dex-highlight) 20%, var(--dex-surface-strong) 80%);
  }

  .fishydex-filter-chip.filter-caught.is-active {
    border-color: color-mix(in oklab, var(--dex-caught) 56%, var(--dex-line) 44%);
    background: color-mix(in oklab, var(--dex-caught) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-success, #2f855a) 82%, var(--color-base-content, #1f2937) 18%);
  }

  .fishydex-filter-chip.filter-missing.is-active {
    border-color: color-mix(in oklab, var(--color-base-content, #1f2937) 32%, transparent);
    background: color-mix(in oklab, var(--color-base-content, #1f2937) 10%, var(--dex-surface-strong) 90%);
  }

  .fishydex-filter-chip.filter-rod.is-active {
    border-color: color-mix(in oklab, var(--color-info, #6b8afd) 56%, var(--dex-line) 44%);
    background: color-mix(in oklab, var(--color-info, #6b8afd) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-info, #6b8afd) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-filter-chip.filter-harpoon.is-active {
    border-color: color-mix(in oklab, var(--color-secondary, #e07a5f) 56%, var(--dex-line) 44%);
    background: color-mix(in oklab, var(--color-secondary, #e07a5f) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-secondary, #e07a5f) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-filter-chip.filter-show-dried.is-active {
    border-color: color-mix(in oklab, var(--color-warning, #c77d19) 56%, var(--dex-line) 44%);
    background: color-mix(in oklab, var(--color-warning, #c77d19) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-warning, #c77d19) 76%, var(--color-base-content, #1f2937) 24%);
  }

  .fishydex-filter-chip.grade-prize.is-active {
    border-color: color-mix(in oklab, var(--dex-prize) 56%, var(--dex-line) 44%);
    background: var(--dex-prize-surface);
    color: color-mix(in oklab, var(--color-error, #d64545) 62%, var(--color-base-content, #1f2937) 38%);
  }

  .fishydex-filter-chip.grade-rare.is-active {
    border-color: color-mix(in oklab, var(--dex-grade-rare) 56%, var(--dex-line) 44%);
    background: var(--dex-grade-rare-surface);
    color: color-mix(in oklab, var(--dex-grade-rare) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-filter-chip.grade-highquality.is-active {
    border-color: color-mix(in oklab, var(--dex-grade-highquality) 56%, var(--dex-line) 44%);
    background: var(--dex-grade-highquality-surface);
    color: color-mix(in oklab, var(--dex-grade-highquality) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-filter-chip.grade-general.is-active {
    border-color: color-mix(in oklab, var(--dex-grade-general) 56%, var(--dex-line) 44%);
    background: var(--dex-grade-general-surface);
    color: color-mix(in oklab, var(--dex-grade-general) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-filter-chip.grade-trash.is-active {
    border-color: color-mix(in oklab, var(--dex-grade-trash) 56%, var(--dex-line) 44%);
    background: var(--dex-grade-trash-surface);
    color: color-mix(in oklab, var(--dex-grade-trash) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-filter-chip.grade-unknown.is-active {
    border-color: color-mix(in oklab, var(--dex-grade-unknown) 56%, var(--dex-line) 44%);
    background: var(--dex-grade-unknown-surface);
    color: color-mix(in oklab, var(--dex-grade-unknown) 68%, var(--color-base-content, #1f2937) 32%);
  }

  .fishydex-filter-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .fishydex-filter-clear {
    white-space: nowrap;
  }

  .fishydex-button {
    white-space: nowrap;
  }

  .fishydex-stats {
    display: grid;
    gap: 0.85rem;
    align-content: start;
    padding: 1.25rem;
  }

  .fishydex-stat-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .fishydex-stat {
    border-radius: 1rem;
    border: 1px solid var(--dex-line);
    background: var(--dex-surface-soft);
    padding: 0.9rem;
  }

  .fishydex-stat-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.72;
  }

  .fishydex-stat-value {
    display: block;
    font-size: clamp(1.3rem, 2vw, 2rem);
    font-weight: 800;
  }

  .fishydex-status,
  .fishydex-error {
    border-radius: 1rem;
    padding: 0.85rem 1rem;
  }

  .fishydex-status {
    background: color-mix(in oklab, var(--color-info, #6b8afd) 12%, var(--dex-surface-strong) 88%);
    border: 1px solid color-mix(in oklab, var(--color-info, #6b8afd) 30%, var(--dex-line) 70%);
  }

  .fishydex-error {
    background: color-mix(in oklab, var(--color-error, #d64545) 14%, var(--dex-surface-strong) 86%);
    border: 1px solid color-mix(in oklab, var(--color-error, #d64545) 34%, var(--dex-line) 66%);
  }

  .fishydex-status strong {
    color: color-mix(in oklab, var(--color-info, #6b8afd) 54%, var(--color-base-content, #1f2937) 46%);
  }

  .fishydex-error strong {
    color: color-mix(in oklab, var(--color-error, #d64545) 60%, var(--color-base-content, #1f2937) 40%);
  }

  .fishydex-grid-shell {
    padding: 0 1.5rem 1.5rem;
    overflow-anchor: none;
  }

  .fishydex-groups {
    display: grid;
    gap: 1rem;
    overflow-anchor: none;
  }

  .fishydex-group {
    border-radius: 1.4rem;
    border: 2px solid var(--dex-line);
    background: var(--dex-surface);
    color: var(--color-base-content, #1f2937);
    padding: 1rem;
  }

  .fishydex-group-header {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: baseline;
    margin-bottom: 0.9rem;
  }

  .fishydex-group-count {
    color: var(--dex-text-muted);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .fishydex-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(12rem, 1fr));
    gap: 0.85rem;
  }

  .fishydex-card {
    display: grid;
    min-height: 12.5rem;
    border: 2px solid var(--dex-line);
    border-radius: 1.25rem;
    background: var(--dex-surface-strong);
    color: var(--color-base-content, #1f2937);
    overflow: hidden;
    padding: 0.95rem;
    position: relative;
    transition: border-color 120ms ease, background 120ms ease, outline-color 120ms ease;
  }

  .fishydex-card.is-entering {
    animation: fishydex-card-in 220ms cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: var(--fishydex-card-delay, 0ms);
  }

  .fishydex-card:hover {
    border-color: color-mix(in oklab, var(--dex-highlight) 62%, var(--color-base-content, #1f2937) 38%);
    background: var(--dex-surface);
  }

  .fishydex-card:focus-within {
    border-color: color-mix(in oklab, var(--dex-highlight) 62%, var(--color-base-content, #1f2937) 38%);
    background: var(--dex-surface);
    outline: 3px solid var(--dex-focus);
    outline-offset: 2px;
  }

  .fishydex-card.is-caught {
    border-color: color-mix(in oklab, var(--dex-caught) 70%, var(--color-base-content, #1f2937) 30%);
  }

  .fishydex-card.is-prize {
    background: var(--dex-prize-surface);
    border-color: color-mix(in oklab, var(--dex-prize) 44%, var(--dex-line) 56%);
  }

  .fishydex-card.is-prize:hover,
  .fishydex-card.is-prize:focus-within {
    background: var(--dex-prize-surface-hover);
  }

  .fishydex-card-top {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 0.65rem;
  }

  .fishydex-card-open {
    appearance: none;
    position: absolute;
    inset: 0;
    border: 0;
    background: transparent;
    border-radius: inherit;
    cursor: pointer;
    margin: 0;
    padding: 0;
  }

  .fishydex-card-open:focus-visible {
    outline: none;
  }

  .fishydex-card-content {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.75rem;
    pointer-events: none;
    transition: transform 90ms ease;
  }

  .fishydex-card-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: start;
    gap: 0.45rem;
  }

  .fishydex-caught-button {
    appearance: none;
    pointer-events: auto;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: color-mix(in oklab, var(--color-base-content, #1f2937) 60%, transparent);
    cursor: pointer;
    display: grid;
    place-items: center;
    inline-size: 2.2rem;
    block-size: 2.2rem;
    padding: 0;
    transition: color 120ms ease, background 120ms ease, outline-color 120ms ease;
  }

  .fishydex-caught-button:hover {
    background: color-mix(in oklab, var(--dex-highlight) 18%, var(--dex-surface-soft) 82%);
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-caught-button:focus-visible {
    background: color-mix(in oklab, var(--dex-highlight) 18%, var(--dex-surface-soft) 82%);
    outline: 3px solid var(--dex-focus);
    outline-offset: 2px;
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-caught-button.is-caught {
    color: color-mix(in oklab, var(--color-success, #2f855a) 82%, var(--color-base-content, #1f2937) 18%);
  }

  .fishydex-caught-button.is-caught:hover,
  .fishydex-caught-button.is-caught:focus-visible {
    background: color-mix(in oklab, var(--dex-caught) 16%, var(--dex-surface-soft) 84%);
  }

  .fishydex-caught-button svg {
    inline-size: 2rem;
    block-size: 2rem;
    flex: none;
    transform-origin: 50% 60%;
  }

  .fishydex-caught-button.is-stamping svg {
    animation: fishydex-caught-stamp 360ms cubic-bezier(0.2, 0.9, 0.25, 1.15);
  }

  .fishydex-grade,
  .fishydex-caught,
  .fishydex-method {
    align-self: start;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    line-height: 1;
    padding: 0.3rem 0.6rem;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .fishydex-grade {
    background: color-mix(in oklab, var(--color-base-content, #1f2937) 10%, var(--dex-surface-soft) 90%);
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-grade.grade-prize {
    background: color-mix(in oklab, var(--dex-prize) 38%, var(--dex-surface-strong) 62%);
    color: color-mix(in oklab, var(--color-error, #d64545) 62%, var(--color-base-content, #1f2937) 38%);
  }

  .fishydex-grade.grade-rare {
    background: var(--dex-grade-rare-surface);
    color: color-mix(in oklab, var(--dex-grade-rare) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-grade.grade-highquality {
    background: var(--dex-grade-highquality-surface);
    color: color-mix(in oklab, var(--dex-grade-highquality) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-grade.grade-general {
    background: var(--dex-grade-general-surface);
    color: color-mix(in oklab, var(--dex-grade-general) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-grade.grade-trash {
    background: var(--dex-grade-trash-surface);
    color: color-mix(in oklab, var(--dex-grade-trash) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-grade.grade-unknown {
    background: var(--dex-grade-unknown-surface);
    color: color-mix(in oklab, var(--dex-grade-unknown) 68%, var(--color-base-content, #1f2937) 32%);
  }

  .fishydex-caught {
    background: color-mix(in oklab, var(--dex-caught) 24%, var(--dex-surface-strong) 76%);
    color: color-mix(in oklab, var(--color-success, #2f855a) 62%, var(--color-base-content, #1f2937) 38%);
  }

  .fishydex-method {
    background: color-mix(in oklab, var(--color-base-content, #1f2937) 10%, var(--dex-surface-soft) 90%);
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-method.method-rod {
    background: color-mix(in oklab, var(--color-info, #6b8afd) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-info, #6b8afd) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-method.method-harpoon {
    background: color-mix(in oklab, var(--color-secondary, #e07a5f) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-secondary, #e07a5f) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-method.method-dried {
    background: color-mix(in oklab, var(--color-warning, #c77d19) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-warning, #c77d19) 76%, var(--color-base-content, #1f2937) 24%);
  }

  .fishydex-caught-placeholder {
    visibility: hidden;
  }

  .fishydex-card-main {
    display: grid;
    justify-items: center;
    gap: 0.65rem;
    min-height: 7.8rem;
    transition: transform 120ms ease;
  }

  .fishydex-card:hover .fishydex-card-main,
  .fishydex-card:focus-within .fishydex-card-main {
    transform: translateY(-2px);
  }

  .fishydex-card-open:active + .fishydex-card-content {
    transform: translateY(1px);
  }

  .fishydex-card-open:active + .fishydex-card-content .fishydex-card-main {
    transform: translateY(0);
  }

  .fishydex-icon-wrap {
    display: grid;
    place-items: center;
    width: 4.75rem;
    height: 4.75rem;
    border-radius: 1.2rem;
    border: 1px solid var(--dex-line);
    background: var(--dex-surface-soft);
  }

  .fishydex-icon {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    margin: 0;
    object-fit: contain;
    image-rendering: auto;
  }

  .fishydex-placeholder {
    color: var(--dex-text-muted);
    font-size: 2rem;
  }

  .fishydex-name {
    font-weight: 800;
    line-height: 1.25;
    text-align: center;
  }

  .fishydex-empty {
    border: 2px dashed var(--dex-line);
    border-radius: 1.4rem;
    background: var(--dex-surface);
    color: var(--color-base-content, #1f2937);
    padding: 1.25rem;
    text-align: center;
  }

  @keyframes fishydex-card-in {
    from {
      opacity: 0;
      transform: translateY(0.5rem);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fishydex-caught-stamp {
    0% {
      transform: translateY(0) scale(1) rotate(0deg);
    }

    35% {
      transform: translateY(-0.42rem) scale(1.34) rotate(-13deg);
    }

    72% {
      transform: translateY(0.08rem) scale(0.94) rotate(0deg);
    }

    100% {
      transform: translateY(0) scale(1) rotate(0deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fishydex-card.is-entering {
      animation: none;
    }

    .fishydex-caught-button.is-stamping svg {
      animation: none;
    }
  }

  .fishydex-details-modal[hidden] {
    display: none;
  }

  .fishydex-details-modal {
    position: fixed;
    inset: 0;
    z-index: 40;
    display: grid;
    place-items: center;
    padding: 1rem;
  }

  .fishydex-details-backdrop {
    appearance: none;
    position: absolute;
    inset: 0;
    border: 0;
    background: color-mix(in oklab, var(--color-base-content, #1f2937) 36%, transparent);
    cursor: pointer;
    margin: 0;
    padding: 0;
  }

  .fishydex-details-panel {
    position: relative;
    z-index: 1;
    width: min(42rem, 100%);
    max-height: min(90vh, 46rem);
    overflow: auto;
    border-radius: 1.5rem;
    border: 3px solid var(--dex-screen-border);
    background: var(--dex-screen);
    color: var(--color-base-content, #1f2937);
    padding: 1.2rem;
  }

  .fishydex-details-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: start;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .fishydex-details-header-main {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
    min-width: 0;
  }

  .fishydex-details-title {
    margin: 0;
    font-family: "Modak", "Trebuchet MS", sans-serif;
    font-size: clamp(1.25rem, 2.2vw, 1.85rem);
    font-weight: 400;
    letter-spacing: 0.03em;
  }

  .fishydex-details-title-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem;
  }

  .fishydex-details-close {
    flex: none;
  }

  .fishydex-details-icon-wrap {
    display: grid;
    place-items: center;
    width: 5.5rem;
    height: 5.5rem;
    border-radius: 1.4rem;
    border: 2px solid var(--dex-line);
    background: var(--dex-surface-soft);
  }

  .fishydex-details-icon-wrap.grade-prize {
    border-color: color-mix(in oklab, var(--dex-prize) 64%, var(--dex-line) 36%);
    background: var(--dex-prize-surface);
  }

  .fishydex-details-icon-wrap.grade-rare {
    border-color: color-mix(in oklab, var(--dex-grade-rare) 64%, var(--dex-line) 36%);
    background: var(--dex-grade-rare-surface);
  }

  .fishydex-details-icon-wrap.grade-highquality {
    border-color: color-mix(in oklab, var(--dex-grade-highquality) 64%, var(--dex-line) 36%);
    background: var(--dex-grade-highquality-surface);
  }

  .fishydex-details-icon-wrap.grade-general {
    border-color: color-mix(in oklab, var(--dex-grade-general) 64%, var(--dex-line) 36%);
    background: var(--dex-grade-general-surface);
  }

  .fishydex-details-icon-wrap.grade-trash {
    border-color: color-mix(in oklab, var(--dex-grade-trash) 64%, var(--dex-line) 36%);
    background: var(--dex-grade-trash-surface);
  }

  .fishydex-details-icon-wrap.grade-unknown {
    border-color: color-mix(in oklab, var(--dex-grade-unknown) 64%, var(--dex-line) 36%);
    background: var(--dex-grade-unknown-surface);
  }

  .fishydex-details-icon {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .fishydex-details-copy {
    display: grid;
    gap: 0.75rem;
    min-width: 0;
  }

  .fishydex-details-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .fishydex-details-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
    gap: 0.75rem;
  }

  .fishydex-details-guide {
    margin-bottom: 1rem;
  }

  .fishydex-details-guide-frame {
    display: grid;
    place-items: center;
    min-height: 14rem;
    border-radius: 1.35rem;
    border: 1px solid var(--dex-line);
    background: var(--dex-surface);
    padding: 1rem;
  }

  .fishydex-details-guide-image {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 16rem;
    object-fit: contain;
  }

  .fishydex-details-meta-card,
  .fishydex-details-section {
    border-radius: 1rem;
    border: 1px solid var(--dex-line);
    background: var(--dex-surface);
    padding: 0.85rem 0.95rem;
  }

  .fishydex-details-meta-card dt {
    margin: 0 0 0.35rem;
    color: var(--dex-text-muted);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .fishydex-details-meta-card dd {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
  }

  .fishydex-details-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--dex-highlight) 52%, transparent);
    text-underline-offset: 0.14em;
  }

  .fishydex-details-link:hover,
  .fishydex-details-link:focus-visible {
    color: color-mix(in oklab, var(--dex-highlight) 72%, var(--color-base-content, #1f2937) 28%);
    text-decoration-color: currentColor;
  }

  .fishydex-details-stack {
    display: grid;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .fishydex-details-section h4 {
    margin: 0 0 0.45rem;
    font-size: 1rem;
  }

  .fishydex-details-note {
    margin: 0.6rem 0 0;
    color: var(--dex-text-muted);
    font-size: 0.92rem;
  }

  .fishydex-details-note.is-error {
    color: color-mix(in oklab, var(--color-error, #d64545) 62%, var(--color-base-content, #1f2937) 38%);
  }

  @media (max-width: 900px) {
    .fishydex-top {
      grid-template-columns: 1fr;
    }

    .fishydex-details-header {
      grid-template-columns: 1fr;
    }

    .fishydex-details-header-main {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    #content {
      padding: 1rem;
    }

    .fishydex-top,
    .fishydex-grid-shell {
      padding: 1rem;
    }

    .fishydex-stat-grid {
      grid-template-columns: 1fr 1fr;
    }

    .fishydex-card-grid {
      grid-template-columns: repeat(auto-fill, minmax(9.75rem, 1fr));
    }
  }
</style>

  <script>
  (() => {
    const STORAGE_KEY = "fishystuff.fishydex.caught.v1";
    const DATASTAR_EVENT = "datastar-sse";
    const DATASTAR_MERGE_SIGNALS = "datastar-merge-signals";
    const GRADE_ORDER = ["Prize", "Rare", "HighQuality", "General", "Trash", "Unknown"];
    const GRADE_FILTER_ORDER = ["Prize", "Rare", "HighQuality", "General", "Trash"];
    const GRADE_LABELS = {
      Prize: "Red",
      Rare: "Yellow",
      HighQuality: "Blue",
      General: "Green",
      Trash: "White",
      Unknown: "Unknown",
    };
    const HEROICON_CHECK_BADGE_OUTLINE = `
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
      </svg>
    `;
    const HEROICON_CHECK_BADGE_SOLID = `
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6" aria-hidden="true">
        <path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0 1 12 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 0 1 3.498 1.307 4.491 4.491 0 0 1 1.307 3.497A4.49 4.49 0 0 1 21.75 12a4.49 4.49 0 0 1-1.549 3.397 4.491 4.491 0 0 1-1.307 3.497 4.491 4.491 0 0 1-3.497 1.307A4.49 4.49 0 0 1 12 21.75a4.49 4.49 0 0 1-3.397-1.549 4.49 4.49 0 0 1-3.498-1.306 4.491 4.491 0 0 1-1.307-3.498A4.49 4.49 0 0 1 2.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 0 1 1.307-3.497 4.49 4.49 0 0 1 3.497-1.307Zm7.007 6.387a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" />
      </svg>
    `;
    const CAUGHT_FILTER_ORDER = ["all", "caught", "missing"];
    const METHOD_ORDER = ["rod", "harpoon"];
    const SORT_FIELD_ORDER = ["name", "price"];
    const SORT_DIRECTION_ORDER = ["asc", "desc"];
    const METHOD_LABELS = {
      rod: "Rod",
      harpoon: "Harpoon",
      unknown: "Unknown",
    };
    const SILVER_FORMATTER = new Intl.NumberFormat();
    const state = {
      currentCaughtIds: [],
      currentCaughtFilter: "all",
      currentGradeFilters: [],
      currentMethodFilters: [],
      currentShowDried: false,
      currentSortField: "name",
      currentSortDirection: "asc",
      fishById: new Map(),
      detailCache: new Map(),
      detailsFishId: null,
      detailsBound: false,
      renderKey: "",
      gridBound: false,
      pendingViewportRestore: null,
      pendingViewportFrame: 0,
      suppressCardAnimation: false,
      pendingCaughtStampFishId: null,
      pendingCaughtStampTimer: 0,
    };

    function mergeSignals(patch) {
      document.dispatchEvent(new CustomEvent(DATASTAR_EVENT, {
        detail: {
          type: DATASTAR_MERGE_SIGNALS,
          argsRaw: {
            signals: JSON.stringify(patch),
          },
        },
      }));
    }

    function normalizeFishPayload(payload) {
      const fish = Array.isArray(payload && payload.fish) ? payload.fish : [];
      const count = Number(payload && payload.count);
      return {
        revision: typeof (payload && payload.revision) === "string" ? payload.revision : "",
        count: Number.isFinite(count) ? count : fish.length,
        fish,
        loading: false,
        status_message: typeof (payload && payload.status_message) === "string" ? payload.status_message : "",
        api_error_message: typeof (payload && payload.api_error_message) === "string" ? payload.api_error_message : "",
        api_error_hint: typeof (payload && payload.api_error_hint) === "string" ? payload.api_error_hint : "",
      };
    }

    function parseDatastarSignalsStream(streamText) {
      const lines = streamText.split(/\r?\n/);
      let eventType = "";
      let dataLines = [];

      function decodePatch() {
        if (eventType !== DATASTAR_MERGE_SIGNALS) {
          return null;
        }
        for (const rawLine of dataLines) {
          const line = rawLine.trim();
          if (!line.startsWith("signals ")) {
            continue;
          }
          return normalizeFishPayload(JSON.parse(line.slice("signals ".length)));
        }
        return null;
      }

      for (const line of lines) {
        if (line.startsWith("event:")) {
          eventType = line.slice("event:".length).trim();
          continue;
        }
        if (line.startsWith("data:")) {
          dataLines.push(line.slice("data:".length).trimStart());
          continue;
        }
        if (line.trim() === "") {
          const patch = decodePatch();
          if (patch) {
            return patch;
          }
          eventType = "";
          dataLines = [];
        }
      }

      const patch = decodePatch();
      if (patch) {
        return patch;
      }
      throw new Error("Fish API did not return a Datastar signal patch.");
    }

    async function loadFish() {
      mergeSignals({
        loading: true,
        api_error_message: "",
        api_error_hint: "",
        status_message: "",
      });

      let response;
      try {
        response = await fetch(fishApiUrl(), {
          headers: {
            Accept: "text/event-stream, application/json",
            "Datastar-Request": "true",
          },
          credentials: "same-origin",
        });
      } catch (_error) {
        mergeSignals({
          loading: false,
          api_error_message: "Fish API request failed.",
          api_error_hint: "If this page is on a different origin than the API, confirm the API CORS allowlist includes this site.",
        });
        return;
      }

      if (!response.ok) {
        mergeSignals({
          loading: false,
          api_error_message: `Fish API request failed (HTTP ${response.status}).`,
          api_error_hint: "If this page is on a different origin than the API, confirm the API CORS allowlist includes this site.",
        });
        return;
      }

      try {
        const contentType = response.headers.get("content-type") || "";
        if (contentType.includes("text/event-stream")) {
          mergeSignals(parseDatastarSignalsStream(await response.text()));
          return;
        }
        mergeSignals(normalizeFishPayload(await response.json()));
      } catch (_error) {
        mergeSignals({
          loading: false,
          api_error_message: "Fish API response could not be parsed.",
          api_error_hint: "Confirm the API is serving either Datastar SSE or JSON fish data.",
        });
      }
    }

    function normalizeCaughtIds(value) {
      let ids = [];
      if (Array.isArray(value)) {
        ids = value;
      } else if (value && typeof value === "object") {
        ids = Object.entries(value)
          .filter(([, enabled]) => enabled)
          .map(([fishId]) => fishId);
      }

      const unique = new Set();
      for (const raw of ids) {
        const fishId = Number.parseInt(String(raw), 10);
        if (Number.isInteger(fishId) && fishId > 0) {
          unique.add(fishId);
        }
      }
      return Array.from(unique).sort((left, right) => left - right);
    }

    function parseCaughtJson(raw) {
      return normalizeCaughtIds(JSON.parse(raw));
    }

    function persistCaughtIds(caughtIds) {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(caughtIds));
      } catch (_error) {
        mergeSignals({ status_message: "localStorage is unavailable; progress is not persisted." });
      }
    }

    function resetFilters() {
      mergeSignals({
        search_draft: "",
        search_query: "",
        caught_filter: "all",
        grade_filters: [],
        method_filters: [],
        show_dried: false,
      });
    }

    function restoreCaught() {
      let caughtIds = [];
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (raw) {
          try {
            caughtIds = parseCaughtJson(raw);
          } catch (_error) {
            localStorage.removeItem(STORAGE_KEY);
            mergeSignals({ status_message: "Reset corrupted local fishydex progress." });
          }
        }
      } catch (_error) {
        mergeSignals({ status_message: "localStorage is unavailable; progress is not persisted." });
      }
      state.currentCaughtIds = caughtIds;
      mergeSignals({ caught_ids: caughtIds });
    }

    function queueCaughtStamp(fishId, isCaught) {
      if (state.pendingCaughtStampTimer) {
        window.clearTimeout(state.pendingCaughtStampTimer);
        state.pendingCaughtStampTimer = 0;
      }
      if (!isCaught || !Number.isInteger(fishId)) {
        state.pendingCaughtStampFishId = null;
        return;
      }
      state.pendingCaughtStampFishId = fishId;
      state.pendingCaughtStampTimer = window.setTimeout(() => {
        if (state.pendingCaughtStampFishId === fishId) {
          state.pendingCaughtStampFishId = null;
        }
        state.pendingCaughtStampTimer = 0;
      }, 420);
    }

    function shouldStampCaughtToggle(fishId, isCaught) {
      return isCaught && Number.isInteger(fishId) && state.pendingCaughtStampFishId === fishId;
    }

    function toggleCaught(fishId) {
      const next = new Set(state.currentCaughtIds);
      if (next.has(fishId)) {
        next.delete(fishId);
      } else {
        next.add(fishId);
      }
      const caughtIds = Array.from(next).sort((left, right) => left - right);
      state.currentCaughtIds = caughtIds;
      queueCaughtStamp(fishId, next.has(fishId));
      state.suppressCardAnimation = true;
      persistCaughtIds(caughtIds);
      mergeSignals({ caught_ids: caughtIds, status_message: "" });
    }

    function rememberViewport(card, anchor) {
      if (!(card instanceof HTMLElement)) {
        state.pendingViewportRestore = null;
        return;
      }
      const fishId = Number.parseInt(card.dataset.fishId || "", 10);
      if (!Number.isInteger(fishId)) {
        state.pendingViewportRestore = null;
        return;
      }
      const anchorElement = anchor instanceof HTMLElement ? anchor : card;
      const restoreFocusSelector = anchorElement.closest("[data-action='toggle-caught']")
        ? "[data-action='toggle-caught']"
        : anchorElement.closest("[data-action='open-details']")
          ? "[data-action='open-details']"
          : "";
      state.pendingViewportRestore = {
        fishId,
        anchorTop: anchorElement.getBoundingClientRect().top,
        scrollX: window.scrollX,
        scrollY: window.scrollY,
        restoreFocusSelector,
      };
    }

    function scheduleViewportRestore() {
      if (!state.pendingViewportRestore) {
        return;
      }
      if (state.pendingViewportFrame) {
        window.cancelAnimationFrame(state.pendingViewportFrame);
      }
      state.pendingViewportFrame = window.requestAnimationFrame(() => {
        state.pendingViewportFrame = 0;
        const pending = state.pendingViewportRestore;
        state.pendingViewportRestore = null;
        if (!pending) {
          return;
        }

        const nextCard = document.querySelector(`[data-fish-id="${pending.fishId}"]`);
        if (!(nextCard instanceof HTMLElement)) {
          window.scrollTo(pending.scrollX, pending.scrollY);
          return;
        }

        const nextAnchor = pending.restoreFocusSelector
          ? nextCard.matches(pending.restoreFocusSelector)
            ? nextCard
            : nextCard.querySelector(pending.restoreFocusSelector)
          : nextCard;
        if (nextAnchor instanceof HTMLElement) {
          nextAnchor.focus({ preventScroll: true });
          const delta = nextAnchor.getBoundingClientRect().top - pending.anchorTop;
          if (Math.abs(delta) > 1.5 || Math.abs(pending.scrollX - window.scrollX) > 0.5) {
            window.scrollTo(pending.scrollX, window.scrollY + delta);
          }
          return;
        }
        window.scrollTo(pending.scrollX, pending.scrollY);
      });
    }

    function downloadJson(filename, text) {
      const blob = new Blob([text], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = filename;
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(url);
    }

    async function exportCaught(caughtIds) {
      const normalized = normalizeCaughtIds(caughtIds);
      const text = JSON.stringify(normalized, null, 2);
      try {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          await navigator.clipboard.writeText(text);
          mergeSignals({ status_message: `Copied ${normalized.length} caught fish IDs.` });
          return;
        }
      } catch (_error) {
      }
      downloadJson("fishystuff-fishydex-caught.json", text);
      mergeSignals({ status_message: `Downloaded ${normalized.length} caught fish IDs.` });
    }

    function importCaught() {
      const raw = window.prompt("Paste caught fish JSON (array of IDs or an id:true map).");
      if (raw === null) {
        return;
      }
      try {
        const caughtIds = parseCaughtJson(raw);
        state.currentCaughtIds = caughtIds;
        persistCaughtIds(caughtIds);
        mergeSignals({
          caught_ids: caughtIds,
          status_message: `Imported ${caughtIds.length} caught fish IDs.`,
        });
      } catch (_error) {
        mergeSignals({
          status_message: "Import failed. Paste a JSON array of fish IDs or a map like {\"8474\": true}.",
        });
      }
    }

    function slugifyGrade(value) {
      return String(value || "unknown").toLowerCase();
    }

    function gradeLabel(value) {
      const grade = GRADE_ORDER.find((candidate) => candidate === String(value));
      return grade ? GRADE_LABELS[grade] : GRADE_LABELS.Unknown;
    }

    function normalizeMethod(value) {
      const normalized = String(value || "").trim().toLowerCase();
      return normalized === "harpoon" ? "harpoon" : normalized === "rod" ? "rod" : "unknown";
    }

    function normalizeMethodList(values) {
      const rawValues = Array.isArray(values)
        ? values
        : values === undefined || values === null
          ? []
          : [values];
      const selected = new Set();
      for (const raw of rawValues) {
        const method = normalizeMethod(raw);
        if (method !== "unknown") {
          selected.add(method);
        }
      }
      return METHOD_ORDER.filter((method) => selected.has(method));
    }

    function entryCatchMethods(entry) {
      if (!entry) {
        return [];
      }
      const methods = Array.isArray(entry.catch_methods)
        ? normalizeMethodList(entry.catch_methods)
        : normalizeMethodList(entry.catch_method);
      return methods.length ? methods : ["rod"];
    }

    function methodLabel(values) {
      const methods = normalizeMethodList(values);
      if (!methods.length) {
        return METHOD_LABELS.rod;
      }
      return methods.map((method) => METHOD_LABELS[method] || METHOD_LABELS.unknown).join(" + ");
    }

    function formatSilver(value) {
      const amount = Number(value);
      if (!Number.isFinite(amount) || amount <= 0) {
        return "Unavailable";
      }
      return `${SILVER_FORMATTER.format(amount)} silver`;
    }

    function normalizeBooleanFlag(value) {
      return value === true || value === "true" || value === 1 || value === "1";
    }

    function normalizeSortField(value) {
      const normalized = String(value || "name").trim().toLowerCase();
      return SORT_FIELD_ORDER.includes(normalized) ? normalized : "name";
    }

    function normalizeSortDirection(value) {
      const normalized = String(value || "asc").trim().toLowerCase();
      return SORT_DIRECTION_ORDER.includes(normalized) ? normalized : "asc";
    }

    function normalizeCaughtFilter(value) {
      const normalized = String(value || "all").trim().toLowerCase();
      return CAUGHT_FILTER_ORDER.includes(normalized) ? normalized : "all";
    }

    function normalizeMethodFilters(value) {
      const rawValues = Array.isArray(value)
        ? value
        : value === undefined || value === null || value === "all"
          ? []
          : [value];
      const selected = [];
      for (const raw of rawValues) {
        const method = normalizeMethod(raw);
        if (METHOD_ORDER.includes(method) && !selected.includes(method)) {
          selected.push(method);
        }
      }
      return METHOD_ORDER.filter((method) => selected.includes(method));
    }

    function normalizeGradeFilters(value) {
      const rawValues = Array.isArray(value) ? value : [];
      const selected = [];
      for (const raw of rawValues) {
        const grade = GRADE_FILTER_ORDER.find((candidate) => candidate === String(raw));
        if (grade && !selected.includes(grade)) {
          selected.push(grade);
        }
      }
      return selected;
    }

    function filterGradeForEntry(entry) {
      if (!entry) {
        return "Unknown";
      }
      if (entry.is_prize === true || entry.grade === "Prize") {
        return "Prize";
      }
      return GRADE_ORDER.includes(entry.grade) ? entry.grade : "Unknown";
    }

    function filterMethodsForEntry(entry) {
      return entryCatchMethods(entry);
    }

    function entryIsDried(entry) {
      return normalizeBooleanFlag(entry && entry.is_dried);
    }

    function syncFilterUi(caughtFilter, gradeFilters, methodFilters, showDried, sortField, sortDirection) {
      for (const button of document.querySelectorAll("[data-caught-filter-value]")) {
        if (!(button instanceof HTMLButtonElement)) {
          continue;
        }
        const active = button.dataset.caughtFilterValue === caughtFilter;
        button.classList.toggle("is-active", active);
        button.classList.toggle("btn-active", active);
        button.setAttribute("aria-pressed", active ? "true" : "false");
      }

      const selectedGrades = new Set(gradeFilters);
      for (const button of document.querySelectorAll("[data-grade-filter-value]")) {
        if (!(button instanceof HTMLButtonElement)) {
          continue;
        }
        const grade = button.dataset.gradeFilterValue || "";
        const active = selectedGrades.has(grade);
        button.classList.toggle("is-active", active);
        button.classList.toggle("btn-active", active);
        button.setAttribute("aria-pressed", active ? "true" : "false");
      }

      const selectedMethods = new Set(methodFilters);
      for (const button of document.querySelectorAll("[data-method-filter-value]")) {
        if (!(button instanceof HTMLButtonElement)) {
          continue;
        }
        const method = button.dataset.methodFilterValue || "";
        const active = method === "all" ? selectedMethods.size === 0 : selectedMethods.has(method);
        button.classList.toggle("is-active", active);
        button.classList.toggle("btn-active", active);
        button.setAttribute("aria-pressed", active ? "true" : "false");
      }

      for (const button of document.querySelectorAll("[data-dried-toggle]")) {
        if (!(button instanceof HTMLButtonElement)) {
          continue;
        }
        const active = showDried;
        button.classList.toggle("is-active", active);
        button.classList.toggle("btn-active", active);
        button.setAttribute("aria-pressed", active ? "true" : "false");
      }

      for (const button of document.querySelectorAll("[data-sort-field-value]")) {
        if (!(button instanceof HTMLButtonElement)) {
          continue;
        }
        const active = button.dataset.sortFieldValue === sortField;
        button.classList.toggle("is-active", active);
        button.classList.toggle("btn-active", active);
        button.setAttribute("aria-pressed", active ? "true" : "false");
      }

      for (const button of document.querySelectorAll("[data-sort-direction-toggle]")) {
        if (!(button instanceof HTMLButtonElement)) {
          continue;
        }
        button.classList.add("is-active");
        button.setAttribute("aria-pressed", sortDirection === "desc" ? "true" : "false");
        button.textContent = sortDirection === "desc" ? "Descending" : "Ascending";
        button.setAttribute("aria-label", `Toggle sort direction. Current: ${sortDirection === "desc" ? "descending" : "ascending"}.`);
      }
    }

    function setCaughtFilter(value) {
      const next = normalizeCaughtFilter(value);
      state.currentCaughtFilter = next;
      mergeSignals({ caught_filter: next });
    }

    function clearMethodFilters() {
      state.currentMethodFilters = [];
      mergeSignals({ method_filters: [] });
    }

    function toggleMethodFilter(value) {
      const method = METHOD_ORDER.find((candidate) => candidate === normalizeMethod(value));
      if (!method) {
        return;
      }
      const next = new Set(state.currentMethodFilters);
      if (next.has(method)) {
        next.delete(method);
      } else {
        next.add(method);
      }
      const selected = METHOD_ORDER.filter((candidate) => next.has(candidate));
      state.currentMethodFilters = selected;
      mergeSignals({ method_filters: selected });
    }

    function setShowDried(value) {
      const next = normalizeBooleanFlag(value);
      state.currentShowDried = next;
      mergeSignals({ show_dried: next });
    }

    function toggleShowDried() {
      setShowDried(!state.currentShowDried);
    }

    function setSortField(value) {
      const next = normalizeSortField(value);
      state.currentSortField = next;
      mergeSignals({ sort_field: next });
    }

    function setSortDirection(value) {
      const next = normalizeSortDirection(value);
      state.currentSortDirection = next;
      mergeSignals({ sort_direction: next });
    }

    function toggleSortDirection() {
      setSortDirection(state.currentSortDirection === "desc" ? "asc" : "desc");
    }

    function toggleGradeFilter(value) {
      const grade = GRADE_FILTER_ORDER.find((candidate) => candidate === value);
      if (!grade) {
        return;
      }
      const next = new Set(state.currentGradeFilters);
      if (next.has(grade)) {
        next.delete(grade);
      } else {
        next.add(grade);
      }
      const selected = GRADE_FILTER_ORDER.filter((candidate) => next.has(candidate));
      state.currentGradeFilters = selected;
      mergeSignals({ grade_filters: selected });
    }

    function createElement(tagName, className, textContent) {
      const element = document.createElement(tagName);
      if (className) {
        element.className = className;
      }
      if (textContent !== undefined) {
        element.textContent = textContent;
      }
      return element;
    }

    function fishRenderSignature(fish) {
      let hash = 2166136261;
      for (const entry of fish) {
        const raw = entry
          ? `${entry.fish_id || 0}|${entry.grade || ""}|${entry.is_prize === true ? 1 : 0}|${entry.name || ""}|${entryIsDried(entry) ? 1 : 0}|${entryCatchMethods(entry).join(",")}|${entry.vendor_price || 0}`
          : "null";
        for (let index = 0; index < raw.length; index += 1) {
          hash ^= raw.charCodeAt(index);
          hash = Math.imul(hash, 16777619);
        }
      }
      return `${fish.length}:${(hash >>> 0).toString(16)}`;
    }

    function compareFishNames(left, right) {
      return String(left?.name || "").localeCompare(String(right?.name || ""), undefined, {
        sensitivity: "base",
        numeric: true,
      });
    }

    function entryVendorPrice(entry) {
      const amount = Number(entry && entry.vendor_price);
      return Number.isFinite(amount) && amount > 0 ? amount : null;
    }

    function compareFishEntries(left, right, sortField, sortDirection) {
      if (sortField === "price") {
        const leftPrice = entryVendorPrice(left);
        const rightPrice = entryVendorPrice(right);
        if (leftPrice === null && rightPrice !== null) {
          return 1;
        }
        if (leftPrice !== null && rightPrice === null) {
          return -1;
        }
        if (leftPrice !== null && rightPrice !== null && leftPrice !== rightPrice) {
          return sortDirection === "desc" ? rightPrice - leftPrice : leftPrice - rightPrice;
        }
      }

      const nameOrder = compareFishNames(left, right);
      if (nameOrder !== 0) {
        return sortDirection === "desc" && sortField === "name" ? -nameOrder : nameOrder;
      }
      return (left?.fish_id || 0) - (right?.fish_id || 0);
    }

    function renderEmptyState(hasActiveFilters) {
      const empty = createElement("div", "fishydex-empty");
      const title = createElement("h3", "fishydex-group-title", "No fish match this filter.");
      const detail = createElement(
        "p",
        "fishydex-subtle",
        hasActiveFilters
          ? "Try a broader search or clear some filters."
          : "The fish catalog is empty."
      );
      empty.append(title, detail);
      return empty;
    }

    function renderFishCard(fish, caughtSet, animationIndex, animateCards) {
      const isCaught = caughtSet.has(fish.fish_id);
      const stampCaught = shouldStampCaughtToggle(fish.fish_id, isCaught);
      const card = createElement("article", "fishydex-card");
      card.dataset.fishId = String(fish.fish_id);
      if (animateCards) {
        card.classList.add("is-entering");
        card.style.setProperty("--fishydex-card-delay", `${Math.min(animationIndex, 11) * 24}ms`);
      }
      if (isCaught) {
        card.classList.add("is-caught");
      }
      if (fish.is_prize || fish.grade === "Prize") {
        card.classList.add("is-prize");
      }

      const openButton = createElement("button", "fishydex-card-open");
      openButton.type = "button";
      openButton.dataset.action = "open-details";
      openButton.setAttribute("aria-haspopup", "dialog");
      openButton.setAttribute("aria-label", `Open details for ${fish.name || `Fish ${fish.fish_id}`}`);

      const content = createElement("div", "fishydex-card-content");
      const top = createElement("div", "fishydex-card-top");
      const actions = createElement("div", "fishydex-card-actions");
      const caughtButton = createElement(
        "button",
        `fishydex-caught-button${isCaught ? " is-caught" : ""}${stampCaught ? " is-stamping" : ""}`
      );
      caughtButton.type = "button";
      caughtButton.dataset.action = "toggle-caught";
      caughtButton.dataset.fishId = String(fish.fish_id);
      caughtButton.setAttribute("aria-pressed", isCaught ? "true" : "false");
      caughtButton.setAttribute(
        "aria-label",
        `Mark ${fish.name || `Fish ${fish.fish_id}`} as ${isCaught ? "not caught" : "caught"}`
      );
      caughtButton.innerHTML = isCaught ? HEROICON_CHECK_BADGE_SOLID : HEROICON_CHECK_BADGE_OUTLINE;
      actions.appendChild(caughtButton);
      top.appendChild(actions);

      if (fish.grade) {
        const grade = createElement(
          "span",
          `fishydex-grade grade-${slugifyGrade(fish.grade)}`,
          gradeLabel(filterGradeForEntry(fish))
        );
        top.appendChild(grade);
      }

      const main = createElement("div", "fishydex-card-main");
      const iconWrap = createElement("div", "fishydex-icon-wrap");
      const iconUrl = normalizeFishIconUrl(fish.icon_url);
      if (iconUrl) {
        const icon = createElement("img", "fishydex-icon");
        icon.src = iconUrl;
        icon.alt = `${fish.name} icon`;
        icon.loading = "lazy";
        iconWrap.appendChild(icon);
      } else {
        iconWrap.appendChild(createElement("div", "fishydex-placeholder", "?"));
      }
      main.appendChild(iconWrap);
      main.appendChild(createElement("div", "fishydex-name", fish.name || `Fish ${fish.fish_id}`));

      content.append(top, main);
      card.append(openButton, content);
      return card;
    }

    function renderGroup(title, fish, caughtSet, animationIndex, animateCards) {
      if (!fish.length) {
        return null;
      }

      const section = createElement("section", "fishydex-group");
      const header = createElement("div", "fishydex-group-header");
      header.appendChild(createElement("h3", "fishydex-group-title", gradeLabel(title)));
      header.appendChild(createElement("span", "fishydex-group-count", `${fish.length} fish`));

      const grid = createElement("div", "fishydex-card-grid");
      let nextAnimationIndex = animationIndex;
      for (const entry of fish) {
        grid.appendChild(renderFishCard(entry, caughtSet, nextAnimationIndex, animateCards));
        nextAnimationIndex += 1;
      }

      section.append(header, grid);
      return {
        section,
        nextAnimationIndex,
      };
    }

    function bindGridClicks() {
      if (state.gridBound) {
        return;
      }
      const grid = document.getElementById("fishydex-grid");
      if (!grid) {
        return;
      }
      grid.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) {
          return;
        }
        const card = target.closest("[data-fish-id]");
        if (!card) {
          return;
        }
        const fishId = Number.parseInt(card.dataset.fishId || "", 10);
        if (!Number.isInteger(fishId)) {
          return;
        }
        const toggleButton = target.closest("[data-action='toggle-caught']");
        if (toggleButton) {
          rememberViewport(card, toggleButton);
          toggleCaught(fishId);
          return;
        }
        openDetails(fishId);
      });
      state.gridBound = true;
    }

    function fishMetaById(fishId) {
      if (!Number.isInteger(fishId)) {
        return null;
      }
      const fish = state.fishById.get(fishId);
      if (!fish) {
        return null;
      }
      return {
        fishId,
        name: fish.name || `Fish ${fishId}`,
        grade: fish.grade || "Unknown",
        isPrize: fish.is_prize === true || fish.grade === "Prize",
        iconUrl: fish.icon_url || "",
        isDried: entryIsDried(fish),
        catchMethods: entryCatchMethods(fish),
        vendorPrice: Number.isFinite(Number(fish.vendor_price)) && Number(fish.vendor_price) > 0
          ? Number(fish.vendor_price)
          : null,
        caught: state.currentCaughtIds.includes(fishId),
      };
    }

    function fishMapApiUrl(fishId) {
      const url = new URL(apiUrl("/api/v1/fish_map"));
      url.searchParams.set("item_key", String(fishId));
      return url.toString();
    }

    function cdnBaseUrl() {
      const candidates = [
        window.__fishystuffCdnBaseUrl,
        window.__fishystuffRuntimeConfig && window.__fishystuffRuntimeConfig.cdnBaseUrl,
        "https://cdn.fishystuff.fish",
      ];
      for (const value of candidates) {
        const explicitBase = String(value || "").trim();
        if (explicitBase) {
          return explicitBase.replace(/\/+$/, "");
        }
      }
      return "https://cdn.fishystuff.fish";
    }

    function cdnUrl(path) {
      const raw = String(path || "").trim();
      if (!raw) {
        return "";
      }
      if (
        raw.startsWith("http://")
        || raw.startsWith("https://")
        || raw.startsWith("data:")
      ) {
        return raw;
      }
      const base = cdnBaseUrl().replace(/\/+$/, "");
      if (raw.startsWith("/")) {
        return `${base}${raw}`;
      }
      return `${base}/${raw.replace(/^\/+/, "")}`;
    }

    function extractAbsoluteAssetPath(value) {
      const raw = String(value || "").trim();
      if (!(raw.startsWith("http://") || raw.startsWith("https://"))) {
        return "";
      }
      try {
        return new URL(raw).pathname || "";
      } catch (_) {
        return "";
      }
    }

    function normalizeFishIconPath(value) {
      const raw = String(value || "").trim();
      if (!raw || raw.toLowerCase() === "null") {
        return "";
      }
      if (raw.startsWith("/images/")) {
        return raw;
      }
      if (raw.startsWith("images/")) {
        return `/${raw}`;
      }
      if (raw.startsWith("/FishIcons/")) {
        return `/images${raw}`;
      }
      if (raw.startsWith("FishIcons/")) {
        return `/images/${raw}`;
      }
      const absolutePath = extractAbsoluteAssetPath(raw);
      if (absolutePath) {
        return normalizeFishIconPath(absolutePath);
      }

      const file = raw.split(/[?#]/, 1)[0].split("/").pop() || raw;
      if (!/\.(png|jpe?g|gif|webp|avif|svg)$/i.test(file)) {
        return "";
      }
      return `/images/FishIcons/${file}`;
    }

    function normalizeFishIconUrl(value) {
      const raw = String(value || "").trim();
      if (!raw || raw.toLowerCase() === "null") {
        return "";
      }
      if (raw.startsWith("data:")) {
        return raw;
      }
      const assetPath = normalizeFishIconPath(raw);
      if (assetPath) {
        return cdnUrl(assetPath);
      }
      if (
        raw.startsWith("http://")
        || raw.startsWith("https://")
      ) {
        return raw;
      }
      return "";
    }

    function setElementText(element, text) {
      if (element) {
        element.textContent = text;
      }
    }

    function setElementLink(element, text, href) {
      if (!element) {
        return;
      }
      if (!href) {
        element.textContent = text;
        return;
      }
      const link = document.createElement("a");
      link.className = "fishydex-details-link";
      link.href = href;
      link.target = "_blank";
      link.rel = "noreferrer noopener";
      link.textContent = text;
      element.replaceChildren(link);
    }

    function bdolyticsItemUrl(itemKey) {
      if (!Number.isInteger(itemKey)) {
        return "";
      }
      return `https://bdolytics.com/en/NA/db/item/${itemKey}`;
    }

    function renderDetails() {
      const modal = document.getElementById("fishydex-details");
      if (!(modal instanceof HTMLElement)) {
        return;
      }

      const meta = fishMetaById(state.detailsFishId);
      if (!meta) {
        modal.hidden = true;
        return;
      }

      modal.hidden = false;
      const cached = state.detailCache.get(meta.fishId) || { loading: false, error: "", mapping: null };
      const title = document.getElementById("fishydex-details-title");
      const titleToggle = document.getElementById("fishydex-details-caught-toggle");
      const itemKey = document.getElementById("fishydex-details-item-key");
      const vendorPrice = document.getElementById("fishydex-details-vendor-price");
      const caught = document.getElementById("fishydex-details-caught");
      const grade = document.getElementById("fishydex-details-grade");
      const methodRod = document.getElementById("fishydex-details-method-rod");
      const methodHarpoon = document.getElementById("fishydex-details-method-harpoon");
      const driedBadge = document.getElementById("fishydex-details-dried-badge");
      const spotsNote = document.getElementById("fishydex-details-spots-note");
      const icon = document.getElementById("fishydex-details-icon");
      const iconFrame = document.getElementById("fishydex-details-icon-frame");
      const placeholder = document.getElementById("fishydex-details-placeholder");
      const guideImage = document.getElementById("fishydex-details-guide-image");
      const guidePlaceholder = document.getElementById("fishydex-details-guide-placeholder");
      const iconFrameGrade = meta.isPrize ? "prize" : slugifyGrade(meta.grade);
      const itemIconUrl = normalizeFishIconUrl(
        meta.iconUrl
          || (cached.mapping && cached.mapping.icon)
          || (cached.mapping && cached.mapping.encyclopedia_icon)
      );
      const guideIconUrl = normalizeFishIconUrl(cached.mapping && cached.mapping.encyclopedia_icon);

      setElementText(title, meta.name);
      if (titleToggle instanceof HTMLButtonElement) {
        titleToggle.className = `fishydex-caught-button${meta.caught ? " is-caught" : ""}${shouldStampCaughtToggle(meta.fishId, meta.caught) ? " is-stamping" : ""}`;
        titleToggle.setAttribute("aria-pressed", meta.caught ? "true" : "false");
        titleToggle.setAttribute(
          "aria-label",
          `Mark ${meta.name} as ${meta.caught ? "not caught" : "caught"}`
        );
        titleToggle.innerHTML = meta.caught ? HEROICON_CHECK_BADGE_SOLID : HEROICON_CHECK_BADGE_OUTLINE;
      }
      setElementLink(itemKey, String(meta.fishId), bdolyticsItemUrl(meta.fishId));
      setElementText(vendorPrice, formatSilver(meta.vendorPrice));
      setElementText(
        spotsNote,
        "Planned input: evidence locations mapped back to fishing zones, then ranked by rarity and bite-time behavior in each zone."
      );

      if (caught instanceof HTMLElement) {
        caught.className = meta.caught ? "fishydex-caught" : "fishydex-grade grade-unknown";
        caught.textContent = meta.caught ? "Caught" : "Not Caught";
      }
      if (grade instanceof HTMLElement) {
        grade.className = `fishydex-grade grade-${slugifyGrade(meta.grade)}`;
        grade.textContent = gradeLabel(meta.grade);
      }
      if (methodRod instanceof HTMLElement) {
        methodRod.hidden = !meta.catchMethods.includes("rod");
      }
      if (methodHarpoon instanceof HTMLElement) {
        methodHarpoon.hidden = !meta.catchMethods.includes("harpoon");
      }
      if (driedBadge instanceof HTMLElement) {
        driedBadge.hidden = !meta.isDried;
      }
      if (icon instanceof HTMLImageElement && placeholder instanceof HTMLElement) {
        if (iconFrame instanceof HTMLElement) {
          iconFrame.className = `fishydex-details-icon-wrap grade-${iconFrameGrade}`;
        }
        if (itemIconUrl) {
          icon.hidden = false;
          icon.src = itemIconUrl;
          icon.alt = `${meta.name} icon`;
          placeholder.hidden = true;
        } else {
          icon.hidden = true;
          icon.removeAttribute("src");
          icon.alt = "";
          placeholder.hidden = false;
        }
      }
      if (guideImage instanceof HTMLImageElement && guidePlaceholder instanceof HTMLElement) {
        if (guideIconUrl) {
          guideImage.hidden = false;
          guideImage.src = guideIconUrl;
          guideImage.alt = `${meta.name} guide image`;
          guidePlaceholder.hidden = true;
        } else {
          guideImage.hidden = true;
          guideImage.removeAttribute("src");
          guideImage.alt = "";
          guidePlaceholder.hidden = false;
        }
      }
    }

    function closeDetails(options = {}) {
      const restoreFocus = options.restoreFocus !== false;
      const fishId = state.detailsFishId;
      state.detailsFishId = null;
      renderDetails();
      if (!restoreFocus || !Number.isInteger(fishId)) {
        return;
      }
      const nextFocus = document.querySelector(`[data-fish-id="${fishId}"] [data-action="open-details"]`);
      if (nextFocus instanceof HTMLElement) {
        nextFocus.focus({ preventScroll: true });
      }
    }

    async function loadDetailsMapping(fishId) {
      const cached = state.detailCache.get(fishId);
      if (cached && (cached.loading || cached.mapping)) {
        return;
      }
      state.detailCache.set(fishId, { loading: true, error: "", mapping: null });
      if (state.detailsFishId === fishId) {
        renderDetails();
      }

      let response;
      try {
        response = await fetch(fishMapApiUrl(fishId), {
          headers: { Accept: "application/json" },
          credentials: "same-origin",
        });
      } catch (_error) {
        state.detailCache.set(fishId, { loading: false, error: "Fish mapping request failed.", mapping: null });
        if (state.detailsFishId === fishId) {
          renderDetails();
        }
        return;
      }

      if (!response.ok) {
        state.detailCache.set(
          fishId,
          {
            loading: false,
            error: response.status === 404
              ? "Fish mapping not found."
              : `Fish mapping request failed (HTTP ${response.status}).`,
            mapping: null,
          }
        );
        if (state.detailsFishId === fishId) {
          renderDetails();
        }
        return;
      }

      try {
        const mapping = await response.json();
        state.detailCache.set(fishId, { loading: false, error: "", mapping });
      } catch (_error) {
        state.detailCache.set(fishId, { loading: false, error: "Fish mapping response could not be parsed.", mapping: null });
      }

      if (state.detailsFishId === fishId) {
        renderDetails();
      }
    }

    function openDetails(fishId) {
      if (!fishMetaById(fishId)) {
        return;
      }
      state.detailsFishId = fishId;
      renderDetails();
      loadDetailsMapping(fishId);
    }

    function bindDetailsControls() {
      if (state.detailsBound) {
        return;
      }
      const modal = document.getElementById("fishydex-details");
      if (!(modal instanceof HTMLElement)) {
        return;
      }
      modal.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) {
          return;
        }
        if (target.closest("[data-action='toggle-caught-details']")) {
          if (Number.isInteger(state.detailsFishId)) {
            toggleCaught(state.detailsFishId);
            renderDetails();
          }
          return;
        }
        if (target.closest("[data-action='close-details']")) {
          closeDetails();
        }
      });
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && state.detailsFishId !== null) {
          closeDetails();
        }
      });
      state.detailsBound = true;
    }

    function sync(snapshot) {
      bindGridClicks();
      bindDetailsControls();

      const fish = Array.isArray(snapshot.fish) ? snapshot.fish : [];
      const caughtIds = normalizeCaughtIds(snapshot.caught_ids);
      state.currentCaughtIds = caughtIds;
      const caughtFilter = normalizeCaughtFilter(snapshot.caught_filter);
      const gradeFilters = normalizeGradeFilters(snapshot.grade_filters);
      const methodFilters = normalizeMethodFilters(
        snapshot.method_filters !== undefined ? snapshot.method_filters : snapshot.method_filter
      );
      const showDried = normalizeBooleanFlag(snapshot.show_dried);
      const sortField = normalizeSortField(snapshot.sort_field);
      const sortDirection = normalizeSortDirection(snapshot.sort_direction);
      state.currentCaughtFilter = caughtFilter;
      state.currentGradeFilters = gradeFilters;
      state.currentMethodFilters = methodFilters;
      state.currentShowDried = showDried;
      state.currentSortField = sortField;
      state.currentSortDirection = sortDirection;
      state.fishById = new Map(
        fish
          .filter((entry) => entry && Number.isInteger(entry.fish_id))
          .map((entry) => [entry.fish_id, entry])
      );
      const fishSignature = fishRenderSignature(fish);
      syncFilterUi(caughtFilter, gradeFilters, methodFilters, showDried, sortField, sortDirection);

      const renderKey = [
        snapshot.revision || "",
        fishSignature,
        (snapshot.search_query || "").trim().toLowerCase(),
        caughtFilter,
        gradeFilters.join(","),
        methodFilters.join(","),
        showDried ? "1" : "0",
        sortField,
        sortDirection,
        caughtIds.join(","),
      ].join("|");
      if (renderKey === state.renderKey) {
        renderDetails();
        return;
      }
      state.renderKey = renderKey;

      const supportsGradeFilter = fish.some((entry) => entry && (entry.is_prize !== null || entry.grade));
      const supportsMethodFilter = fish.some((entry) => entry && filterMethodsForEntry(entry).length > 0);
      const supportsDriedFilter = fish.some((entry) => entry && entryIsDried(entry));
      const searchQuery = (snapshot.search_query || "").trim().toLowerCase();
      const caughtSet = new Set(caughtIds);
      const filtered = fish.filter((entry) => {
        if (!entry) {
          return false;
        }
        const haystack = `${entry.fish_id || ""} ${entry.name || ""}`.toLowerCase();
        if (searchQuery && !haystack.includes(searchQuery)) {
          return false;
        }
        if (caughtFilter === "caught" && !caughtSet.has(entry.fish_id)) {
          return false;
        }
        if (caughtFilter === "missing" && caughtSet.has(entry.fish_id)) {
          return false;
        }
        if (gradeFilters.length > 0 && !gradeFilters.includes(filterGradeForEntry(entry))) {
          return false;
        }
        if (!showDried && entryIsDried(entry)) {
          return false;
        }
        if (
          methodFilters.length > 0
          && !methodFilters.every((method) => filterMethodsForEntry(entry).includes(method))
        ) {
          return false;
        }
        return true;
      });

      const sorted = filtered.slice().sort((left, right) => {
        return compareFishEntries(left, right, sortField, sortDirection);
      });

      const groups = new Map();
      for (const grade of GRADE_ORDER) {
        groups.set(grade, []);
      }
      for (const entry of sorted) {
        const grade = filterGradeForEntry(entry);
        groups.get(grade).push(entry);
      }

      const activeFilterCount = [
        searchQuery ? 1 : 0,
        caughtFilter !== "all" ? 1 : 0,
        gradeFilters.length,
        methodFilters.length,
        showDried ? 1 : 0,
      ].reduce((sum, count) => sum + count, 0);

      const prizeCaughtCount = fish.filter((entry) => {
        return (entry.is_prize === true || entry.grade === "Prize") && caughtSet.has(entry.fish_id);
      }).length;

      const grid = document.getElementById("fishydex-grid");
      if (grid) {
        const fragment = document.createDocumentFragment();
        const animateCards = !state.suppressCardAnimation;
        let animationIndex = 0;
        for (const grade of GRADE_ORDER) {
          const rendered = renderGroup(grade, groups.get(grade) || [], caughtSet, animationIndex, animateCards);
          if (rendered) {
            fragment.appendChild(rendered.section);
            animationIndex = rendered.nextAnimationIndex;
          }
        }
        if (!filtered.length) {
          fragment.appendChild(renderEmptyState(activeFilterCount > 0));
        }
        grid.replaceChildren(fragment);
      }
      state.suppressCardAnimation = false;

      const patch = {
        total_count: fish.length,
        visible_count: filtered.length,
        caught_count: caughtIds.length,
        prize_caught_count: prizeCaughtCount,
        supports_grade_filter: supportsGradeFilter,
        supports_method_filter: supportsMethodFilter,
        supports_dried_filter: supportsDriedFilter,
        active_filter_message: activeFilterCount > 0
          ? `${activeFilterCount} active filter${activeFilterCount === 1 ? "" : "s"}.`
          : "No extra filters.",
      };
      if (fish.length > 0) {
        patch.api_error_message = "";
        patch.api_error_hint = "";
      }
      mergeSignals(patch);
      renderDetails();
      scheduleViewportRestore();
    }

    function handleDatastarEvent(event) {
      const detail = event && event.detail ? event.detail : null;
      if (!detail) {
        return;
      }
      if (detail.type === "error") {
        const status = detail.argsRaw && detail.argsRaw.status;
        const message = status
          ? `Fish API request failed (HTTP ${status}).`
          : "Fish API request failed.";
        mergeSignals({
          api_error_message: message,
          api_error_hint: "If this page is on a different origin than the API, confirm the API CORS allowlist includes this site.",
        });
      }
      if (detail.type === "retrying") {
        mergeSignals({
          api_error_message: "Fish API request is retrying.",
          api_error_hint: detail.argsRaw && detail.argsRaw.message
            ? String(detail.argsRaw.message)
            : "The request could not be completed cleanly.",
        });
      }
    }

    function apiUrl(pathname) {
      const candidates = [
        window.__fishystuffApiBaseUrl,
        window.__fishystuffRuntimeConfig && window.__fishystuffRuntimeConfig.apiBaseUrl,
        "https://api.fishystuff.fish",
      ];
      for (const value of candidates) {
        const explicitBase = String(value || "").trim();
        if (explicitBase) {
          return new URL(pathname, explicitBase).toString();
        }
      }
      return new URL(pathname, "https://api.fishystuff.fish").toString();
    }

    function fishApiUrl() {
      return apiUrl("/api/v1/fish");
    }

    document.addEventListener(DATASTAR_EVENT, handleDatastarEvent);

    window.Fishydex = {
      resetFilters,
      restoreCaught,
      loadFish,
      sync,
      setCaughtFilter,
      clearMethodFilters,
      toggleMethodFilter,
      setShowDried,
      toggleShowDried,
      setSortField,
      setSortDirection,
      toggleSortDirection,
      toggleGradeFilter,
      exportCaught,
      importCaught,
      fishApiUrl,
      closeDetails,
    };
  })();
</script>

<div id="fishydex-app" class="not-prose"
     data-signals="{
       fish: [],
       revision: '',
       count: 0,
       search_draft: '',
       search_query: '',
       caught_filter: 'all',
       grade_filters: [],
       method_filters: [],
       show_dried: false,
       sort_field: 'name',
       sort_direction: 'asc',
       caught_ids: [],
       total_count: 0,
       visible_count: 0,
       caught_count: 0,
       prize_caught_count: 0,
       supports_grade_filter: false,
       supports_method_filter: false,
       supports_dried_filter: false,
       active_filter_message: 'No extra filters.',
       loading: true,
       status_message: '',
       api_error_message: '',
       api_error_hint: '',
     }">

  <div data-indicator-loading
       data-on-load="window.Fishydex.resetFilters(); window.Fishydex.restoreCaught(); window.Fishydex.loadFish()"
       data-on-signals-change="window.Fishydex.sync({
         fish: $fish || [],
         revision: $revision || '',
         search_query: $search_query || '',
         caught_filter: $caught_filter || 'all',
         grade_filters: $grade_filters || [],
         method_filters: $method_filters || [],
         show_dried: $show_dried === true,
         sort_field: $sort_field || 'name',
         sort_direction: $sort_direction || 'asc',
         caught_ids: $caught_ids || [],
       })"></div>

  <section class="fishydex-shell">
    <div class="fishydex-top">
      <div class="fishydex-screen">
        <div class="fishydex-heading">
          <h3>Filter</h3>
          <span class="fishydex-subtle">Revision <span data-text="$revision || 'pending'"></span></span>
        </div>

        <div class="fishydex-controls">
          <label>
            <span class="sr-only">Search fish</span>
            <input class="fishydex-search"
                   type="search"
                   autocomplete="off"
                   placeholder="Search by fish name or ID"
                   data-bind-search_draft
                   data-on-input__debounce.125ms="$search_query = ($search_draft || '').trim()">
          </label>

          <div class="fishydex-filter-stack">
            <div class="fishydex-filter-group">
              <span class="fishydex-filter-label">Caught Status</span>
              <div class="fishydex-filter-chips" role="group" aria-label="Caught status filters">
                <button type="button"
                        class="btn btn-sm btn-soft fishydex-filter-chip"
                        data-caught-filter-value="all"
                        aria-pressed="true"
                        data-on-click="window.Fishydex.setCaughtFilter('all')">All</button>
                <button type="button"
                        class="btn btn-sm btn-soft fishydex-filter-chip filter-caught"
                        data-caught-filter-value="caught"
                        aria-pressed="false"
                        data-on-click="window.Fishydex.setCaughtFilter('caught')">Caught</button>
                <button type="button"
                        class="btn btn-sm btn-soft fishydex-filter-chip filter-missing"
                        data-caught-filter-value="missing"
                        aria-pressed="false"
                        data-on-click="window.Fishydex.setCaughtFilter('missing')">Missing</button>
              </div>
            </div>

            <div class="fishydex-filter-group" data-show="$supports_grade_filter">
              <span class="fishydex-filter-label">Grade</span>
              <div class="fishydex-filter-chips" role="group" aria-label="Grade color filters">
                <button type="button"
                        class="btn btn-sm btn-soft fishydex-filter-chip grade-prize"
                        data-grade-filter-value="Prize"
                        aria-pressed="false"
                        data-on-click="window.Fishydex.toggleGradeFilter('Prize')">Red</button>
                <button type="button"
                        class="btn btn-sm btn-soft fishydex-filter-chip grade-rare"
                        data-grade-filter-value="Rare"
                        aria-pressed="false"
                        data-on-click="window.Fishydex.toggleGradeFilter('Rare')">Yellow</button>
                <button type="button"
                        class="btn btn-sm btn-soft fishydex-filter-chip grade-highquality"
                        data-grade-filter-value="HighQuality"
                        aria-pressed="false"
                        data-on-click="window.Fishydex.toggleGradeFilter('HighQuality')">Blue</button>
                <button type="button"
                        class="btn btn-sm btn-soft fishydex-filter-chip grade-general"
                        data-grade-filter-value="General"
                        aria-pressed="false"
                        data-on-click="window.Fishydex.toggleGradeFilter('General')">Green</button>
                <button type="button"
                        class="btn btn-sm btn-soft fishydex-filter-chip grade-trash"
                        data-grade-filter-value="Trash"
                        aria-pressed="false"
                        data-on-click="window.Fishydex.toggleGradeFilter('Trash')">White</button>
              </div>
            </div>

            <div class="fishydex-filter-group" data-show="$supports_method_filter || $supports_dried_filter">
              <span class="fishydex-filter-label">Method</span>
              <div class="fishydex-filter-chips" role="group" aria-label="Catch method and dried filters">
                <button type="button"
                        class="btn btn-sm btn-soft fishydex-filter-chip"
                        data-show="$supports_method_filter"
                        data-method-filter-value="all"
                        aria-pressed="true"
                        data-on-click="window.Fishydex.clearMethodFilters()">All</button>
                <button type="button"
                        class="btn btn-sm btn-soft fishydex-filter-chip filter-rod"
                        data-show="$supports_method_filter"
                        data-method-filter-value="rod"
                        aria-pressed="false"
                        data-on-click="window.Fishydex.toggleMethodFilter('rod')">Rod</button>
                <button type="button"
                        class="btn btn-sm btn-soft fishydex-filter-chip filter-harpoon"
                        data-show="$supports_method_filter"
                        data-method-filter-value="harpoon"
                        aria-pressed="false"
                        data-on-click="window.Fishydex.toggleMethodFilter('harpoon')">Harpoon</button>
                <button type="button"
                        data-show="$supports_dried_filter"
                        class="btn btn-sm btn-soft fishydex-filter-chip filter-show-dried"
                        data-dried-toggle
                        aria-pressed="false"
                        data-on-click="window.Fishydex.toggleShowDried()">Show Dried</button>
              </div>
            </div>

            <div class="fishydex-filter-group">
              <span class="fishydex-filter-label">Sort</span>
              <div class="fishydex-filter-chips" role="group" aria-label="Sort controls">
                <button type="button"
                        class="btn btn-sm btn-soft fishydex-filter-chip"
                        data-sort-field-value="name"
                        aria-pressed="true"
                        data-on-click="window.Fishydex.setSortField('name')">Name</button>
                <button type="button"
                        class="btn btn-sm btn-soft fishydex-filter-chip"
                        data-sort-field-value="price"
                        aria-pressed="false"
                        data-on-click="window.Fishydex.setSortField('price')">Price</button>
                <button type="button"
                        class="btn btn-sm btn-soft fishydex-filter-chip"
                        data-sort-direction-toggle
                        aria-pressed="true"
                        data-on-click="window.Fishydex.toggleSortDirection()">Ascending</button>
              </div>
            </div>

            <div class="fishydex-filter-meta">
              <span class="fishydex-subtle" data-text="$active_filter_message || 'No extra filters.'"></span>
              <button type="button" class="btn btn-sm btn-ghost fishydex-filter-clear" data-on-click="window.Fishydex.resetFilters()">Clear filters</button>
            </div>
          </div>

          <div class="fishydex-status" data-show="($status_message || '').length > 0">
            <strong>Status:</strong>
            <span data-text="$status_message"></span>
          </div>

          <div class="fishydex-error" data-show="($api_error_message || '').length > 0">
            <strong data-text="$api_error_message"></strong>
            <div class="fishydex-subtle" data-show="($api_error_hint || '').length > 0" data-text="$api_error_hint"></div>
          </div>
        </div>
      </div>

      <aside class="fishydex-stats">
        <h3>Progress</h3>
        <div class="fishydex-stat-grid">
          <div class="fishydex-stat">
            <span class="fishydex-stat-label">Caught</span>
            <span class="fishydex-stat-value" data-text="$caught_count || 0"></span>
          </div>
          <div class="fishydex-stat">
            <span class="fishydex-stat-label">Red Caught</span>
            <span class="fishydex-stat-value" data-text="$prize_caught_count || 0"></span>
          </div>
          <div class="fishydex-stat">
            <span class="fishydex-stat-label">Visible</span>
            <span class="fishydex-stat-value" data-text="$visible_count || 0"></span>
          </div>
          <div class="fishydex-stat">
            <span class="fishydex-stat-label">Catalog</span>
            <span class="fishydex-stat-value" data-text="$total_count || $count || 0"></span>
          </div>
        </div>
        <div class="fishydex-status" data-show="$loading">
          <strong>Loading...</strong>
          <div class="fishydex-subtle">Fetching the fish catalog from the Axum API.</div>
        </div>
        <div class="fishydex-actions" data-show="!$loading">
          <button type="button" class="btn btn-sm btn-primary fishydex-button" data-on-click="window.Fishydex.exportCaught($caught_ids || [])">Export</button>
          <button type="button" class="btn btn-sm btn-secondary fishydex-button" data-on-click="window.Fishydex.importCaught()">Import</button>
        </div>
      </aside>
    </div>

    <div class="fishydex-grid-shell">
      <div id="fishydex-grid" class="fishydex-groups"></div>
    </div>
  </section>

  <div id="fishydex-details" class="fishydex-details-modal" hidden>
    <button type="button"
            class="fishydex-details-backdrop"
            data-action="close-details"
            aria-label="Close fish details"></button>

    <section class="fishydex-details-panel" role="dialog" aria-modal="true" aria-labelledby="fishydex-details-title">
      <div class="fishydex-details-header">
        <div class="fishydex-details-header-main">
          <div id="fishydex-details-icon-frame" class="fishydex-details-icon-wrap grade-unknown">
            <img id="fishydex-details-icon" class="fishydex-details-icon" hidden>
            <div id="fishydex-details-placeholder" class="fishydex-placeholder">?</div>
          </div>

          <div class="fishydex-details-copy">
            <div class="fishydex-details-title-row">
              <h3 id="fishydex-details-title" class="fishydex-details-title">Fish</h3>
              <button type="button"
                      id="fishydex-details-caught-toggle"
                      class="fishydex-caught-button"
                      data-action="toggle-caught-details"
                      aria-pressed="false"
                      aria-label="Mark fish as caught"></button>
            </div>

            <div class="fishydex-details-badges">
              <span id="fishydex-details-caught" class="fishydex-caught">Caught</span>
              <span id="fishydex-details-grade" class="fishydex-grade grade-unknown">Unknown</span>
              <span id="fishydex-details-method-rod" class="fishydex-method method-rod" hidden>Rod</span>
              <span id="fishydex-details-method-harpoon" class="fishydex-method method-harpoon" hidden>Harpoon</span>
              <span id="fishydex-details-dried-badge" class="fishydex-method method-dried" hidden>Dried</span>
            </div>
          </div>
        </div>
        <button type="button"
                class="btn btn-sm btn-secondary fishydex-button fishydex-details-close"
                data-action="close-details">Close</button>
      </div>

      <div class="fishydex-details-guide">
        <div class="fishydex-details-guide-frame">
          <img id="fishydex-details-guide-image" class="fishydex-details-guide-image" hidden>
          <div id="fishydex-details-guide-placeholder" class="fishydex-placeholder">?</div>
        </div>
      </div>

      <dl class="fishydex-details-meta">
        <div class="fishydex-details-meta-card">
          <dt>Item Key</dt>
          <dd id="fishydex-details-item-key"></dd>
        </div>
        <div class="fishydex-details-meta-card">
          <dt>Vendor Price</dt>
          <dd id="fishydex-details-vendor-price"></dd>
        </div>
      </dl>

      <div class="fishydex-details-stack">
        <section class="fishydex-details-section">
          <h4>Best Spots</h4>
          <p id="fishydex-details-spots-note" class="fishydex-details-note"></p>
        </section>
      </div>
    </section>
  </div>
</div>
```
