## Fishydex

```=html
<style>
  #fishydex-app {
    --dex-screen: var(--color-base-100, #fffdf4);
    --dex-screen-border: color-mix(in srgb, var(--color-base-content, #1f2937) 14%, transparent);
    --dex-line: color-mix(in srgb, var(--color-base-content, #1f2937) 14%, transparent);
    --dex-highlight: var(--color-primary, #e07a5f);
    --dex-grade-red: var(--color-error, #d64545);
    --dex-grade-red-surface: color-mix(in srgb, var(--color-error, #d64545) 10%, var(--color-base-100, #fffdf4));
    --dex-grade-yellow: var(--color-warning, #f59e0b);
    --dex-grade-yellow-surface: color-mix(in srgb, var(--color-warning, #f59e0b) 12%, var(--color-base-100, #fffdf4));
    --dex-grade-blue: var(--color-info, #6b8afd);
    --dex-grade-blue-surface: color-mix(in srgb, var(--color-info, #6b8afd) 12%, var(--color-base-100, #fffdf4));
    --dex-grade-green: var(--color-success, #2f855a);
    --dex-grade-green-surface: color-mix(in srgb, var(--color-success, #2f855a) 12%, var(--color-base-100, #fffdf4));
    --dex-grade-white: var(--color-base-content, #1f2937);
    --dex-grade-white-surface: var(--color-base-200, #efe7d6);
    --dex-grade-unknown: var(--color-neutral, #1f2937);
    --dex-grade-unknown-surface: var(--color-base-200, #efe7d6);
    --dex-caught: var(--color-success, #2f855a);
    --dex-surface: var(--color-base-200, #efe7d6);
    --dex-surface-strong: var(--color-base-100, #fffdf4);
    --dex-surface-soft: var(--color-base-200, #efe7d6);
    --dex-card: color-mix(in oklab, var(--dex-surface) 68%, var(--dex-surface-strong) 32%);
    --dex-card-hover: color-mix(in oklab, var(--dex-surface) 80%, var(--dex-surface-strong) 20%);
    --dex-field: var(--color-base-100, #fffdf4);
    --dex-focus: color-mix(in srgb, var(--color-primary, #e07a5f) 28%, transparent);
    --dex-text-muted: color-mix(in srgb, var(--color-base-content, #1f2937) 68%, transparent);
    display: grid;
    gap: 1.5rem;
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-shell {
    display: grid;
    gap: 1.5rem;
  }

  .fishydex-bento {
    display: grid;
    gap: 1rem;
  }

  .fishydex-screen,
  .fishydex-stats,
  .fishydex-grid-shell {
    min-width: 0;
  }

  .fishydex-panel-body,
  .fishydex-stats-body,
  .fishydex-grid-body {
    display: grid;
    gap: 1rem;
  }

  .fishydex-panel-meta {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 1rem;
  }

  .fishydex-subtle {
    color: var(--dex-text-muted);
    font-size: 0.95rem;
  }

  .fishydex-controls {
    display: grid;
    gap: 1rem;
  }

  .fishydex-search-field {
    width: 100%;
  }

  .fishydex-search-field input {
    width: 100%;
    min-width: 0;
  }

  .fishydex-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .fishydex-filter-stack {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 900px) {
    .fishydex-filter-stack {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .fishydex-filter-group {
    display: grid;
    gap: 0.65rem;
  }

  .fishydex-filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .fishydex-filter-chip {
    white-space: nowrap;
  }

  .fishydex-sort-price-icon {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.02rem;
    width: auto;
    height: 1.4rem;
  }

  .fishydex-sort-price-icon .fishy-icon {
    width: 1.15rem;
    height: 1.15rem;
  }

  .fishydex-sort-price-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 0.95rem;
    height: 0.95rem;
    margin-left: -0.2rem;
  }

  .fishydex-sort-price-arrow .fishy-icon {
    width: 0.95rem;
    height: 0.95rem;
  }

  .fishydex-filter-chip.is-active {
    border-color: color-mix(in srgb, var(--dex-highlight) 28%, var(--color-base-content, #1f2937));
    background: var(--dex-surface);
  }

  .fishydex-filter-chip.filter-caught.is-active {
    border-color: color-mix(in oklab, var(--dex-caught) 56%, var(--dex-line) 44%);
    background: color-mix(in oklab, var(--dex-caught) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-success, #2f855a) 82%, var(--color-base-content, #1f2937) 18%);
  }

  .fishydex-filter-chip.filter-missing.is-active {
    border-color: color-mix(in oklab, var(--color-base-content, #1f2937) 32%, transparent);
    background: color-mix(in oklab, var(--color-base-content, #1f2937) 10%, var(--dex-surface-strong) 90%);
  }

  .fishydex-filter-chip.filter-favourite.is-active {
    border-color: color-mix(in oklab, var(--color-error, #d64545) 56%, var(--dex-line) 44%);
    background: color-mix(in oklab, var(--color-error, #d64545) 14%, var(--dex-surface-strong) 86%);
    color: color-mix(in oklab, var(--color-error, #d64545) 82%, var(--color-base-content, #1f2937) 18%);
  }

  .fishydex-filter-chip.filter-rod.is-active {
    border-color: color-mix(in oklab, var(--color-info, #6b8afd) 56%, var(--dex-line) 44%);
    background: color-mix(in oklab, var(--color-info, #6b8afd) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-info, #6b8afd) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-filter-chip.filter-harpoon.is-active {
    border-color: color-mix(in oklab, var(--color-secondary, #e07a5f) 56%, var(--dex-line) 44%);
    background: color-mix(in oklab, var(--color-secondary, #e07a5f) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-secondary, #e07a5f) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-filter-chip.filter-show-dried.is-active {
    border-color: color-mix(in oklab, var(--color-warning, #c77d19) 56%, var(--dex-line) 44%);
    background: color-mix(in oklab, var(--color-warning, #c77d19) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-warning, #c77d19) 76%, var(--color-base-content, #1f2937) 24%);
  }

  .fishydex-filter-chip.grade-red.is-active {
    border-color: color-mix(in oklab, var(--dex-grade-red) 56%, var(--dex-line) 44%);
    background: var(--dex-grade-red-surface);
    color: color-mix(in oklab, var(--color-error, #d64545) 62%, var(--color-base-content, #1f2937) 38%);
  }

  .fishydex-filter-chip.grade-yellow.is-active {
    border-color: color-mix(in oklab, var(--dex-grade-yellow) 56%, var(--dex-line) 44%);
    background: var(--dex-grade-yellow-surface);
    color: color-mix(in oklab, var(--dex-grade-yellow) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-filter-chip.grade-blue.is-active {
    border-color: color-mix(in oklab, var(--dex-grade-blue) 56%, var(--dex-line) 44%);
    background: var(--dex-grade-blue-surface);
    color: color-mix(in oklab, var(--dex-grade-blue) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-filter-chip.grade-green.is-active {
    border-color: color-mix(in oklab, var(--dex-grade-green) 56%, var(--dex-line) 44%);
    background: var(--dex-grade-green-surface);
    color: color-mix(in oklab, var(--dex-grade-green) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-filter-chip.grade-white.is-active {
    border-color: color-mix(in oklab, var(--dex-grade-white) 56%, var(--dex-line) 44%);
    background: var(--dex-grade-white-surface);
    color: color-mix(in oklab, var(--dex-grade-white) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-filter-chip.grade-unknown.is-active {
    border-color: color-mix(in oklab, var(--dex-grade-unknown) 56%, var(--dex-line) 44%);
    background: var(--dex-grade-unknown-surface);
    color: color-mix(in oklab, var(--dex-grade-unknown) 68%, var(--color-base-content, #1f2937) 32%);
  }

  .fishydex-filter-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .fishydex-filter-clear {
    white-space: nowrap;
  }

  .fishydex-filter-count {
    color: var(--dex-text-muted);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .fishydex-button {
    white-space: nowrap;
  }

  .fishydex-stats-body {
    align-content: start;
  }

  .fishydex-stat-stack {
    display: grid;
    gap: 0.85rem;
    width: 100%;
  }

  .fishydex-stat-row {
    width: 100%;
  }

  .fishydex-grade-stats {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(auto-fit, minmax(10.75rem, 1fr));
  }

  .fishydex-grade-stat {
    width: 100%;
  }

  .fishydex-stat {
    border-radius: 0;
    border: 0;
    background: transparent;
    padding: 0.9rem;
  }

  .fishydex-stat-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.72;
  }

  .fishydex-stat-value {
    display: block;
    font-size: clamp(1.3rem, 2vw, 2rem);
    font-weight: 800;
  }

  .fishydex-grade-stat .fishydex-stat-value {
    font-size: clamp(1.1rem, 1.8vw, 1.45rem);
  }

  .fishydex-grade-stat .fieldset-legend {
    margin: 0;
    opacity: 1;
  }

  .fishydex-grade-stat .stat-desc {
    color: var(--dex-text-muted);
    font-size: 0.78rem;
    font-weight: 600;
  }

  .fishydex-grade-stat .fieldset-legend.grade-red {
    color: color-mix(in oklab, var(--dex-grade-red) 78%, var(--color-base-content, #1f2937) 22%);
  }

  .fishydex-grade-stat .fieldset-legend.grade-yellow {
    color: color-mix(in oklab, var(--dex-grade-yellow) 78%, var(--color-base-content, #1f2937) 22%);
  }

  .fishydex-grade-stat .fieldset-legend.grade-blue {
    color: color-mix(in oklab, var(--dex-grade-blue) 78%, var(--color-base-content, #1f2937) 22%);
  }

  .fishydex-grade-stat .fieldset-legend.grade-green {
    color: color-mix(in oklab, var(--dex-grade-green) 78%, var(--color-base-content, #1f2937) 22%);
  }

  .fishydex-grade-stat .fieldset-legend.grade-white {
    color: color-mix(in oklab, var(--color-base-content, #1f2937) 82%, transparent);
  }

  .fishydex-status,
  .fishydex-error {
    border-radius: 1rem;
    padding: 0.85rem 1rem;
  }

  .fishydex-status {
    background: var(--dex-surface);
    border: 1px solid color-mix(in srgb, var(--color-info, #6b8afd) 30%, transparent);
  }

  .fishydex-error {
    background: var(--dex-surface);
    border: 1px solid color-mix(in srgb, var(--color-error, #d64545) 34%, transparent);
  }

  .fishydex-status strong {
    color: color-mix(in oklab, var(--color-info, #6b8afd) 54%, var(--color-base-content, #1f2937) 46%);
  }

  .fishydex-error strong {
    color: color-mix(in oklab, var(--color-error, #d64545) 60%, var(--color-base-content, #1f2937) 40%);
  }

  .fishydex-grid-shell {
    overflow-anchor: none;
  }

  .fishydex-groups {
    display: grid;
    gap: 1rem;
    overflow-anchor: none;
  }

  .fishydex-group {
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-empty-title {
    margin: 0;
    font-size: clamp(1.25rem, 2vw, 1.9rem);
    font-weight: 700;
  }

  .fishydex-group-header {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    align-items: baseline;
    margin-bottom: 0.9rem;
  }

  .fishydex-group-title.fieldset-legend,
  .fishydex-panel-legend.fieldset-legend,
  .fishydex-filter-group .fieldset-legend,
  .fishydex-grade-stat .fieldset-legend {
    letter-spacing: normal;
    text-transform: none;
  }

  .fishydex-panel-legend.fieldset-legend,
  .fishydex-filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .fishydex-panel-legend .fishy-icon,
  .fishydex-filter-chip .fishy-icon {
    flex: none;
  }

  .fishydex-panel-label {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .fishydex-panel-controls {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .fishydex-sort-button.btn {
    min-height: 2rem;
    padding-inline: 0.65rem;
    border-color: transparent;
    color: var(--dex-text-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    white-space: nowrap;
  }

  .fishydex-sort-button.btn:hover,
  .fishydex-sort-button.btn:focus-visible {
    color: var(--color-base-content, #1f2937);
    background: color-mix(in oklab, var(--color-base-content, #1f2937) 6%, transparent);
  }

  .fishydex-sort-button.is-active {
    color: var(--color-base-content, #1f2937);
    background: transparent;
    box-shadow: inset 0 -2px 0 0 color-mix(in oklab, var(--dex-highlight) 42%, transparent);
  }

  .fishydex-sort-button .fishy-icon {
    flex: none;
  }

  .fishydex-sort-button.is-active .fishy-icon {
    color: color-mix(in oklab, var(--dex-highlight) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-panel-toggle {
    pointer-events: auto;
    width: 1.85rem;
    height: 1.85rem;
    min-height: 1.85rem;
    padding: 0;
    color: var(--dex-text-muted);
    transition: color 120ms ease, background 120ms ease;
  }

  .fishydex-panel-toggle:hover,
  .fishydex-panel-toggle:focus-visible {
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-panel-toggle .fishy-icon {
    transition: transform 120ms ease;
  }

  .fishydex-panel-toggle.is-collapsed .fishy-icon {
    transform: rotate(-90deg);
  }

  .fishydex-group-count {
    color: var(--dex-text-muted);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .fishydex-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(12rem, 1fr));
    gap: 0.85rem;
  }

  .fishydex-card {
    display: grid;
    min-height: 12rem;
    border: 2px solid var(--dex-line);
    border-radius: 1rem;
    background: var(--dex-card);
    color: var(--color-base-content, #1f2937);
    overflow: hidden;
    padding: 0;
    position: relative;
    transition: border-color 120ms ease, background 120ms ease, transform 120ms ease;
  }

  .fishydex-card.is-entering {
    animation: fishydex-card-in 220ms cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: var(--fishydex-card-delay, 0ms);
  }

  .fishydex-card:hover {
    border-color: color-mix(in srgb, var(--dex-highlight) 28%, var(--color-base-content, #1f2937));
    background: var(--dex-card-hover);
    transform: translateY(-1px);
  }

  .fishydex-card:focus-within {
    border-color: color-mix(in srgb, var(--dex-highlight) 28%, var(--color-base-content, #1f2937));
    background: var(--dex-card-hover);
    transform: translateY(-1px);
  }

  .fishydex-card.is-caught {
    border-color: color-mix(in oklab, var(--dex-caught) 70%, var(--color-base-content, #1f2937) 30%);
  }

  .fishydex-card-top {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    z-index: 2;
  }

  .fishydex-card-open {
    appearance: none;
    position: absolute;
    inset: 0;
    border: 0;
    background: transparent;
    border-radius: inherit;
    cursor: pointer;
    margin: 0;
    padding: 0;
  }

  .fishydex-card-open:focus-visible {
    outline: none;
  }

  .fishydex-card-content {
    position: relative;
    z-index: 1;
    display: grid;
    height: 100%;
    padding: 0.95rem;
    pointer-events: none;
    transition: transform 90ms ease;
  }

  .fishydex-card-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.35rem;
  }

  .fishydex-caught-button,
  .fishydex-favourite-button {
    pointer-events: auto;
    width: 2.25rem;
    height: 2.25rem;
    min-height: 2.25rem;
    padding: 0;
    color: color-mix(in oklab, var(--color-base-content, #1f2937) 60%, transparent);
    transition: color 120ms ease, background 120ms ease, outline-color 120ms ease;
  }

  .fishydex-caught-button:hover,
  .fishydex-favourite-button:hover {
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-caught-button:focus-visible,
  .fishydex-favourite-button:focus-visible {
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-caught-button.is-caught {
    color: color-mix(in oklab, var(--color-success, #2f855a) 82%, var(--color-base-content, #1f2937) 18%);
  }

  .fishydex-caught-button.is-caught:hover,
  .fishydex-caught-button.is-caught:focus-visible {
    background: color-mix(in oklab, var(--dex-caught) 16%, var(--dex-surface-soft) 84%);
  }

  .fishydex-favourite-button.is-favourite {
    color: color-mix(in oklab, var(--color-error, #d64545) 82%, var(--color-base-content, #1f2937) 18%);
  }

  .fishydex-favourite-button.is-favourite:hover,
  .fishydex-favourite-button.is-favourite:focus-visible {
    background: color-mix(in oklab, var(--color-error, #d64545) 14%, var(--dex-surface-soft) 86%);
  }

  .fishydex-caught-button .fishy-icon,
  .fishydex-favourite-button .fishy-icon {
    inline-size: 2rem;
    block-size: 2rem;
    flex: none;
    transform-origin: 50% 60%;
  }

  .fishydex-caught-button.is-stamping .fishy-icon,
  .fishydex-favourite-button.is-stamping .fishy-icon {
    animation: fishydex-caught-stamp 360ms cubic-bezier(0.2, 0.9, 0.25, 1.15);
  }

  .fishydex-grade,
  .fishydex-caught,
  .fishydex-method {
    align-self: start;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    line-height: 1;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .fishydex-grade {
    background: color-mix(in oklab, var(--color-base-content, #1f2937) 10%, var(--dex-surface-soft) 90%);
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-grade.grade-red {
    background: color-mix(in oklab, var(--dex-grade-red) 38%, var(--dex-surface-strong) 62%);
    color: color-mix(in oklab, var(--color-error, #d64545) 62%, var(--color-base-content, #1f2937) 38%);
  }

  .fishydex-grade.grade-yellow {
    background: var(--dex-grade-yellow-surface);
    color: color-mix(in oklab, var(--dex-grade-yellow) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-grade.grade-blue {
    background: var(--dex-grade-blue-surface);
    color: color-mix(in oklab, var(--dex-grade-blue) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-grade.grade-green {
    background: var(--dex-grade-green-surface);
    color: color-mix(in oklab, var(--dex-grade-green) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-grade.grade-white {
    background: var(--dex-grade-white-surface);
    color: color-mix(in oklab, var(--dex-grade-white) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-grade.grade-unknown {
    background: var(--dex-grade-unknown-surface);
    color: color-mix(in oklab, var(--dex-grade-unknown) 68%, var(--color-base-content, #1f2937) 32%);
  }

  .fishydex-caught {
    background: color-mix(in oklab, var(--dex-caught) 24%, var(--dex-surface-strong) 76%);
    color: color-mix(in oklab, var(--color-success, #2f855a) 62%, var(--color-base-content, #1f2937) 38%);
  }

  .fishydex-method {
    background: color-mix(in oklab, var(--color-base-content, #1f2937) 10%, var(--dex-surface-soft) 90%);
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-method.method-rod {
    background: color-mix(in oklab, var(--color-info, #6b8afd) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-info, #6b8afd) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-method.method-harpoon {
    background: color-mix(in oklab, var(--color-secondary, #e07a5f) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-secondary, #e07a5f) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-method.method-dried {
    background: color-mix(in oklab, var(--color-warning, #c77d19) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-warning, #c77d19) 76%, var(--color-base-content, #1f2937) 24%);
  }

  .fishydex-caught-placeholder {
    visibility: hidden;
  }

  .fishydex-card-main {
    display: grid;
    height: 100%;
    align-content: center;
    justify-items: center;
    gap: 0.75rem;
    min-height: 0;
    padding: 0.35rem 0.25rem 0.15rem;
    transition: transform 120ms ease;
  }

  .fishydex-card:hover .fishydex-card-main,
  .fishydex-card:focus-within .fishydex-card-main {
    transform: translateY(-2px);
  }

  .fishydex-card-open:active + .fishydex-card-content {
    transform: translateY(1px);
  }

  .fishydex-card-open:active + .fishydex-card-content .fishydex-card-main {
    transform: translateY(0);
  }

  .fishydex-icon-wrap {
    display: grid;
    place-items: center;
    width: 4.75rem;
    height: 4.75rem;
    border-radius: 34%;
    border: 1px solid color-mix(in oklab, var(--color-base-content, #1f2937) 18%, var(--dex-line) 82%);
    background: var(--dex-surface-strong);
  }

  .fishydex-icon-wrap.grade-red,
  .fishydex-details-icon-wrap.grade-red {
    border-color: color-mix(in oklab, var(--dex-grade-red) 28%, var(--dex-line) 72%);
  }

  .fishydex-icon-wrap.grade-yellow,
  .fishydex-details-icon-wrap.grade-yellow {
    border-color: color-mix(in oklab, var(--dex-grade-yellow) 28%, var(--dex-line) 72%);
  }

  .fishydex-icon-wrap.grade-blue,
  .fishydex-details-icon-wrap.grade-blue {
    border-color: color-mix(in oklab, var(--dex-grade-blue) 28%, var(--dex-line) 72%);
  }

  .fishydex-icon-wrap.grade-green,
  .fishydex-details-icon-wrap.grade-green {
    border-color: color-mix(in oklab, var(--dex-grade-green) 28%, var(--dex-line) 72%);
  }

  .fishydex-icon-wrap.grade-white,
  .fishydex-details-icon-wrap.grade-white {
    border-color: color-mix(in oklab, var(--dex-grade-white) 22%, var(--dex-line) 78%);
  }

  .fishydex-icon-wrap.grade-unknown,
  .fishydex-details-icon-wrap.grade-unknown {
    border-color: color-mix(in oklab, var(--dex-grade-unknown) 18%, var(--dex-line) 82%);
  }

  .fishydex-icon {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    margin: 0;
    object-fit: contain;
    image-rendering: auto;
  }

  .fishydex-placeholder {
    color: var(--dex-text-muted);
    font-size: 2rem;
  }

  .fishydex-name {
    max-width: 100%;
    font-weight: 800;
    line-height: 1.25;
    text-align: center;
    text-wrap: balance;
  }

  .fishydex-price {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    max-width: 100%;
    color: var(--dex-text-muted);
    font-weight: 700;
    line-height: 1.2;
  }

  .fishydex-card-price {
    align-items: baseline;
    justify-content: center;
    font-size: 0.88rem;
    text-align: center;
    text-wrap: balance;
  }

  .fishydex-details-price {
    font-size: 1rem;
  }

  .fishydex-price-icon {
    display: inline-flex;
    flex: 0 0 auto;
  }

  .fishydex-price-icon .fishy-icon {
    display: block;
    width: 1.1rem;
    height: 1.1rem;
    transform: translateY(0.16em);
  }

  .fishydex-price-value {
    min-width: 0;
  }

  .fishydex-empty {
    color: var(--color-base-content, #1f2937);
    text-align: center;
  }

  @keyframes fishydex-card-in {
    from {
      opacity: 0;
      transform: translateY(0.5rem);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fishydex-caught-stamp {
    0% {
      transform: translateY(0) scale(1) rotate(0deg);
    }

    35% {
      transform: translateY(-0.42rem) scale(1.34) rotate(-13deg);
    }

    72% {
      transform: translateY(0.08rem) scale(0.94) rotate(0deg);
    }

    100% {
      transform: translateY(0) scale(1) rotate(0deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fishydex-card.is-entering {
      animation: none;
    }

    .fishydex-caught-button.is-stamping .fishy-icon,
    .fishydex-favourite-button.is-stamping .fishy-icon {
      animation: none;
    }
  }

  .fishydex-details-modal[hidden] {
    display: none;
  }

  .fishydex-details-modal {
    position: fixed;
    inset: 0;
    z-index: 40;
    display: grid;
    place-items: center;
  }

  .fishydex-details-backdrop {
    appearance: none;
    position: absolute;
    inset: 0;
    border: 0;
    background: color-mix(in srgb, var(--color-base-content, #1f2937) 24%, transparent);
    cursor: pointer;
    margin: 0;
    padding: 0;
  }

  .fishydex-details-panel {
    position: relative;
    z-index: 1;
    max-height: min(90vh, 46rem);
    overflow: auto;
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-details-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: start;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .fishydex-details-header-main {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
    min-width: 0;
  }

  .fishydex-details-title {
    margin: 0;
    font-size: clamp(1.25rem, 2.2vw, 1.85rem);
    font-weight: 700;
  }

  .fishydex-details-title-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem;
  }

  .fishydex-details-close {
    flex: none;
  }

  #fishydex-details-caught-toggle {
    transition: background 120ms ease, outline-color 120ms ease;
  }

  #fishydex-details-caught-toggle[data-caught-state="uncaught"] {
    color: color-mix(in oklab, var(--color-base-content, #1f2937) 60%, transparent);
  }

  #fishydex-details-caught-toggle[data-caught-state="caught"] {
    color: color-mix(in oklab, var(--color-success, #2f855a) 82%, var(--color-base-content, #1f2937) 18%);
  }

  #fishydex-details-favourite-toggle[data-favourite-state="active"] {
    color: color-mix(in oklab, var(--color-error, #d64545) 82%, var(--color-base-content, #1f2937) 18%);
  }

  .fishydex-details-icon-wrap {
    display: grid;
    place-items: center;
    width: 5.5rem;
    height: 5.5rem;
    border-radius: 34%;
    border: 1px solid color-mix(in oklab, var(--color-base-content, #1f2937) 18%, var(--dex-line) 82%);
    background: var(--dex-surface-strong);
  }

  .fishydex-details-icon {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .fishydex-details-copy {
    display: grid;
    gap: 0.75rem;
    min-width: 0;
  }

  .fishydex-details-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .fishydex-details-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
    gap: 0.75rem;
  }

  .fishydex-details-guide {
    margin-bottom: 1rem;
  }

  .fishydex-details-guide-frame {
    display: grid;
    place-items: center;
    min-height: 14rem;
    padding: 1rem;
  }

  .fishydex-details-guide-image {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 16rem;
    object-fit: contain;
  }

  .fishydex-details-meta-card,
  .fishydex-details-section {
    padding: 0.85rem 0.95rem;
  }

  .fishydex-details-meta-card dt {
    margin: 0 0 0.35rem;
    color: var(--dex-text-muted);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .fishydex-details-meta-card dd {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
  }

  .fishydex-details-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--dex-highlight) 52%, transparent);
    text-underline-offset: 0.14em;
  }

  .fishydex-details-link:hover,
  .fishydex-details-link:focus-visible {
    color: var(--color-primary, #e07a5f);
    text-decoration-color: currentColor;
  }

  .fishydex-details-stack {
    display: grid;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .fishydex-details-section h4 {
    margin: 0 0 0.45rem;
    font-size: 1rem;
  }

  .fishydex-details-note {
    margin: 0.6rem 0 0;
    color: var(--dex-text-muted);
    font-size: 0.92rem;
  }

  .fishydex-details-note.is-error {
    color: color-mix(in oklab, var(--color-error, #d64545) 62%, var(--color-base-content, #1f2937) 38%);
  }

  @media (max-width: 900px) {
    .fishydex-details-header {
      grid-template-columns: 1fr;
    }

    .fishydex-details-header-main {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .fishydex-card-grid {
      grid-template-columns: repeat(auto-fill, minmax(9.75rem, 1fr));
    }
  }
</style>

  <script>
  (() => {
    const DEX_UI_STORAGE_KEY = "fishystuff.fishydex.ui.v1";
    const DEX_PROGRESS_PANEL_UI_KEY = "dex.panels.progress.collapsed";
    const DEX_FILTER_PANEL_UI_KEY = "dex.panels.filter.collapsed";
    const CAUGHT_STORAGE_KEY = "fishystuff.fishydex.caught.v1";
    const FAVOURITES_STORAGE_KEY = "fishystuff.fishydex.favourites.v1";
    const GRADE_FILTER_COLOR_ORDER = ["red", "yellow", "blue", "green", "white"];
    const GRADE_COLOR_ORDER = [...GRADE_FILTER_COLOR_ORDER, "unknown"];
    const GRADE_CODE_TO_COLOR = Object.freeze({
      Prize: "red",
      Rare: "yellow",
      HighQuality: "blue",
      General: "green",
      Trash: "white",
      Unknown: "unknown",
    });
    const GRADE_COLOR_LABELS = Object.freeze({
      red: "Red",
      yellow: "Yellow",
      blue: "Blue",
      green: "Green",
      white: "White",
      unknown: "Unknown",
    });
    function spriteIconMarkup(name, className = "", inline = false) {
      const classes = ["fishy-icon"];
      if (inline) {
        classes.push("fishy-icon--inline");
      }
      if (className) {
        classes.push(className);
      }
      return `<svg class="${classes.join(" ")}" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-${name}"></use></svg>`;
    }

    const ICON_CHECK_CIRCLE_DASH_LINE = spriteIconMarkup("check-circle-dash-line", "size-7");
    const ICON_CHECK_BADGE_SOLID = spriteIconMarkup("check-badge-solid", "size-7");
    const ICON_HEART_FILL = spriteIconMarkup("heart-fill", "size-6");
    const ICON_HEART_LINE = spriteIconMarkup("heart-line", "size-6");
    const ICON_COIN_STACK = spriteIconMarkup("coin-stack");
    const ICON_SORT_NAME_ASC = spriteIconMarkup("az-sort-ascending-letters-fill", "size-5");
    const ICON_SORT_NAME_DESC = spriteIconMarkup("za-sort-descending-letters-fill", "size-5");
    const ICON_SORT_PRICE_COIN = spriteIconMarkup("coin-2-fill", "size-5");
    const ICON_SORT_PRICE_ASC = spriteIconMarkup("arrow-up-fill");
    const ICON_SORT_PRICE_DESC = spriteIconMarkup("arrow-down-fill");
    const CAUGHT_FILTER_ORDER = ["all", "caught", "missing"];
    const METHOD_ORDER = ["rod", "harpoon"];
    const SORT_FIELD_ORDER = ["price", "name"];
    const SORT_DIRECTION_ORDER = ["asc", "desc"];
    const SORT_FIELD_LABELS = Object.freeze({
      name: "Name",
      price: "Price",
    });
    const METHOD_LABELS = {
      rod: "Rod",
      harpoon: "Harpoon",
      unknown: "Unknown",
    };
    const SILVER_FORMATTER = new Intl.NumberFormat();
    const state = {
      currentCaughtIds: [],
      currentFavouriteIds: [],
      currentCaughtFilter: "all",
      currentFavouriteFilter: false,
      currentGradeFilters: [],
      currentMethodFilters: [],
      currentShowDried: false,
      currentSortField: "price",
      currentSortDirection: "desc",
      fishById: new Map(),
      signals: null,
      uiSettingsUnsubscribe: null,
      detailsFishId: null,
      detailsBound: false,
      renderKey: "",
      gridBound: false,
      persistedUiJson: "",
      pendingViewportRestore: null,
      pendingViewportFrame: 0,
      suppressCardAnimation: false,
      pendingCaughtStampFishId: null,
      pendingCaughtStampTimer: 0,
      pendingFavouriteStampFishId: null,
      pendingFavouriteStampTimer: 0,
    };

    function connect(signals) {
      state.signals = signals && typeof signals === "object" ? signals : null;
      if (typeof state.uiSettingsUnsubscribe === "function") {
        state.uiSettingsUnsubscribe();
        state.uiSettingsUnsubscribe = null;
      }
      const store = sharedUiSettingsStore();
      if (store && typeof store.subscribe === "function") {
        state.uiSettingsUnsubscribe = store.subscribe(() => {
          if (!state.signals) {
            return;
          }
          const progressCollapsed = readPanelCollapsedState("progress");
          const filterCollapsed = readPanelCollapsedState("filter");
          if (
            normalizeBooleanFlag(state.signals.progress_panel_collapsed) === progressCollapsed
            && normalizeBooleanFlag(state.signals.filter_panel_collapsed) === filterCollapsed
          ) {
            return;
          }
          mergeSignals({
            progress_panel_collapsed: progressCollapsed,
            filter_panel_collapsed: filterCollapsed,
          });
        });
      }
    }

    function mergeSignals(patch) {
      if (!state.signals || !patch || typeof patch !== "object") {
        return;
      }
      Object.assign(state.signals, patch);
    }

    function sharedUiSettingsStore() {
      const store = window.__fishystuffUiSettings;
      return store && typeof store.get === "function" && typeof store.set === "function"
        ? store
        : null;
    }

    function panelUiKey(panelId) {
      return panelId === "progress" ? DEX_PROGRESS_PANEL_UI_KEY : DEX_FILTER_PANEL_UI_KEY;
    }

    function panelSignalKey(panelId) {
      return panelId === "progress" ? "progress_panel_collapsed" : "filter_panel_collapsed";
    }

    function readPanelCollapsedState(panelId) {
      const store = sharedUiSettingsStore();
      return normalizeBooleanFlag(store ? store.get(panelUiKey(panelId), false) : false);
    }

    function persistPanelCollapsedState(panelId, collapsed) {
      const store = sharedUiSettingsStore();
      if (!store) {
        return;
      }
      store.set(panelUiKey(panelId), Boolean(collapsed));
    }

    function storedUiSignals(signals) {
      const searchQuery = String(signals && (signals.search_query ?? signals.search_draft) || "").trim();
      return {
        search_draft: searchQuery,
        search_query: searchQuery,
        caught_filter: normalizeCaughtFilter(signals && signals.caught_filter),
        favourite_filter: normalizeBooleanFlag(signals && signals.favourite_filter),
        grade_filters: normalizeGradeFilters(signals && signals.grade_filters),
        method_filters: normalizeMethodFilters(signals && signals.method_filters),
        show_dried: normalizeBooleanFlag(signals && signals.show_dried),
        sort_field: normalizeSortField(signals && signals.sort_field),
        sort_direction: normalizeSortDirection(signals && signals.sort_direction),
      };
    }

    function persistUiSignals(signals) {
      try {
        const json = JSON.stringify(storedUiSignals(signals));
        if (json === state.persistedUiJson) {
          return;
        }
        localStorage.setItem(DEX_UI_STORAGE_KEY, json);
        state.persistedUiJson = json;
      } catch (_error) {
        mergeSignals({ status_message: "localStorage is unavailable; progress is not persisted." });
      }
    }

    function normalizeStoredFishIds(value) {
      let ids = [];
      if (Array.isArray(value)) {
        ids = value;
      } else if (value && typeof value === "object") {
        ids = Object.entries(value)
          .filter(([, enabled]) => enabled)
          .map(([fishId]) => fishId);
      }

      const unique = new Set();
      for (const raw of ids) {
        const fishId = Number.parseInt(String(raw), 10);
        if (Number.isInteger(fishId) && fishId > 0) {
          unique.add(fishId);
        }
      }
      return Array.from(unique).sort((left, right) => left - right);
    }

    function normalizeCaughtIds(value) {
      return normalizeStoredFishIds(value);
    }

    function normalizeFavouriteIds(value) {
      return normalizeStoredFishIds(value);
    }

    function parseCaughtJson(raw) {
      return normalizeCaughtIds(JSON.parse(raw));
    }

    function parseFavouriteJson(raw) {
      return normalizeFavouriteIds(JSON.parse(raw));
    }

    function loadUiStateFromStorage() {
      let patch = storedUiSignals({});
      let statusMessage = "";
      try {
        const raw = localStorage.getItem(DEX_UI_STORAGE_KEY);
        if (raw) {
          try {
            patch = storedUiSignals(JSON.parse(raw));
          } catch (_error) {
            localStorage.removeItem(DEX_UI_STORAGE_KEY);
            statusMessage = "Reset corrupted local fishydex filters.";
          }
        }
      } catch (_error) {
        statusMessage = "localStorage is unavailable; progress is not persisted.";
      }
      state.persistedUiJson = JSON.stringify(patch);
      return { patch, statusMessage };
    }

    function loadCaughtIdsFromStorage() {
      let caughtIds = [];
      let statusMessage = "";
      try {
        const raw = localStorage.getItem(CAUGHT_STORAGE_KEY);
        if (raw) {
          try {
            caughtIds = parseCaughtJson(raw);
          } catch (_error) {
            localStorage.removeItem(CAUGHT_STORAGE_KEY);
            statusMessage = "Reset corrupted local fishydex progress.";
          }
        }
      } catch (_error) {
        statusMessage = "localStorage is unavailable; progress is not persisted.";
      }
      return { caughtIds, statusMessage };
    }

    function loadFavouriteIdsFromStorage() {
      let favouriteIds = [];
      let statusMessage = "";
      try {
        const raw = localStorage.getItem(FAVOURITES_STORAGE_KEY);
        if (raw) {
          try {
            favouriteIds = parseFavouriteJson(raw);
          } catch (_error) {
            localStorage.removeItem(FAVOURITES_STORAGE_KEY);
            statusMessage = "Reset corrupted local fishydex favourites.";
          }
        }
      } catch (_error) {
        statusMessage = "localStorage is unavailable; progress is not persisted.";
      }
      return { favouriteIds, statusMessage };
    }

    function persistCaughtIds(caughtIds) {
      try {
        localStorage.setItem(CAUGHT_STORAGE_KEY, JSON.stringify(caughtIds));
      } catch (_error) {
        mergeSignals({ status_message: "localStorage is unavailable; progress is not persisted." });
      }
    }

    function persistFavouriteIds(favouriteIds) {
      try {
        localStorage.setItem(FAVOURITES_STORAGE_KEY, JSON.stringify(favouriteIds));
      } catch (_error) {
        mergeSignals({ status_message: "localStorage is unavailable; progress is not persisted." });
      }
    }

    function resetFilters() {
      mergeSignals({
        search_draft: "",
        search_query: "",
        caught_filter: "all",
        favourite_filter: false,
        grade_filters: [],
        method_filters: [],
        show_dried: false,
      });
    }

    function restore(signals) {
      connect(signals);
      const uiState = loadUiStateFromStorage();
      const caughtState = loadCaughtIdsFromStorage();
      const favouriteState = loadFavouriteIdsFromStorage();
      state.currentCaughtIds = caughtState.caughtIds;
      state.currentFavouriteIds = favouriteState.favouriteIds;
      Object.assign(signals, uiState.patch, {
        caught_ids: caughtState.caughtIds,
        favourite_ids: favouriteState.favouriteIds,
        progress_panel_collapsed: readPanelCollapsedState("progress"),
        filter_panel_collapsed: readPanelCollapsedState("filter"),
        status_message:
          uiState.statusMessage
          || caughtState.statusMessage
          || favouriteState.statusMessage
          || "",
      });
    }

    function syncPanelUi(progressCollapsed, filterCollapsed) {
      for (const button of document.querySelectorAll("[data-panel-toggle]")) {
        if (!(button instanceof HTMLButtonElement)) {
          continue;
        }
        const panelId = button.dataset.panelToggle === "filter" ? "filter" : "progress";
        const collapsed = panelId === "progress" ? progressCollapsed : filterCollapsed;
        const label = panelId === "progress" ? "progress" : "filter";
        button.classList.toggle("is-collapsed", collapsed);
        button.setAttribute("aria-expanded", collapsed ? "false" : "true");
        button.setAttribute("aria-label", `${collapsed ? "Expand" : "Collapse"} ${label} panel`);
        button.setAttribute("title", `${collapsed ? "Expand" : "Collapse"} ${label} panel`);
      }
    }

    function togglePanel(panelId) {
      const key = panelSignalKey(panelId);
      const next = !normalizeBooleanFlag(state.signals && state.signals[key]);
      mergeSignals({ [key]: next });
      persistPanelCollapsedState(panelId, next);
    }

    function queueCaughtStamp(fishId, isCaught) {
      if (state.pendingCaughtStampTimer) {
        window.clearTimeout(state.pendingCaughtStampTimer);
        state.pendingCaughtStampTimer = 0;
      }
      if (!isCaught || !Number.isInteger(fishId)) {
        state.pendingCaughtStampFishId = null;
        return;
      }
      state.pendingCaughtStampFishId = fishId;
      state.pendingCaughtStampTimer = window.setTimeout(() => {
        if (state.pendingCaughtStampFishId === fishId) {
          state.pendingCaughtStampFishId = null;
        }
        state.pendingCaughtStampTimer = 0;
      }, 420);
    }

    function shouldStampCaughtToggle(fishId, isCaught) {
      return isCaught && Number.isInteger(fishId) && state.pendingCaughtStampFishId === fishId;
    }

    function queueFavouriteStamp(fishId, isFavourite) {
      if (state.pendingFavouriteStampTimer) {
        window.clearTimeout(state.pendingFavouriteStampTimer);
        state.pendingFavouriteStampTimer = 0;
      }
      if (!isFavourite || !Number.isInteger(fishId)) {
        state.pendingFavouriteStampFishId = null;
        return;
      }
      state.pendingFavouriteStampFishId = fishId;
      state.pendingFavouriteStampTimer = window.setTimeout(() => {
        if (state.pendingFavouriteStampFishId === fishId) {
          state.pendingFavouriteStampFishId = null;
        }
        state.pendingFavouriteStampTimer = 0;
      }, 420);
    }

    function shouldStampFavouriteToggle(fishId, isFavourite) {
      return isFavourite && Number.isInteger(fishId) && state.pendingFavouriteStampFishId === fishId;
    }

    function toggleCaught(fishId) {
      const next = new Set(state.currentCaughtIds);
      if (next.has(fishId)) {
        next.delete(fishId);
      } else {
        next.add(fishId);
      }
      const caughtIds = Array.from(next).sort((left, right) => left - right);
      state.currentCaughtIds = caughtIds;
      queueCaughtStamp(fishId, next.has(fishId));
      state.suppressCardAnimation = true;
      persistCaughtIds(caughtIds);
      mergeSignals({ caught_ids: caughtIds, status_message: "" });
    }

    function toggleFavourite(fishId) {
      const next = new Set(state.currentFavouriteIds);
      if (next.has(fishId)) {
        next.delete(fishId);
      } else {
        next.add(fishId);
      }
      const favouriteIds = Array.from(next).sort((left, right) => left - right);
      state.currentFavouriteIds = favouriteIds;
      queueFavouriteStamp(fishId, next.has(fishId));
      state.suppressCardAnimation = true;
      persistFavouriteIds(favouriteIds);
      mergeSignals({ favourite_ids: favouriteIds, status_message: "" });
    }

    function rememberViewport(card, anchor) {
      if (!(card instanceof HTMLElement)) {
        state.pendingViewportRestore = null;
        return;
      }
      const fishId = Number.parseInt(card.dataset.fishId || "", 10);
      if (!Number.isInteger(fishId)) {
        state.pendingViewportRestore = null;
        return;
      }
      const anchorElement = anchor instanceof HTMLElement ? anchor : card;
      const restoreFocusSelector = anchorElement.closest("[data-action='toggle-caught']")
        ? "[data-action='toggle-caught']"
        : anchorElement.closest("[data-action='toggle-favourite']")
          ? "[data-action='toggle-favourite']"
        : anchorElement.closest("[data-action='open-details']")
          ? "[data-action='open-details']"
          : "";
      state.pendingViewportRestore = {
        fishId,
        anchorTop: anchorElement.getBoundingClientRect().top,
        scrollX: window.scrollX,
        scrollY: window.scrollY,
        restoreFocusSelector,
      };
    }

    function scheduleViewportRestore() {
      if (!state.pendingViewportRestore) {
        return;
      }
      if (state.pendingViewportFrame) {
        window.cancelAnimationFrame(state.pendingViewportFrame);
      }
      state.pendingViewportFrame = window.requestAnimationFrame(() => {
        state.pendingViewportFrame = 0;
        const pending = state.pendingViewportRestore;
        state.pendingViewportRestore = null;
        if (!pending) {
          return;
        }

        const nextCard = document.querySelector(`[data-fish-id="${pending.fishId}"]`);
        if (!(nextCard instanceof HTMLElement)) {
          window.scrollTo(pending.scrollX, pending.scrollY);
          return;
        }

        const nextAnchor = pending.restoreFocusSelector
          ? nextCard.matches(pending.restoreFocusSelector)
            ? nextCard
            : nextCard.querySelector(pending.restoreFocusSelector)
          : nextCard;
        if (nextAnchor instanceof HTMLElement) {
          nextAnchor.focus({ preventScroll: true });
          const delta = nextAnchor.getBoundingClientRect().top - pending.anchorTop;
          if (Math.abs(delta) > 1.5 || Math.abs(pending.scrollX - window.scrollX) > 0.5) {
            window.scrollTo(pending.scrollX, window.scrollY + delta);
          }
          return;
        }
        window.scrollTo(pending.scrollX, pending.scrollY);
      });
    }

    function downloadJson(filename, text) {
      const blob = new Blob([text], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = filename;
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(url);
    }

    function showToast(tone, message) {
      const toast = window.__fishystuffToast;
      if (!toast || !message) {
        return;
      }
      const handler =
        typeof toast[tone] === "function"
          ? toast[tone]
          : typeof toast.show === "function"
            ? function (value) {
                toast.show({ tone, message: value });
              }
            : null;
      handler?.(message);
    }

    async function exportCaught(caughtIds) {
      const normalized = normalizeCaughtIds(caughtIds);
      const text = JSON.stringify(normalized, null, 2);
      try {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          await navigator.clipboard.writeText(text);
          mergeSignals({ status_message: `Copied ${normalized.length} caught fish IDs.` });
          showToast("success", `Copied ${normalized.length} caught fish IDs.`);
          return;
        }
      } catch (_error) {
      }
      downloadJson("fishystuff-fishydex-caught.json", text);
      mergeSignals({ status_message: `Downloaded ${normalized.length} caught fish IDs.` });
      showToast("info", `Downloaded ${normalized.length} caught fish IDs.`);
    }

    function importCaught() {
      const raw = window.prompt("Paste caught fish JSON (array of IDs or an id:true map).");
      if (raw === null) {
        return;
      }
      try {
        const caughtIds = parseCaughtJson(raw);
        state.currentCaughtIds = caughtIds;
        persistCaughtIds(caughtIds);
        mergeSignals({
          caught_ids: caughtIds,
          status_message: `Imported ${caughtIds.length} caught fish IDs.`,
        });
        showToast("success", `Imported ${caughtIds.length} caught fish IDs.`);
      } catch (_error) {
        mergeSignals({
          status_message: "Import failed. Paste a JSON array of fish IDs or a map like {\"8474\": true}.",
        });
        showToast("error", "Import failed. Paste a JSON array of fish IDs or a map like {\"8474\": true}.");
      }
    }

    function gradeColorKey(value) {
      const code = String(value || "Unknown");
      return GRADE_CODE_TO_COLOR[code] || "unknown";
    }

    function gradeLabel(value) {
      return GRADE_COLOR_LABELS[gradeColorKey(value)] || GRADE_COLOR_LABELS.unknown;
    }

    function normalizeMethod(value) {
      const normalized = String(value || "").trim().toLowerCase();
      return normalized === "harpoon" ? "harpoon" : normalized === "rod" ? "rod" : "unknown";
    }

    function normalizeMethodList(values) {
      const rawValues = Array.isArray(values)
        ? values
        : values === undefined || values === null
          ? []
          : [values];
      const selected = new Set();
      for (const raw of rawValues) {
        const method = normalizeMethod(raw);
        if (method !== "unknown") {
          selected.add(method);
        }
      }
      return METHOD_ORDER.filter((method) => selected.has(method));
    }

    function entryCatchMethods(entry) {
      if (!entry) {
        return [];
      }
      const methods = Array.isArray(entry.catch_methods)
        ? normalizeMethodList(entry.catch_methods)
        : normalizeMethodList(entry.catch_method);
      return methods.length ? methods : ["rod"];
    }

    function methodLabel(values) {
      const methods = normalizeMethodList(values);
      if (!methods.length) {
        return METHOD_LABELS.rod;
      }
      return methods.map((method) => METHOD_LABELS[method] || METHOD_LABELS.unknown).join(" + ");
    }

    function formatSilver(value) {
      const amount = Number(value);
      if (!Number.isFinite(amount) || amount <= 0) {
        return "Unavailable";
      }
      return SILVER_FORMATTER.format(amount);
    }

    function populateVendorPrice(element, value) {
      if (!(element instanceof HTMLElement)) {
        return;
      }
      const icon = createElement("span", "fishydex-price-icon");
      icon.innerHTML = ICON_COIN_STACK;
      const amount = createElement("span", "fishydex-price-value", formatSilver(value));
      element.replaceChildren(icon, amount);
    }

    function createVendorPriceElement(tagName, className, value) {
      const element = createElement(tagName, className);
      populateVendorPrice(element, value);
      return element;
    }

    function normalizeBooleanFlag(value) {
      return value === true || value === "true" || value === 1 || value === "1";
    }

    function normalizeSortField(value) {
      const normalized = String(value || "price").trim().toLowerCase();
      return SORT_FIELD_ORDER.includes(normalized) ? normalized : "price";
    }

    function normalizeSortDirection(value) {
      const normalized = String(value || "desc").trim().toLowerCase();
      return SORT_DIRECTION_ORDER.includes(normalized) ? normalized : "desc";
    }

    function sortFieldIconMarkup(sortField, sortDirection) {
      if (sortField === "price") {
        const arrow = sortDirection === "desc" ? ICON_SORT_PRICE_DESC : ICON_SORT_PRICE_ASC;
        return `<span class="fishydex-sort-price-icon" aria-hidden="true">${ICON_SORT_PRICE_COIN}<span class="fishydex-sort-price-arrow">${arrow}</span></span>`;
      }
      return sortDirection === "desc" ? ICON_SORT_NAME_DESC : ICON_SORT_NAME_ASC;
    }

    function sortFieldButtonMarkup(sortField, active, sortDirection) {
      const effectiveDirection = active ? sortDirection : "asc";
      const label = SORT_FIELD_LABELS[sortField] || sortField;
      return `${sortFieldIconMarkup(sortField, effectiveDirection)}<span>${label}</span>`;
    }

    function normalizeCaughtFilter(value) {
      const normalized = String(value || "all").trim().toLowerCase();
      return CAUGHT_FILTER_ORDER.includes(normalized) ? normalized : "all";
    }

    function normalizeMethodFilters(value) {
      const rawValues = Array.isArray(value)
        ? value
        : value === undefined || value === null || value === "all"
          ? []
          : [value];
      const selected = [];
      for (const raw of rawValues) {
        const method = normalizeMethod(raw);
        if (METHOD_ORDER.includes(method) && !selected.includes(method)) {
          selected.push(method);
        }
      }
      return METHOD_ORDER.filter((method) => selected.includes(method));
    }

    function normalizeGradeFilters(value) {
      const rawValues = Array.isArray(value) ? value : [];
      const selected = [];
      for (const raw of rawValues) {
        const normalized = String(raw || "").trim();
        const grade = GRADE_FILTER_COLOR_ORDER.find((candidate) => candidate === normalized)
          || (normalized ? gradeColorKey(normalized) : "");
        if (GRADE_FILTER_COLOR_ORDER.includes(grade) && !selected.includes(grade)) {
          selected.push(grade);
        }
      }
      return GRADE_FILTER_COLOR_ORDER.filter((candidate) => selected.includes(candidate));
    }

    function filterGradeForEntry(entry) {
      if (!entry) {
        return "unknown";
      }
      if (entry.is_prize === true || entry.grade === "Prize") {
        return "red";
      }
      return gradeColorKey(entry.grade);
    }

    function filterMethodsForEntry(entry) {
      return entryCatchMethods(entry);
    }

    function entryIsDried(entry) {
      return normalizeBooleanFlag(entry && entry.is_dried);
    }

    function syncFilterUi(caughtFilter, favouriteFilter, gradeFilters, methodFilters, showDried, sortField, sortDirection) {
      for (const button of document.querySelectorAll("[data-caught-filter-value]")) {
        if (!(button instanceof HTMLButtonElement)) {
          continue;
        }
        const active = button.dataset.caughtFilterValue === caughtFilter;
        button.classList.toggle("is-active", active);
        button.classList.toggle("btn-active", active);
        button.setAttribute("aria-pressed", active ? "true" : "false");
      }

      for (const button of document.querySelectorAll("[data-favourite-filter-toggle]")) {
        if (!(button instanceof HTMLButtonElement)) {
          continue;
        }
        const active = favouriteFilter;
        button.classList.toggle("is-active", active);
        button.classList.toggle("btn-active", active);
        button.setAttribute("aria-pressed", active ? "true" : "false");
      }

      const selectedGrades = new Set(gradeFilters);
      for (const button of document.querySelectorAll("[data-grade-filter-value]")) {
        if (!(button instanceof HTMLButtonElement)) {
          continue;
        }
        const grade = button.dataset.gradeFilterValue || "";
        const active = selectedGrades.has(grade);
        button.classList.toggle("is-active", active);
        button.classList.toggle("btn-active", active);
        button.setAttribute("aria-pressed", active ? "true" : "false");
      }

      const selectedMethods = new Set(methodFilters);
      for (const button of document.querySelectorAll("[data-method-filter-value]")) {
        if (!(button instanceof HTMLButtonElement)) {
          continue;
        }
        const method = button.dataset.methodFilterValue || "";
        const active = method === "all" ? selectedMethods.size === 0 : selectedMethods.has(method);
        button.classList.toggle("is-active", active);
        button.classList.toggle("btn-active", active);
        button.setAttribute("aria-pressed", active ? "true" : "false");
      }

      for (const button of document.querySelectorAll("[data-dried-toggle]")) {
        if (!(button instanceof HTMLButtonElement)) {
          continue;
        }
        const active = showDried;
        button.classList.toggle("is-active", active);
        button.classList.toggle("btn-active", active);
        button.setAttribute("aria-pressed", active ? "true" : "false");
      }

      for (const button of document.querySelectorAll("[data-sort-field-value]")) {
        if (!(button instanceof HTMLButtonElement)) {
          continue;
        }
        const field = button.dataset.sortFieldValue || "";
        const active = field === sortField;
        button.classList.toggle("is-active", active);
        button.setAttribute("aria-pressed", active ? "true" : "false");
        button.innerHTML = sortFieldButtonMarkup(field, active, sortDirection);
        if (active) {
          button.setAttribute("aria-label", `Toggle ${field} sort direction. Current: ${sortDirection === "desc" ? "descending" : "ascending"}.`);
        } else {
          button.setAttribute("aria-label", `Sort catalog by ${field} ascending.`);
        }
      }
    }

    function setCaughtFilter(value) {
      const next = normalizeCaughtFilter(value);
      state.currentCaughtFilter = next;
      mergeSignals({ caught_filter: next });
    }

    function setFavouriteFilter(value) {
      const next = normalizeBooleanFlag(value);
      state.currentFavouriteFilter = next;
      mergeSignals({ favourite_filter: next });
    }

    function toggleFavouriteFilter() {
      setFavouriteFilter(!state.currentFavouriteFilter);
    }

    function clearMethodFilters() {
      state.currentMethodFilters = [];
      mergeSignals({ method_filters: [] });
    }

    function toggleMethodFilter(value) {
      const method = METHOD_ORDER.find((candidate) => candidate === normalizeMethod(value));
      if (!method) {
        return;
      }
      const next = new Set(state.currentMethodFilters);
      if (next.has(method)) {
        next.delete(method);
      } else {
        next.add(method);
      }
      const selected = METHOD_ORDER.filter((candidate) => next.has(candidate));
      state.currentMethodFilters = selected;
      mergeSignals({ method_filters: selected });
    }

    function setShowDried(value) {
      const next = normalizeBooleanFlag(value);
      state.currentShowDried = next;
      mergeSignals({ show_dried: next });
    }

    function toggleShowDried() {
      setShowDried(!state.currentShowDried);
    }

    function setSortField(value) {
      const next = normalizeSortField(value);
      state.currentSortField = next;
      mergeSignals({ sort_field: next });
    }

    function activateSortField(value) {
      const nextField = normalizeSortField(value);
      const nextDirection = state.currentSortField === nextField
        ? (state.currentSortDirection === "desc" ? "asc" : "desc")
        : "asc";
      state.currentSortField = nextField;
      state.currentSortDirection = nextDirection;
      mergeSignals({
        sort_field: nextField,
        sort_direction: nextDirection,
      });
    }

    function setSortDirection(value) {
      const next = normalizeSortDirection(value);
      state.currentSortDirection = next;
      mergeSignals({ sort_direction: next });
    }

    function toggleSortDirection() {
      setSortDirection(state.currentSortDirection === "desc" ? "asc" : "desc");
    }

    function toggleGradeFilter(value) {
      const grade = GRADE_FILTER_COLOR_ORDER.find((candidate) => candidate === String(value));
      if (!grade) {
        return;
      }
      const next = new Set(state.currentGradeFilters);
      if (next.has(grade)) {
        next.delete(grade);
      } else {
        next.add(grade);
      }
      const selected = GRADE_FILTER_COLOR_ORDER.filter((candidate) => next.has(candidate));
      state.currentGradeFilters = selected;
      mergeSignals({ grade_filters: selected });
    }

    function createElement(tagName, className, textContent) {
      const element = document.createElement(tagName);
      if (className) {
        element.className = className;
      }
      if (textContent !== undefined) {
        element.textContent = textContent;
      }
      return element;
    }

    function fishItemId(entry) {
      const value = Number(entry && entry.item_id);
      return Number.isInteger(value) ? value : 0;
    }

    function fishEncyclopediaId(entry) {
      const value = Number(entry && entry.encyclopedia_id);
      return Number.isInteger(value) && value > 0 ? value : null;
    }

    function fishRenderSignature(fish) {
      let hash = 2166136261;
      for (const entry of fish) {
        const raw = entry
          ? `${fishItemId(entry)}|${fishEncyclopediaId(entry) || 0}|${entry.grade || ""}|${entry.is_prize === true ? 1 : 0}|${entry.name || ""}|${entryIsDried(entry) ? 1 : 0}|${entryCatchMethods(entry).join(",")}|${entry.vendor_price || 0}`
          : "null";
        for (let index = 0; index < raw.length; index += 1) {
          hash ^= raw.charCodeAt(index);
          hash = Math.imul(hash, 16777619);
        }
      }
      return `${fish.length}:${(hash >>> 0).toString(16)}`;
    }

    function compareFishNames(left, right) {
      return String(left?.name || "").localeCompare(String(right?.name || ""), undefined, {
        sensitivity: "base",
        numeric: true,
      });
    }

    function entryVendorPrice(entry) {
      const amount = Number(entry && entry.vendor_price);
      return Number.isFinite(amount) && amount > 0 ? amount : null;
    }

    function compareFishEntries(left, right, sortField, sortDirection) {
      if (sortField === "price") {
        const leftPrice = entryVendorPrice(left);
        const rightPrice = entryVendorPrice(right);
        if (leftPrice === null && rightPrice !== null) {
          return 1;
        }
        if (leftPrice !== null && rightPrice === null) {
          return -1;
        }
        if (leftPrice !== null && rightPrice !== null && leftPrice !== rightPrice) {
          return sortDirection === "desc" ? rightPrice - leftPrice : leftPrice - rightPrice;
        }
      }

      const nameOrder = compareFishNames(left, right);
      if (nameOrder !== 0) {
        return sortDirection === "desc" && sortField === "name" ? -nameOrder : nameOrder;
      }
      return fishItemId(left) - fishItemId(right);
    }

    function renderEmptyState(hasActiveFilters) {
      const empty = createElement("div", "fishydex-empty card card-dash bg-base-100");
      const body = createElement("div", "card-body items-center");
      const title = createElement("h3", "fishydex-empty-title", "No fish match this filter.");
      const detail = createElement(
        "p",
        "fishydex-subtle",
        hasActiveFilters
          ? "Try a broader search or clear some filters."
          : "The fish catalog is empty."
      );
      body.append(title, detail);
      empty.appendChild(body);
      return empty;
    }

    function renderFishCard(fish, caughtSet, favouriteSet, animationIndex, animateCards) {
      const itemId = fishItemId(fish);
      const isCaught = caughtSet.has(itemId);
      const isFavourite = favouriteSet.has(itemId);
      const stampCaught = shouldStampCaughtToggle(itemId, isCaught);
      const stampFavourite = shouldStampFavouriteToggle(itemId, isFavourite);
      const card = createElement("article", "fishydex-card card card-border bg-base-100");
      card.dataset.fishId = String(itemId);
      if (animateCards) {
        card.classList.add("is-entering");
        card.style.setProperty("--fishydex-card-delay", `${Math.min(animationIndex, 11) * 24}ms`);
      }
      if (isCaught) {
        card.classList.add("is-caught");
      }

      const openButton = createElement("button", "fishydex-card-open");
      openButton.type = "button";
      openButton.dataset.action = "open-details";
      openButton.setAttribute("aria-haspopup", "dialog");
      openButton.setAttribute("aria-label", `Open details for ${fish.name || `Fish ${itemId}`}`);

      const content = createElement("div", "fishydex-card-content card-body");
      const top = createElement("div", "fishydex-card-top");
      const actions = createElement("div", "fishydex-card-actions");
      const favouriteButton = createElement(
        "button",
        `fishydex-favourite-button btn btn-sm btn-circle btn-ghost${isFavourite ? " is-favourite" : ""}${stampFavourite ? " is-stamping" : ""}`
      );
      favouriteButton.type = "button";
      favouriteButton.dataset.action = "toggle-favourite";
      favouriteButton.dataset.fishId = String(itemId);
      favouriteButton.setAttribute("aria-pressed", isFavourite ? "true" : "false");
      favouriteButton.setAttribute(
        "aria-label",
        `${isFavourite ? "Remove" : "Add"} ${fish.name || `Fish ${itemId}`} ${isFavourite ? "from" : "to"} favourites`
      );
      favouriteButton.innerHTML = isFavourite ? ICON_HEART_FILL : ICON_HEART_LINE;
      const caughtButton = createElement(
        "button",
        `fishydex-caught-button btn btn-sm btn-circle btn-ghost${isCaught ? " is-caught" : ""}${stampCaught ? " is-stamping" : ""}`
      );
      caughtButton.type = "button";
      caughtButton.dataset.action = "toggle-caught";
      caughtButton.dataset.fishId = String(itemId);
      caughtButton.setAttribute("aria-pressed", isCaught ? "true" : "false");
      caughtButton.setAttribute(
        "aria-label",
        `Mark ${fish.name || `Fish ${itemId}`} as ${isCaught ? "not caught" : "caught"}`
      );
      caughtButton.innerHTML = isCaught ? ICON_CHECK_BADGE_SOLID : ICON_CHECK_CIRCLE_DASH_LINE;
      actions.appendChild(favouriteButton);
      actions.appendChild(caughtButton);
      top.appendChild(actions);

      const main = createElement("div", "fishydex-card-main");
      const iconWrap = createElement(
        "div",
        `fishydex-icon-wrap grade-${filterGradeForEntry(fish)}`
      );
      const iconUrl = fishItemIconUrl(itemId);
      const iconPlaceholder = createElement("div", "fishydex-placeholder", "?");
      if (iconUrl) {
        const icon = createElement("img", "fishydex-icon");
        icon.loading = "lazy";
        iconPlaceholder.hidden = true;
        setImageWithPlaceholder(icon, iconPlaceholder, iconUrl, `${fish.name} icon`);
        iconWrap.append(icon, iconPlaceholder);
      } else {
        iconWrap.appendChild(iconPlaceholder);
      }
      main.appendChild(iconWrap);
      main.appendChild(createElement("div", "fishydex-name", fish.name || `Fish ${itemId}`));
      main.appendChild(
        createVendorPriceElement("div", "fishydex-price fishydex-card-price", entryVendorPrice(fish))
      );

      content.append(top, main);
      card.append(openButton, content);
      return card;
    }

    function renderGroup(title, fish, caughtSet, favouriteSet, animationIndex, animateCards) {
      if (!fish.length) {
        return null;
      }

      const section = createElement("fieldset", "fishydex-group card card-border bg-base-100");
      const legend = createElement("legend", "fishydex-group-title fieldset-legend ml-6 px-2", gradeLabel(title));
      const body = createElement("div", "card-body pt-0");
      const header = createElement("div", "fishydex-group-header");
      header.appendChild(createElement("span", "fishydex-group-count badge badge-ghost", `${fish.length} fish`));

      const grid = createElement("div", "fishydex-card-grid");
      let nextAnimationIndex = animationIndex;
      for (const entry of fish) {
        grid.appendChild(renderFishCard(entry, caughtSet, favouriteSet, nextAnimationIndex, animateCards));
        nextAnimationIndex += 1;
      }

      body.append(header, grid);
      section.append(legend, body);
      return {
        section,
        nextAnimationIndex,
      };
    }

    function bindGridClicks() {
      if (state.gridBound) {
        return;
      }
      const grid = document.getElementById("fishydex-grid");
      if (!grid) {
        return;
      }
      grid.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) {
          return;
        }
        const card = target.closest("[data-fish-id]");
        if (!card) {
          return;
        }
        const fishId = Number.parseInt(card.dataset.fishId || "", 10);
        if (!Number.isInteger(fishId)) {
          return;
        }
        const toggleButton = target.closest("[data-action='toggle-caught']");
        if (toggleButton) {
          rememberViewport(card, toggleButton);
          toggleCaught(fishId);
          return;
        }
        const favouriteButton = target.closest("[data-action='toggle-favourite']");
        if (favouriteButton) {
          rememberViewport(card, favouriteButton);
          toggleFavourite(fishId);
          return;
        }
        openDetails(fishId);
      });
      state.gridBound = true;
    }

    function fishMetaById(fishId) {
      if (!Number.isInteger(fishId)) {
        return null;
      }
      const fish = state.fishById.get(fishId);
      if (!fish) {
        return null;
      }
      return {
        fishId,
        itemId: fishItemId(fish),
        encyclopediaId: fishEncyclopediaId(fish),
        name: fish.name || `Fish ${fishId}`,
        grade: fish.grade || "Unknown",
        isDried: entryIsDried(fish),
        catchMethods: entryCatchMethods(fish),
        vendorPrice: Number.isFinite(Number(fish.vendor_price)) && Number(fish.vendor_price) > 0
          ? Number(fish.vendor_price)
          : null,
        caught: state.currentCaughtIds.includes(fishId),
        favourite: state.currentFavouriteIds.includes(fishId),
      };
    }

    function cdnBaseUrl() {
      if (typeof window.__fishystuffCdnBaseUrl === "string" && window.__fishystuffCdnBaseUrl.trim()) {
        return window.__fishystuffCdnBaseUrl.trim().replace(/\/+$/, "");
      }
      const candidates = [
        window.__fishystuffRuntimeConfig && window.__fishystuffRuntimeConfig.cdnBaseUrl,
        "https://cdn.fishystuff.fish",
      ];
      for (const value of candidates) {
        const explicitBase = String(value || "").trim();
        if (explicitBase) {
          return explicitBase.replace(/\/+$/, "");
        }
      }
      return "https://cdn.fishystuff.fish";
    }

    function cdnUrl(path) {
      if (typeof window.__fishystuffResolveCdnUrl === "function") {
        return window.__fishystuffResolveCdnUrl(path);
      }
      const raw = String(path || "").trim();
      if (!raw) {
        return "";
      }
      if (
        raw.startsWith("http://")
        || raw.startsWith("https://")
        || raw.startsWith("data:")
      ) {
        return raw;
      }
      const base = cdnBaseUrl().replace(/\/+$/, "");
      if (raw.startsWith("/")) {
        return `${base}${raw}`;
      }
      return `${base}/${raw.replace(/^\/+/, "")}`;
    }

    function zeroPad(value, width) {
      return String(Math.max(0, Number(value) || 0)).padStart(width, "0");
    }

    function fishItemIconPath(itemId) {
      if (!Number.isInteger(itemId) || itemId <= 0) {
        return "";
      }
      return `/images/FishIcons/${zeroPad(itemId, 8)}.png`;
    }

    function fishEncyclopediaIconPath(encyclopediaId) {
      if (!Number.isInteger(encyclopediaId) || encyclopediaId <= 0) {
        return "";
      }
      return `/images/FishIcons/IC_0${encyclopediaId}.png`;
    }

    function fishItemIconUrl(itemId) {
      if (typeof window.__fishystuffResolveFishItemIconUrl === "function") {
        return window.__fishystuffResolveFishItemIconUrl(itemId);
      }
      const path = fishItemIconPath(itemId);
      return path ? cdnUrl(path) : "";
    }

    function fishEncyclopediaIconUrl(encyclopediaId) {
      if (typeof window.__fishystuffResolveFishEncyclopediaIconUrl === "function") {
        return window.__fishystuffResolveFishEncyclopediaIconUrl(encyclopediaId);
      }
      const path = fishEncyclopediaIconPath(encyclopediaId);
      return path ? cdnUrl(path) : "";
    }

    function setImageWithPlaceholder(image, placeholder, src, alt) {
      if (!(image instanceof HTMLImageElement) || !(placeholder instanceof HTMLElement)) {
        return;
      }
      image.onload = null;
      image.onerror = null;
      image.dataset.expectedSrc = src || "";
      if (!src) {
        image.hidden = true;
        image.removeAttribute("src");
        image.alt = "";
        placeholder.hidden = false;
        return;
      }
      placeholder.hidden = true;
      image.hidden = false;
      image.alt = alt;
      image.onload = () => {
        if (image.dataset.expectedSrc === src) {
          placeholder.hidden = true;
          image.hidden = false;
        }
      };
      image.onerror = () => {
        if (image.dataset.expectedSrc !== src) {
          return;
        }
        image.onload = null;
        image.onerror = null;
        image.hidden = true;
        image.removeAttribute("src");
        image.alt = "";
        placeholder.hidden = false;
      };
      image.src = src;
    }

    function setElementText(element, text) {
      if (element) {
        element.textContent = text;
      }
    }

    function setElementLink(element, text, href) {
      if (!element) {
        return;
      }
      if (!href) {
        element.textContent = text;
        return;
      }
      const link = document.createElement("a");
      link.className = "fishydex-details-link link link-hover";
      link.href = href;
      link.target = "_blank";
      link.rel = "noreferrer noopener";
      link.textContent = text;
      element.replaceChildren(link);
    }

    function bdolyticsItemUrl(itemKey) {
      if (!Number.isInteger(itemKey)) {
        return "";
      }
      return `https://bdolytics.com/en/NA/db/item/${itemKey}`;
    }

    function renderDetails() {
      const modal = document.getElementById("fishydex-details");
      if (!(modal instanceof HTMLElement)) {
        return;
      }

      const meta = fishMetaById(state.detailsFishId);
      if (!meta) {
        modal.classList.remove("modal-open");
        modal.hidden = true;
        return;
      }

      modal.hidden = false;
      modal.classList.add("modal-open");
      const title = document.getElementById("fishydex-details-title");
      const titleFavouriteToggle = document.getElementById("fishydex-details-favourite-toggle");
      const titleToggle = document.getElementById("fishydex-details-caught-toggle");
      const itemKey = document.getElementById("fishydex-details-item-key");
      const vendorPrice = document.getElementById("fishydex-details-vendor-price");
      const favourite = document.getElementById("fishydex-details-favourite");
      const caught = document.getElementById("fishydex-details-caught");
      const grade = document.getElementById("fishydex-details-grade");
      const methodRod = document.getElementById("fishydex-details-method-rod");
      const methodHarpoon = document.getElementById("fishydex-details-method-harpoon");
      const driedBadge = document.getElementById("fishydex-details-dried-badge");
      const spotsNote = document.getElementById("fishydex-details-spots-note");
      const icon = document.getElementById("fishydex-details-icon");
      const iconFrame = document.getElementById("fishydex-details-icon-frame");
      const placeholder = document.getElementById("fishydex-details-placeholder");
      const guideImage = document.getElementById("fishydex-details-guide-image");
      const guidePlaceholder = document.getElementById("fishydex-details-guide-placeholder");
      const iconFrameGrade = gradeColorKey(meta.grade);
      const itemIconUrl = fishItemIconUrl(meta.itemId);
      const guideIconUrl = fishEncyclopediaIconUrl(meta.encyclopediaId);

      setElementText(title, meta.name);
      if (titleFavouriteToggle instanceof HTMLButtonElement) {
        titleFavouriteToggle.className = `fishydex-favourite-button btn btn-sm btn-circle btn-ghost${meta.favourite ? " is-favourite" : ""}${shouldStampFavouriteToggle(meta.fishId, meta.favourite) ? " is-stamping" : ""}`;
        titleFavouriteToggle.dataset.favouriteState = meta.favourite ? "active" : "inactive";
        titleFavouriteToggle.setAttribute("aria-pressed", meta.favourite ? "true" : "false");
        titleFavouriteToggle.setAttribute(
          "aria-label",
          `${meta.favourite ? "Remove" : "Add"} ${meta.name} ${meta.favourite ? "from" : "to"} favourites`
        );
        titleFavouriteToggle.innerHTML = meta.favourite ? ICON_HEART_FILL : ICON_HEART_LINE;
      }
      if (titleToggle instanceof HTMLButtonElement) {
        titleToggle.className = `fishydex-caught-button btn btn-sm btn-circle btn-ghost${meta.caught ? " is-caught" : ""}${shouldStampCaughtToggle(meta.fishId, meta.caught) ? " is-stamping" : ""}`;
        titleToggle.dataset.caughtState = meta.caught ? "caught" : "uncaught";
        titleToggle.setAttribute("aria-pressed", meta.caught ? "true" : "false");
        titleToggle.setAttribute(
          "aria-label",
          `Mark ${meta.name} as ${meta.caught ? "not caught" : "caught"}`
        );
        titleToggle.innerHTML = meta.caught ? ICON_CHECK_BADGE_SOLID : ICON_CHECK_CIRCLE_DASH_LINE;
      }
      setElementLink(itemKey, String(meta.itemId), bdolyticsItemUrl(meta.itemId));
      if (vendorPrice instanceof HTMLElement) {
        vendorPrice.className = "fishydex-price fishydex-details-price";
        populateVendorPrice(vendorPrice, meta.vendorPrice);
      }
      setElementText(
        spotsNote,
        "Planned input: evidence locations mapped back to fishing zones, then ranked by rarity and bite-time behavior in each zone."
      );

      if (caught instanceof HTMLElement) {
        caught.className = meta.caught ? "fishydex-caught badge badge-soft badge-success" : "fishydex-grade badge badge-soft grade-unknown";
        caught.textContent = meta.caught ? "Caught" : "Not Caught";
      }
      if (favourite instanceof HTMLElement) {
        favourite.hidden = !meta.favourite;
      }
      if (grade instanceof HTMLElement) {
        grade.className = `fishydex-grade badge badge-soft grade-${gradeColorKey(meta.grade)}`;
        grade.textContent = gradeLabel(meta.grade);
      }
      if (methodRod instanceof HTMLElement) {
        methodRod.hidden = !meta.catchMethods.includes("rod");
      }
      if (methodHarpoon instanceof HTMLElement) {
        methodHarpoon.hidden = !meta.catchMethods.includes("harpoon");
      }
      if (driedBadge instanceof HTMLElement) {
        driedBadge.hidden = !meta.isDried;
      }
      if (icon instanceof HTMLImageElement && placeholder instanceof HTMLElement) {
        if (iconFrame instanceof HTMLElement) {
          iconFrame.className = `fishydex-details-icon-wrap grade-${iconFrameGrade}`;
        }
        setImageWithPlaceholder(icon, placeholder, itemIconUrl, `${meta.name} icon`);
      }
      if (guideImage instanceof HTMLImageElement && guidePlaceholder instanceof HTMLElement) {
        setImageWithPlaceholder(guideImage, guidePlaceholder, guideIconUrl, `${meta.name} guide image`);
      }
    }

    function closeDetails(options = {}) {
      const restoreFocus = options.restoreFocus !== false;
      const fishId = state.detailsFishId;
      state.detailsFishId = null;
      renderDetails();
      if (!restoreFocus || !Number.isInteger(fishId)) {
        return;
      }
      const nextFocus = document.querySelector(`[data-fish-id="${fishId}"] [data-action="open-details"]`);
      if (nextFocus instanceof HTMLElement) {
        nextFocus.focus({ preventScroll: true });
      }
    }

    function openDetails(fishId) {
      if (!fishMetaById(fishId)) {
        return;
      }
      state.detailsFishId = fishId;
      renderDetails();
    }

    function bindDetailsControls() {
      if (state.detailsBound) {
        return;
      }
      const modal = document.getElementById("fishydex-details");
      if (!(modal instanceof HTMLElement)) {
        return;
      }
      modal.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) {
          return;
        }
        if (target.closest("[data-action='toggle-caught-details']")) {
          if (Number.isInteger(state.detailsFishId)) {
            toggleCaught(state.detailsFishId);
            renderDetails();
          }
          return;
        }
        if (target.closest("[data-action='toggle-favourite-details']")) {
          if (Number.isInteger(state.detailsFishId)) {
            toggleFavourite(state.detailsFishId);
            renderDetails();
          }
          return;
        }
        if (target.closest("[data-action='close-details']")) {
          closeDetails();
        }
      });
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && state.detailsFishId !== null) {
          closeDetails();
        }
      });
      state.detailsBound = true;
    }

    function sync(snapshot) {
      bindGridClicks();
      bindDetailsControls();
      persistUiSignals(snapshot);

      const fish = Array.isArray(snapshot.fish) ? snapshot.fish : [];
      const progressPanelCollapsed = normalizeBooleanFlag(snapshot.progress_panel_collapsed);
      const filterPanelCollapsed = normalizeBooleanFlag(snapshot.filter_panel_collapsed);
      syncPanelUi(progressPanelCollapsed, filterPanelCollapsed);
      const caughtIds = normalizeCaughtIds(snapshot.caught_ids);
      const favouriteIds = normalizeFavouriteIds(snapshot.favourite_ids);
      state.currentCaughtIds = caughtIds;
      state.currentFavouriteIds = favouriteIds;
      const caughtFilter = normalizeCaughtFilter(snapshot.caught_filter);
      const favouriteFilter = normalizeBooleanFlag(snapshot.favourite_filter);
      const gradeFilters = normalizeGradeFilters(snapshot.grade_filters);
      const methodFilters = normalizeMethodFilters(
        snapshot.method_filters !== undefined ? snapshot.method_filters : snapshot.method_filter
      );
      const showDried = normalizeBooleanFlag(snapshot.show_dried);
      const sortField = normalizeSortField(snapshot.sort_field);
      const sortDirection = normalizeSortDirection(snapshot.sort_direction);
      state.currentCaughtFilter = caughtFilter;
      state.currentFavouriteFilter = favouriteFilter;
      state.currentGradeFilters = gradeFilters;
      state.currentMethodFilters = methodFilters;
      state.currentShowDried = showDried;
      state.currentSortField = sortField;
      state.currentSortDirection = sortDirection;
      state.fishById = new Map(
        fish
          .filter((entry) => entry && Number.isInteger(entry.item_id))
          .map((entry) => [entry.item_id, entry])
      );
      const fishSignature = fishRenderSignature(fish);
      syncFilterUi(caughtFilter, favouriteFilter, gradeFilters, methodFilters, showDried, sortField, sortDirection);

      const renderKey = [
        snapshot.revision || "",
        fishSignature,
        (snapshot.search_query || "").trim().toLowerCase(),
        caughtFilter,
        favouriteFilter ? "1" : "0",
        gradeFilters.join(","),
        methodFilters.join(","),
        showDried ? "1" : "0",
        sortField,
        sortDirection,
        caughtIds.join(","),
        favouriteIds.join(","),
      ].join("|");
      if (renderKey === state.renderKey) {
        renderDetails();
        return;
      }
      state.renderKey = renderKey;

      const supportsGradeFilter = fish.some((entry) => entry && (entry.is_prize !== null || entry.grade));
      const supportsMethodFilter = fish.some((entry) => entry && filterMethodsForEntry(entry).length > 0);
      const supportsDriedFilter = fish.some((entry) => entry && entryIsDried(entry));
      const searchQuery = (snapshot.search_query || "").trim().toLowerCase();
      const caughtSet = new Set(caughtIds);
      const favouriteSet = new Set(favouriteIds);
      const catalogEntries = fish.filter((entry) => {
        return entry && (showDried || !entryIsDried(entry));
      });
      const filtered = fish.filter((entry) => {
        if (!entry) {
          return false;
        }
        const haystack = `${fishItemId(entry) || ""} ${entry.name || ""}`.toLowerCase();
        if (searchQuery && !haystack.includes(searchQuery)) {
          return false;
        }
        if (caughtFilter === "caught" && !caughtSet.has(fishItemId(entry))) {
          return false;
        }
        if (caughtFilter === "missing" && caughtSet.has(fishItemId(entry))) {
          return false;
        }
        if (favouriteFilter && !favouriteSet.has(fishItemId(entry))) {
          return false;
        }
        if (gradeFilters.length > 0 && !gradeFilters.includes(filterGradeForEntry(entry))) {
          return false;
        }
        if (!showDried && entryIsDried(entry)) {
          return false;
        }
        if (
          methodFilters.length > 0
          && !methodFilters.every((method) => filterMethodsForEntry(entry).includes(method))
        ) {
          return false;
        }
        return true;
      });

      const sorted = filtered.slice().sort((left, right) => {
        return compareFishEntries(left, right, sortField, sortDirection);
      });
      const hasNarrowingFilters = Boolean(searchQuery)
        || caughtFilter !== "all"
        || favouriteFilter
        || gradeFilters.length > 0
        || methodFilters.length > 0;
      const catalogCaughtCount = catalogEntries.reduce((count, entry) => {
        return count + (caughtSet.has(fishItemId(entry)) ? 1 : 0);
      }, 0);
      const gradeProgress = {
        red: { total: 0, caught: 0 },
        yellow: { total: 0, caught: 0 },
        blue: { total: 0, caught: 0 },
        green: { total: 0, caught: 0 },
        white: { total: 0, caught: 0 },
      };
      for (const entry of catalogEntries) {
        const grade = filterGradeForEntry(entry);
        if (!(grade in gradeProgress)) {
          continue;
        }
        gradeProgress[grade].total += 1;
        if (caughtSet.has(fishItemId(entry))) {
          gradeProgress[grade].caught += 1;
        }
      }

      const groups = new Map();
      for (const grade of GRADE_COLOR_ORDER) {
        groups.set(grade, []);
      }
      for (const entry of sorted) {
        const grade = filterGradeForEntry(entry);
        groups.get(grade).push(entry);
      }

      const grid = document.getElementById("fishydex-grid");
      if (grid) {
        const fragment = document.createDocumentFragment();
        const animateCards = !state.suppressCardAnimation;
        let animationIndex = 0;
        for (const grade of GRADE_COLOR_ORDER) {
          const rendered = renderGroup(
            grade,
            groups.get(grade) || [],
            caughtSet,
            favouriteSet,
            animationIndex,
            animateCards,
          );
          if (rendered) {
            fragment.appendChild(rendered.section);
            animationIndex = rendered.nextAnimationIndex;
          }
        }
        if (!filtered.length) {
          fragment.appendChild(renderEmptyState(hasNarrowingFilters));
        }
        grid.replaceChildren(fragment);
      }
      state.suppressCardAnimation = false;

      const patch = {
        catalog_count: catalogEntries.length,
        total_count: fish.length,
        visible_count: filtered.length,
        caught_count: catalogCaughtCount,
        red_total_count: gradeProgress.red.total,
        red_caught_count: gradeProgress.red.caught,
        yellow_total_count: gradeProgress.yellow.total,
        yellow_caught_count: gradeProgress.yellow.caught,
        blue_total_count: gradeProgress.blue.total,
        blue_caught_count: gradeProgress.blue.caught,
        green_total_count: gradeProgress.green.total,
        green_caught_count: gradeProgress.green.caught,
        white_total_count: gradeProgress.white.total,
        white_caught_count: gradeProgress.white.caught,
        supports_grade_filter: supportsGradeFilter,
        supports_method_filter: supportsMethodFilter,
        supports_dried_filter: supportsDriedFilter,
      };
      if (fish.length > 0) {
        patch.api_error_message = "";
        patch.api_error_hint = "";
      }
      mergeSignals(patch);
      renderDetails();
      scheduleViewportRestore();
    }

    function handleDatastarEvent(event) {
      const detail = event && event.detail ? event.detail : null;
      if (!detail) {
        return;
      }
      if (detail.type === "error") {
        const status = detail.argsRaw && detail.argsRaw.status;
        const message = status
          ? `Fish API request failed (HTTP ${status}).`
          : "Fish API request failed.";
        mergeSignals({
          loading: false,
          api_error_message: message,
          api_error_hint: "If this page is on a different origin than the API, confirm the API CORS allowlist includes this site.",
        });
      }
      if (detail.type === "retrying") {
        mergeSignals({
          loading: true,
          api_error_message: "Fish API request is retrying.",
          api_error_hint: detail.argsRaw && detail.argsRaw.message
            ? String(detail.argsRaw.message)
            : "The request could not be completed cleanly.",
        });
      }
    }

    function apiUrl(pathname) {
      const candidates = [
        window.__fishystuffApiBaseUrl,
        window.__fishystuffRuntimeConfig && window.__fishystuffRuntimeConfig.apiBaseUrl,
        "https://api.fishystuff.fish",
      ];
      for (const value of candidates) {
        const explicitBase = String(value || "").trim();
        if (explicitBase) {
          return new URL(pathname, explicitBase).toString();
        }
      }
      return new URL(pathname, "https://api.fishystuff.fish").toString();
    }

    function fishApiUrl() {
      return apiUrl("/api/v1/fish");
    }

    document.addEventListener("datastar-fetch", handleDatastarEvent);

    window.Fishydex = {
      connect,
      restore,
      resetFilters,
      sync,
      togglePanel,
      setCaughtFilter,
      setFavouriteFilter,
      toggleFavouriteFilter,
      clearMethodFilters,
      toggleMethodFilter,
      setShowDried,
      toggleShowDried,
      activateSortField,
      setSortField,
      setSortDirection,
      toggleSortDirection,
      toggleGradeFilter,
      toggleFavourite,
      exportCaught,
      importCaught,
      fishApiUrl,
      closeDetails,
    };
  })();
</script>

<div id="fishydex-app" class="not-prose"
     data-signals="{
       fish: [],
       revision: '',
       count: 0,
       search_draft: '',
       search_query: '',
       caught_filter: 'all',
       favourite_filter: false,
       grade_filters: [],
       method_filters: [],
       show_dried: false,
       sort_field: 'price',
       sort_direction: 'desc',
       caught_ids: [],
       favourite_ids: [],
       progress_panel_collapsed: false,
       filter_panel_collapsed: false,
       catalog_count: 0,
       total_count: 0,
       visible_count: 0,
       caught_count: 0,
       red_total_count: 0,
       red_caught_count: 0,
       yellow_total_count: 0,
       yellow_caught_count: 0,
       blue_total_count: 0,
       blue_caught_count: 0,
       green_total_count: 0,
       green_caught_count: 0,
       white_total_count: 0,
       white_caught_count: 0,
       supports_grade_filter: false,
       supports_method_filter: false,
       supports_dried_filter: false,
       loading: true,
       status_message: '',
       api_error_message: '',
       api_error_hint: '',
     }"
     data-init__delay.50ms="window.Fishydex.restore($); @get(window.Fishydex.fishApiUrl())">
  <div
       data-effect="window.Fishydex.sync({
         fish: $fish || [],
         revision: $revision || '',
         search_query: $search_query || '',
         caught_filter: $caught_filter || 'all',
         favourite_filter: $favourite_filter === true,
         grade_filters: $grade_filters || [],
         method_filters: $method_filters || [],
         show_dried: $show_dried === true,
         sort_field: $sort_field || 'price',
         sort_direction: $sort_direction || 'desc',
         caught_ids: $caught_ids || [],
         favourite_ids: $favourite_ids || [],
         progress_panel_collapsed: $progress_panel_collapsed === true,
         filter_panel_collapsed: $filter_panel_collapsed === true,
       })"></div>

  <section class="fishydex-shell">
    <div class="fishydex-bento">
      <fieldset class="fishydex-stats card card-border bg-base-100">
        <legend class="fishydex-panel-legend fieldset-legend ml-6 px-2">
          <span class="fishydex-panel-label"><svg class="fishy-icon fishy-icon--inline size-5" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-chart-pie-2-fill"></use></svg><span>Progress</span></span>
          <button type="button" class="fishydex-panel-toggle btn btn-ghost btn-xs btn-circle" data-panel-toggle="progress" aria-controls="fishydex-progress-body" aria-expanded="true" aria-label="Collapse progress panel" data-on:click="window.Fishydex.togglePanel('progress')"><svg class="fishy-icon fishy-icon--inline size-4" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-caret-down"></use></svg></button>
        </legend>
        <div id="fishydex-progress-body" class="card-body fishydex-stats-body pt-0" data-show="!$progress_panel_collapsed">
        <div class="fishydex-stat-stack">
          <div class="fishydex-stat-row stats stats-horizontal rounded-box border border-base-300 bg-base-200">
            <div class="fishydex-stat stat">
              <div class="fishydex-stat-label stat-title">Caught</div>
              <div class="fishydex-stat-value stat-value text-xl" data-text="$caught_count || 0"></div>
            </div>
            <div class="fishydex-stat stat">
              <div class="fishydex-stat-label stat-title">Catalog</div>
              <div class="fishydex-stat-value stat-value text-xl" data-text="$catalog_count || 0"></div>
            </div>
          </div>
          <div class="fishydex-grade-stats" data-show="$supports_grade_filter">
            <div class="fishydex-grade-stat stats rounded-box border border-base-300 bg-base-200">
              <div class="fishydex-stat stat">
                <div class="stat-title fieldset-legend grade-red">Red</div>
                <div class="fishydex-stat-value stat-value text-lg" data-text="$red_caught_count || 0"></div>
                <div class="stat-desc" data-text="'of ' + ($red_total_count || 0) + ' catalog'"></div>
              </div>
            </div>
            <div class="fishydex-grade-stat stats rounded-box border border-base-300 bg-base-200">
              <div class="fishydex-stat stat">
                <div class="stat-title fieldset-legend grade-yellow">Yellow</div>
                <div class="fishydex-stat-value stat-value text-lg" data-text="$yellow_caught_count || 0"></div>
                <div class="stat-desc" data-text="'of ' + ($yellow_total_count || 0) + ' catalog'"></div>
              </div>
            </div>
            <div class="fishydex-grade-stat stats rounded-box border border-base-300 bg-base-200">
              <div class="fishydex-stat stat">
                <div class="stat-title fieldset-legend grade-blue">Blue</div>
                <div class="fishydex-stat-value stat-value text-lg" data-text="$blue_caught_count || 0"></div>
                <div class="stat-desc" data-text="'of ' + ($blue_total_count || 0) + ' catalog'"></div>
              </div>
            </div>
            <div class="fishydex-grade-stat stats rounded-box border border-base-300 bg-base-200">
              <div class="fishydex-stat stat">
                <div class="stat-title fieldset-legend grade-green">Green</div>
                <div class="fishydex-stat-value stat-value text-lg" data-text="$green_caught_count || 0"></div>
                <div class="stat-desc" data-text="'of ' + ($green_total_count || 0) + ' catalog'"></div>
              </div>
            </div>
            <div class="fishydex-grade-stat stats rounded-box border border-base-300 bg-base-200">
              <div class="fishydex-stat stat">
                <div class="stat-title fieldset-legend grade-white">White</div>
                <div class="fishydex-stat-value stat-value text-lg" data-text="$white_caught_count || 0"></div>
                <div class="stat-desc" data-text="'of ' + ($white_total_count || 0) + ' catalog'"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="fishydex-status" data-show="$loading">
          <strong>Loading...</strong>
          <div class="fishydex-subtle">Fetching the fish catalog from the API.</div>
        </div>
        <div class="fishydex-actions" data-show="!$loading">
          <button type="button" class="btn btn-sm btn-soft btn-primary fishydex-button" data-on:click="window.Fishydex.exportCaught($caught_ids || [])">Export</button>
          <button type="button" class="btn btn-sm btn-outline fishydex-button" data-on:click="window.Fishydex.importCaught()">Import</button>
        </div>
        </div>
      </fieldset>

      <fieldset class="fishydex-screen card card-border bg-base-100">
        <legend class="fishydex-panel-legend fieldset-legend ml-6 px-2">
          <span class="fishydex-panel-label"><svg class="fishy-icon fishy-icon--inline size-5" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-filter-2-fill"></use></svg><span>Filter</span></span>
          <button type="button" class="fishydex-panel-toggle btn btn-ghost btn-xs btn-circle" data-panel-toggle="filter" aria-controls="fishydex-filter-body" aria-expanded="true" aria-label="Collapse filter panel" data-on:click="window.Fishydex.togglePanel('filter')"><svg class="fishy-icon fishy-icon--inline size-4" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-caret-down"></use></svg></button>
        </legend>
        <div id="fishydex-filter-body" class="card-body fishydex-panel-body pt-0" data-show="!$filter_panel_collapsed">
        <div class="fishydex-panel-meta">
          <span class="fishydex-subtle">Revision <span data-text="$revision || 'pending'"></span></span>
        </div>

        <div class="fishydex-controls">
          <fieldset class="fishydex-filter-group fieldset rounded-box border border-base-300 bg-base-200 p-4">
            <legend class="fieldset-legend">Search</legend>
            <label class="fishydex-search-field input input-bordered">
              <svg class="fishy-icon fishy-icon--inline h-[1em] opacity-50" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-search-field"></use></svg>
              <span class="sr-only">Search fish</span>
              <input class="fishydex-search"
                     type="search"
                     autocomplete="off"
                     placeholder="Search by fish name or ID"
                     data-bind:search_draft
                     data-on:input__debounce.125ms="$search_query = ($search_draft || '').trim()">
            </label>
          </fieldset>

          <div class="fishydex-filter-stack">
            <fieldset class="fishydex-filter-group fieldset rounded-box border border-base-300 bg-base-200 p-4">
              <legend class="fieldset-legend">Status</legend>
              <div class="fishydex-filter-chips" role="group" aria-label="Status filters">
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip"
                        data-caught-filter-value="all"
                        aria-pressed="true"
                        data-on:click="window.Fishydex.setCaughtFilter('all')">All</button>
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip filter-caught"
                        data-caught-filter-value="caught"
                        aria-pressed="false"
                        data-on:click="window.Fishydex.setCaughtFilter('caught')"><svg class="fishy-icon fishy-icon--inline size-5" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-check-badge-solid"></use></svg><span>Caught</span></button>
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip filter-missing"
                        data-caught-filter-value="missing"
                        aria-pressed="false"
                        data-on:click="window.Fishydex.setCaughtFilter('missing')"><svg class="fishy-icon fishy-icon--inline size-5" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-check-circle-dash-fill"></use></svg><span>Missing</span></button>
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip filter-favourite"
                        data-favourite-filter-toggle
                        aria-pressed="false"
                        data-on:click="window.Fishydex.toggleFavouriteFilter()"><svg class="fishy-icon fishy-icon--inline size-5" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-heart-fill"></use></svg><span>Favourite</span></button>
              </div>
            </fieldset>

            <fieldset class="fishydex-filter-group fieldset rounded-box border border-base-300 bg-base-200 p-4"
                      data-show="$supports_grade_filter">
              <legend class="fieldset-legend">Grade</legend>
              <div class="fishydex-filter-chips" role="group" aria-label="Grade color filters">
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip grade-red"
                        data-grade-filter-value="red"
                        aria-pressed="false"
                        data-on:click="window.Fishydex.toggleGradeFilter('red')">Red</button>
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip grade-yellow"
                        data-grade-filter-value="yellow"
                        aria-pressed="false"
                        data-on:click="window.Fishydex.toggleGradeFilter('yellow')">Yellow</button>
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip grade-blue"
                        data-grade-filter-value="blue"
                        aria-pressed="false"
                        data-on:click="window.Fishydex.toggleGradeFilter('blue')">Blue</button>
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip grade-green"
                        data-grade-filter-value="green"
                        aria-pressed="false"
                        data-on:click="window.Fishydex.toggleGradeFilter('green')">Green</button>
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip grade-white"
                        data-grade-filter-value="white"
                        aria-pressed="false"
                        data-on:click="window.Fishydex.toggleGradeFilter('white')">White</button>
              </div>
            </fieldset>

            <fieldset class="fishydex-filter-group fieldset rounded-box border border-base-300 bg-base-200 p-4"
                      data-show="$supports_method_filter || $supports_dried_filter">
              <legend class="fieldset-legend">Method</legend>
              <div class="fishydex-filter-chips" role="group" aria-label="Catch method and dried filters">
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip"
                        data-show="$supports_method_filter"
                        data-method-filter-value="all"
                        aria-pressed="true"
                        data-on:click="window.Fishydex.clearMethodFilters()">All</button>
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip filter-rod"
                        data-show="$supports_method_filter"
                        data-method-filter-value="rod"
                        aria-pressed="false"
                        data-on:click="window.Fishydex.toggleMethodFilter('rod')">Rod</button>
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip filter-harpoon"
                        data-show="$supports_method_filter"
                        data-method-filter-value="harpoon"
                        aria-pressed="false"
                        data-on:click="window.Fishydex.toggleMethodFilter('harpoon')">Harpoon</button>
                <button type="button"
                        data-show="$supports_dried_filter"
                        class="btn btn-sm btn-outline fishydex-filter-chip filter-show-dried"
                        data-dried-toggle
                        aria-pressed="false"
                        data-on:click="window.Fishydex.toggleShowDried()">Show Dried</button>
              </div>
            </fieldset>

            <div class="fishydex-filter-meta">
              <span class="fishydex-filter-count"
                    data-text="'Showing ' + ($visible_count || 0) + '/' + ($catalog_count || 0) + ' matches'"></span>
              <button type="button" class="btn btn-sm btn-soft fishydex-filter-clear" data-on:click="window.Fishydex.resetFilters()">Clear filters</button>
            </div>
          </div>

          <div class="fishydex-status" data-show="($status_message || '').length > 0">
            <strong>Status:</strong>
            <span data-text="$status_message"></span>
          </div>

          <div class="fishydex-error" data-show="($api_error_message || '').length > 0">
            <strong data-text="$api_error_message"></strong>
            <div class="fishydex-subtle" data-show="($api_error_hint || '').length > 0" data-text="$api_error_hint"></div>
          </div>
        </div>
        </div>
      </fieldset>
    </div>

    <fieldset class="fishydex-grid-shell card card-border bg-base-100">
      <legend class="fishydex-panel-legend fieldset-legend ml-6 px-2">
        <span class="fishydex-panel-label"><svg class="fishy-icon fishy-icon--inline size-5" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-nav-dex"></use></svg><span>Catalog</span></span>
        <span class="fishydex-panel-controls" role="group" aria-label="Catalog sort controls">
          <button type="button"
                  class="btn btn-sm btn-ghost fishydex-sort-button"
                  data-sort-field-value="price"
                  aria-pressed="true"
                  aria-label="Toggle price sort direction. Current: descending."
                  data-on:click="window.Fishydex.activateSortField('price')"><span class="fishydex-sort-price-icon" aria-hidden="true"><svg class="fishy-icon fishy-icon--inline size-5" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-coin-2-fill"></use></svg><span class="fishydex-sort-price-arrow"><svg class="fishy-icon fishy-icon--inline size-4" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-arrow-down-fill"></use></svg></span></span><span>Price</span></button>
          <button type="button"
                  class="btn btn-sm btn-ghost fishydex-sort-button"
                  data-sort-field-value="name"
                  aria-pressed="false"
                  aria-label="Sort catalog by name ascending."
                  data-on:click="window.Fishydex.activateSortField('name')"><svg class="fishy-icon fishy-icon--inline size-5" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-az-sort-ascending-letters-fill"></use></svg><span>Name</span></button>
        </span>
      </legend>
      <div class="card-body fishydex-grid-body">
      <div id="fishydex-grid" class="fishydex-groups"></div>
      </div>
    </fieldset>
  </section>

  <div id="fishydex-details" class="fishydex-details-modal modal" hidden>
    <button type="button"
            class="fishydex-details-backdrop modal-backdrop"
            data-action="close-details"
            aria-label="Close fish details"></button>

    <section class="fishydex-details-panel modal-box card card-border bg-base-100 w-11/12 max-w-5xl"
             role="dialog"
             aria-modal="true"
             aria-labelledby="fishydex-details-title">
      <div class="fishydex-details-header">
        <div class="fishydex-details-header-main">
          <div id="fishydex-details-icon-frame" class="fishydex-details-icon-wrap grade-unknown">
            <img id="fishydex-details-icon" class="fishydex-details-icon" hidden>
            <div id="fishydex-details-placeholder" class="fishydex-placeholder">?</div>
          </div>

          <div class="fishydex-details-copy">
            <div class="fishydex-details-title-row">
              <h3 id="fishydex-details-title" class="fishydex-details-title">Fish</h3>
              <button type="button"
                      id="fishydex-details-favourite-toggle"
                      class="fishydex-favourite-button btn btn-sm btn-circle btn-ghost"
                      data-action="toggle-favourite-details"
                      aria-pressed="false"
                      aria-label="Mark fish as favourite"></button>
              <button type="button"
                      id="fishydex-details-caught-toggle"
                      class="fishydex-caught-button btn btn-sm btn-circle btn-ghost"
                      data-action="toggle-caught-details"
                      aria-pressed="false"
                      aria-label="Mark fish as caught"></button>
            </div>

            <div class="fishydex-details-badges">
              <span id="fishydex-details-favourite" class="badge badge-soft badge-error" hidden>Favourite</span>
              <span id="fishydex-details-caught" class="fishydex-caught badge badge-soft badge-success">Caught</span>
              <span id="fishydex-details-grade" class="fishydex-grade badge badge-soft grade-unknown">Unknown</span>
              <span id="fishydex-details-method-rod" class="fishydex-method badge badge-soft method-rod" hidden>Rod</span>
              <span id="fishydex-details-method-harpoon" class="fishydex-method badge badge-soft method-harpoon" hidden>Harpoon</span>
              <span id="fishydex-details-dried-badge" class="fishydex-method badge badge-soft method-dried" hidden>Dried</span>
            </div>
          </div>
        </div>
        <button type="button"
                class="btn btn-sm btn-outline fishydex-button fishydex-details-close"
                data-action="close-details">Close</button>
      </div>

      <div class="fishydex-details-guide">
        <div class="fishydex-details-guide-frame rounded-box border border-base-300 bg-base-200">
          <img id="fishydex-details-guide-image" class="fishydex-details-guide-image" hidden>
          <div id="fishydex-details-guide-placeholder" class="fishydex-placeholder">?</div>
        </div>
      </div>

      <dl class="fishydex-details-meta">
        <div class="fishydex-details-meta-card card card-border bg-base-200">
          <dt>Item Key</dt>
          <dd id="fishydex-details-item-key"></dd>
        </div>
        <div class="fishydex-details-meta-card card card-border bg-base-200">
          <dt>Vendor Price</dt>
          <dd id="fishydex-details-vendor-price"></dd>
        </div>
      </dl>

      <div class="fishydex-details-stack">
        <section class="fishydex-details-section card card-border bg-base-200">
          <h4>Best Spots</h4>
          <p id="fishydex-details-spots-note" class="fishydex-details-note"></p>
        </section>
      </div>
    </section>
  </div>
</div>
```
