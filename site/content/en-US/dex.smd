## Fishydex

```=html
<style>
  #fishydex-app {
    --dex-screen: var(--color-base-100, #fffdf4);
    --dex-screen-border: color-mix(in srgb, var(--color-base-content, #1f2937) 14%, transparent);
    --dex-line: color-mix(in srgb, var(--color-base-content, #1f2937) 14%, transparent);
    --dex-highlight: var(--color-primary, #e07a5f);
    --dex-grade-red: var(--color-error, #d64545);
    --dex-grade-red-surface: color-mix(in srgb, var(--color-error, #d64545) 10%, var(--color-base-100, #fffdf4));
    --dex-grade-yellow: var(--color-warning, #f59e0b);
    --dex-grade-yellow-surface: color-mix(in srgb, var(--color-warning, #f59e0b) 12%, var(--color-base-100, #fffdf4));
    --dex-grade-blue: var(--color-info, #6b8afd);
    --dex-grade-blue-surface: color-mix(in srgb, var(--color-info, #6b8afd) 12%, var(--color-base-100, #fffdf4));
    --dex-grade-green: var(--color-success, #2f855a);
    --dex-grade-green-surface: color-mix(in srgb, var(--color-success, #2f855a) 12%, var(--color-base-100, #fffdf4));
    --dex-grade-white: var(--color-base-content, #1f2937);
    --dex-grade-white-surface: var(--color-base-200, #efe7d6);
    --dex-grade-unknown: var(--color-neutral, #1f2937);
    --dex-grade-unknown-surface: var(--color-base-200, #efe7d6);
    --dex-caught: var(--color-success, #2f855a);
    --dex-surface: var(--color-base-200, #efe7d6);
    --dex-surface-strong: var(--color-base-100, #fffdf4);
    --dex-surface-soft: var(--color-base-200, #efe7d6);
    --dex-card: color-mix(in oklab, var(--dex-surface) 68%, var(--dex-surface-strong) 32%);
    --dex-card-hover: color-mix(in oklab, var(--dex-surface) 80%, var(--dex-surface-strong) 20%);
    --dex-field: var(--color-base-100, #fffdf4);
    --dex-focus: color-mix(in srgb, var(--color-primary, #e07a5f) 28%, transparent);
    --dex-text-muted: color-mix(in srgb, var(--color-base-content, #1f2937) 68%, transparent);
    display: grid;
    gap: 1.5rem;
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-shell {
    display: grid;
    gap: 1.5rem;
  }

  .fishydex-bento {
    display: grid;
    gap: 1rem;
  }

  .fishydex-screen,
  .fishydex-stats,
  .fishydex-grid-shell {
    min-width: 0;
  }

  .fishydex-panel-body,
  .fishydex-stats-body,
  .fishydex-grid-body {
    display: grid;
    gap: 1rem;
  }

  .fishydex-subtle {
    color: var(--dex-text-muted);
    font-size: 0.95rem;
  }

  .fishydex-controls {
    display: grid;
    gap: 1rem;
  }

  .fishydex-search-field {
    width: 100%;
  }

  .fishydex-search-field input {
    width: 100%;
    min-width: 0;
  }

  .fishydex-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .fishydex-filter-stack {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 900px) {
    .fishydex-filter-stack {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .fishydex-filter-group {
    display: grid;
    gap: 0.65rem;
  }

  .fishydex-filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .fishydex-filter-chip {
    white-space: nowrap;
  }

  .fishydex-sort-price-icon {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.02rem;
    width: auto;
    height: 1.4rem;
  }

  .fishydex-sort-price-icon .fishy-icon {
    width: 1.15rem;
    height: 1.15rem;
  }

  .fishydex-sort-price-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 0.95rem;
    height: 0.95rem;
    margin-left: -0.2rem;
  }

  .fishydex-sort-price-arrow .fishy-icon {
    width: 0.95rem;
    height: 0.95rem;
  }

  .fishydex-filter-chip.is-active {
    border-color: color-mix(in srgb, var(--dex-highlight) 28%, var(--color-base-content, #1f2937));
    background: var(--dex-surface);
  }

  .fishydex-filter-chip.filter-caught.is-active {
    border-color: color-mix(in oklab, var(--dex-caught) 56%, var(--dex-line) 44%);
    background: color-mix(in oklab, var(--dex-caught) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-success, #2f855a) 82%, var(--color-base-content, #1f2937) 18%);
  }

  .fishydex-filter-chip.filter-missing.is-active {
    border-color: color-mix(in oklab, var(--color-base-content, #1f2937) 32%, transparent);
    background: color-mix(in oklab, var(--color-base-content, #1f2937) 10%, var(--dex-surface-strong) 90%);
  }

  .fishydex-filter-chip.filter-favourite.is-active {
    border-color: color-mix(in oklab, var(--color-error, #d64545) 56%, var(--dex-line) 44%);
    background: color-mix(in oklab, var(--color-error, #d64545) 14%, var(--dex-surface-strong) 86%);
    color: color-mix(in oklab, var(--color-error, #d64545) 82%, var(--color-base-content, #1f2937) 18%);
  }

  .fishydex-filter-chip.filter-rod.is-active {
    border-color: color-mix(in oklab, var(--color-info, #6b8afd) 56%, var(--dex-line) 44%);
    background: color-mix(in oklab, var(--color-info, #6b8afd) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-info, #6b8afd) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-filter-chip.filter-harpoon.is-active {
    border-color: color-mix(in oklab, var(--color-secondary, #e07a5f) 56%, var(--dex-line) 44%);
    background: color-mix(in oklab, var(--color-secondary, #e07a5f) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-secondary, #e07a5f) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-filter-chip.filter-show-dried.is-active {
    border-color: color-mix(in oklab, var(--color-warning, #c77d19) 56%, var(--dex-line) 44%);
    background: color-mix(in oklab, var(--color-warning, #c77d19) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-warning, #c77d19) 76%, var(--color-base-content, #1f2937) 24%);
  }

  .fishydex-filter-chip.grade-red.is-active {
    border-color: color-mix(in oklab, var(--dex-grade-red) 56%, var(--dex-line) 44%);
    background: var(--dex-grade-red-surface);
    color: color-mix(in oklab, var(--color-error, #d64545) 62%, var(--color-base-content, #1f2937) 38%);
  }

  .fishydex-filter-chip.grade-yellow.is-active {
    border-color: color-mix(in oklab, var(--dex-grade-yellow) 56%, var(--dex-line) 44%);
    background: var(--dex-grade-yellow-surface);
    color: color-mix(in oklab, var(--dex-grade-yellow) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-filter-chip.grade-blue.is-active {
    border-color: color-mix(in oklab, var(--dex-grade-blue) 56%, var(--dex-line) 44%);
    background: var(--dex-grade-blue-surface);
    color: color-mix(in oklab, var(--dex-grade-blue) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-filter-chip.grade-green.is-active {
    border-color: color-mix(in oklab, var(--dex-grade-green) 56%, var(--dex-line) 44%);
    background: var(--dex-grade-green-surface);
    color: color-mix(in oklab, var(--dex-grade-green) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-filter-chip.grade-white.is-active {
    border-color: color-mix(in oklab, var(--dex-grade-white) 56%, var(--dex-line) 44%);
    background: var(--dex-grade-white-surface);
    color: color-mix(in oklab, var(--dex-grade-white) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-filter-chip.grade-unknown.is-active {
    border-color: color-mix(in oklab, var(--dex-grade-unknown) 56%, var(--dex-line) 44%);
    background: var(--dex-grade-unknown-surface);
    color: color-mix(in oklab, var(--dex-grade-unknown) 68%, var(--color-base-content, #1f2937) 32%);
  }

  .fishydex-filter-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .fishydex-filter-clear {
    white-space: nowrap;
  }

  .fishydex-filter-count {
    color: var(--dex-text-muted);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .fishydex-button {
    white-space: nowrap;
  }

  .fishydex-stats-body {
    align-content: start;
  }

  .fishydex-progress-overview {
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, auto) minmax(0, 1fr);
    align-items: center;
    width: 100%;
    padding: 1rem 1.1rem;
  }

  .fishydex-progress-overview-chart {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .fishydex-progress-overview-copy {
    display: grid;
    gap: 0.2rem;
    align-content: center;
    min-width: 0;
  }

  .fishydex-progress-kicker {
    display: block;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--dex-text-muted);
  }

  .fishydex-progress-title {
    display: block;
    font-size: clamp(1.15rem, 2vw, 1.65rem);
    font-weight: 800;
    line-height: 1.1;
  }

  .fishydex-progress-count {
    display: block;
    font-size: clamp(1.25rem, 2vw, 1.95rem);
    font-weight: 800;
    line-height: 1.05;
  }

  .fishydex-progress-pie {
    flex: none;
    color: var(--dex-caught);
  }

  .fishydex-progress-pie.is-overall {
    color: color-mix(in oklab, var(--dex-caught) 82%, var(--color-base-content, #1f2937) 18%);
  }

  .fishydex-progress-pie-value {
    font-size: 1.05rem;
    font-weight: 800;
    line-height: 1;
  }

  .fishydex-grade-stats {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
  }

  .fishydex-grade-progress-card {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: minmax(0, auto) minmax(0, 1fr);
    align-items: center;
    width: 100%;
    padding: 0.95rem 1rem;
  }

  .fishydex-grade-progress-copy {
    display: grid;
    gap: 0.14rem;
    min-width: 0;
  }

  .fishydex-grade-progress-percent {
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1;
  }

  .fishydex-grade-progress-title {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .fishydex-grade-progress-value {
    font-size: 1.05rem;
    font-weight: 800;
    line-height: 1.1;
  }

  .fishydex-grade-progress-meta {
    color: var(--dex-text-muted);
    font-size: 0.8rem;
    font-weight: 600;
  }

  .fishydex-progress-pie.grade-red,
  .fishydex-grade-progress-title.grade-red {
    color: color-mix(in oklab, var(--dex-grade-red) 78%, var(--color-base-content, #1f2937) 22%);
  }

  .fishydex-progress-pie.grade-yellow,
  .fishydex-grade-progress-title.grade-yellow {
    color: color-mix(in oklab, var(--dex-grade-yellow) 78%, var(--color-base-content, #1f2937) 22%);
  }

  .fishydex-progress-pie.grade-blue,
  .fishydex-grade-progress-title.grade-blue {
    color: color-mix(in oklab, var(--dex-grade-blue) 78%, var(--color-base-content, #1f2937) 22%);
  }

  .fishydex-progress-pie.grade-green,
  .fishydex-grade-progress-title.grade-green {
    color: color-mix(in oklab, var(--dex-grade-green) 78%, var(--color-base-content, #1f2937) 22%);
  }

  .fishydex-progress-pie.grade-white,
  .fishydex-grade-progress-title.grade-white {
    color: color-mix(in oklab, var(--color-base-content, #1f2937) 82%, transparent);
  }

  @media (max-width: 720px) {
    .fishydex-progress-overview {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }

    .fishydex-progress-overview-copy {
      justify-items: center;
    }
  }

  .fishydex-status,
  .fishydex-error {
    border-radius: 1rem;
    padding: 0.85rem 1rem;
  }

  .fishydex-status {
    background: var(--dex-surface);
    border: 1px solid color-mix(in srgb, var(--color-info, #6b8afd) 30%, transparent);
  }

  .fishydex-error {
    background: var(--dex-surface);
    border: 1px solid color-mix(in srgb, var(--color-error, #d64545) 34%, transparent);
  }

  .fishydex-status strong {
    color: color-mix(in oklab, var(--color-info, #6b8afd) 54%, var(--color-base-content, #1f2937) 46%);
  }

  .fishydex-error strong {
    color: color-mix(in oklab, var(--color-error, #d64545) 60%, var(--color-base-content, #1f2937) 40%);
  }

  .fishydex-grid-shell {
    overflow-anchor: none;
  }

  .fishydex-groups {
    display: grid;
    gap: 1rem;
    overflow-anchor: none;
  }

  .fishydex-group {
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-empty-title {
    margin: 0;
    font-size: clamp(1.25rem, 2vw, 1.9rem);
    font-weight: 700;
  }

  .fishydex-group-header {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    align-items: baseline;
    margin-bottom: 0.9rem;
  }

  .fishydex-group-title.fieldset-legend,
  .fishydex-panel-legend.fieldset-legend,
  .fishydex-filter-group .fieldset-legend {
    letter-spacing: normal;
    text-transform: none;
  }

  .fishydex-panel-legend.fieldset-legend,
  .fishydex-filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .fishydex-panel-legend .fishy-icon,
  .fishydex-filter-chip .fishy-icon {
    flex: none;
  }

  .fishydex-panel-label {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .fishydex-panel-spinner {
    flex: none;
    width: 1rem;
    height: 1rem;
    color: var(--dex-text-muted);
    transition: opacity 120ms ease;
  }

  .fishydex-panel-controls {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .fishydex-sort-button.btn {
    min-height: 2rem;
    padding-inline: 0.65rem;
    border-color: transparent;
    color: var(--dex-text-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    white-space: nowrap;
  }

  .fishydex-sort-button.btn:hover,
  .fishydex-sort-button.btn:focus-visible {
    color: var(--color-base-content, #1f2937);
    background: color-mix(in oklab, var(--color-base-content, #1f2937) 6%, transparent);
  }

  .fishydex-sort-button.is-active {
    color: var(--color-base-content, #1f2937);
    background: transparent;
    box-shadow: inset 0 -2px 0 0 color-mix(in oklab, var(--dex-highlight) 42%, transparent);
  }

  .fishydex-sort-button .fishy-icon {
    flex: none;
  }

  .fishydex-sort-button.is-active .fishy-icon {
    color: color-mix(in oklab, var(--dex-highlight) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-panel-toggle {
    pointer-events: auto;
    width: 1.85rem;
    height: 1.85rem;
    min-height: 1.85rem;
    padding: 0;
    color: var(--dex-text-muted);
    transition: color 120ms ease, background 120ms ease;
  }

  .fishydex-panel-toggle:hover,
  .fishydex-panel-toggle:focus-visible {
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-panel-toggle .fishy-icon {
    transition: transform 120ms ease;
  }

  .fishydex-panel-toggle.is-collapsed .fishy-icon {
    transform: rotate(-90deg);
  }

  .fishydex-group-count {
    color: var(--dex-text-muted);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .fishydex-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(12rem, 1fr));
    gap: 0.85rem;
  }

  .fishydex-card {
    display: grid;
    min-height: 12rem;
    border: 2px solid var(--dex-line);
    border-radius: 1rem;
    background: var(--dex-card);
    color: var(--color-base-content, #1f2937);
    overflow: hidden;
    padding: 0;
    position: relative;
    transition: border-color 120ms ease, background 120ms ease, transform 120ms ease;
  }

  .fishydex-card.is-entering {
    animation: fishydex-card-in 220ms cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: var(--fishydex-card-delay, 0ms);
  }

  .fishydex-card:hover {
    border-color: color-mix(in srgb, var(--dex-highlight) 28%, var(--color-base-content, #1f2937));
    background: var(--dex-card-hover);
    transform: translateY(-1px);
  }

  .fishydex-card:focus-within {
    border-color: color-mix(in srgb, var(--dex-highlight) 28%, var(--color-base-content, #1f2937));
    background: var(--dex-card-hover);
    transform: translateY(-1px);
  }

  .fishydex-card.is-caught {
    border-color: color-mix(in oklab, var(--dex-caught) 70%, var(--color-base-content, #1f2937) 30%);
  }

  .fishydex-card-top {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    z-index: 2;
  }

  .fishydex-card-open {
    appearance: none;
    position: absolute;
    inset: 0;
    border: 0;
    background: transparent;
    border-radius: inherit;
    cursor: pointer;
    margin: 0;
    padding: 0;
  }

  .fishydex-card-open:focus-visible {
    outline: none;
  }

  .fishydex-card-content {
    position: relative;
    z-index: 1;
    display: grid;
    height: 100%;
    padding: 0.95rem;
    pointer-events: none;
    transition: transform 90ms ease;
  }

  .fishydex-card-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.35rem;
  }

  .fishydex-caught-button,
  .fishydex-favourite-button {
    pointer-events: auto;
    width: 2.25rem;
    height: 2.25rem;
    min-height: 2.25rem;
    padding: 0;
    color: color-mix(in oklab, var(--color-base-content, #1f2937) 60%, transparent);
    transition: color 120ms ease, background 120ms ease, outline-color 120ms ease;
  }

  .fishydex-caught-button:hover,
  .fishydex-favourite-button:hover {
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-caught-button:focus-visible,
  .fishydex-favourite-button:focus-visible {
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-caught-button.is-caught {
    color: color-mix(in oklab, var(--color-success, #2f855a) 82%, var(--color-base-content, #1f2937) 18%);
  }

  .fishydex-caught-button.is-caught:hover,
  .fishydex-caught-button.is-caught:focus-visible {
    background: color-mix(in oklab, var(--dex-caught) 16%, var(--dex-surface-soft) 84%);
  }

  .fishydex-favourite-button.is-favourite {
    color: color-mix(in oklab, var(--color-error, #d64545) 82%, var(--color-base-content, #1f2937) 18%);
  }

  .fishydex-favourite-button.is-favourite:hover,
  .fishydex-favourite-button.is-favourite:focus-visible {
    background: color-mix(in oklab, var(--color-error, #d64545) 14%, var(--dex-surface-soft) 86%);
  }

  .fishydex-caught-button .fishy-icon,
  .fishydex-favourite-button .fishy-icon {
    inline-size: 2rem;
    block-size: 2rem;
    flex: none;
    transform-origin: 50% 60%;
  }

  .fishydex-caught-button.is-stamping .fishy-icon,
  .fishydex-favourite-button.is-stamping .fishy-icon {
    animation: fishydex-caught-stamp 360ms cubic-bezier(0.2, 0.9, 0.25, 1.15);
  }

  .fishydex-grade,
  .fishydex-caught,
  .fishydex-method {
    align-self: start;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    line-height: 1;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .fishydex-grade {
    background: color-mix(in oklab, var(--color-base-content, #1f2937) 10%, var(--dex-surface-soft) 90%);
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-grade.grade-red {
    background: color-mix(in oklab, var(--dex-grade-red) 38%, var(--dex-surface-strong) 62%);
    color: color-mix(in oklab, var(--color-error, #d64545) 62%, var(--color-base-content, #1f2937) 38%);
  }

  .fishydex-grade.grade-yellow {
    background: var(--dex-grade-yellow-surface);
    color: color-mix(in oklab, var(--dex-grade-yellow) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-grade.grade-blue {
    background: var(--dex-grade-blue-surface);
    color: color-mix(in oklab, var(--dex-grade-blue) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-grade.grade-green {
    background: var(--dex-grade-green-surface);
    color: color-mix(in oklab, var(--dex-grade-green) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-grade.grade-white {
    background: var(--dex-grade-white-surface);
    color: color-mix(in oklab, var(--dex-grade-white) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-grade.grade-unknown {
    background: var(--dex-grade-unknown-surface);
    color: color-mix(in oklab, var(--dex-grade-unknown) 68%, var(--color-base-content, #1f2937) 32%);
  }

  .fishydex-caught {
    background: color-mix(in oklab, var(--dex-caught) 24%, var(--dex-surface-strong) 76%);
    color: color-mix(in oklab, var(--color-success, #2f855a) 62%, var(--color-base-content, #1f2937) 38%);
  }

  .fishydex-method {
    background: color-mix(in oklab, var(--color-base-content, #1f2937) 10%, var(--dex-surface-soft) 90%);
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-method.method-rod {
    background: color-mix(in oklab, var(--color-info, #6b8afd) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-info, #6b8afd) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-method.method-harpoon {
    background: color-mix(in oklab, var(--color-secondary, #e07a5f) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-secondary, #e07a5f) 72%, var(--color-base-content, #1f2937) 28%);
  }

  .fishydex-method.method-dried {
    background: color-mix(in oklab, var(--color-warning, #c77d19) 18%, var(--dex-surface-strong) 82%);
    color: color-mix(in oklab, var(--color-warning, #c77d19) 76%, var(--color-base-content, #1f2937) 24%);
  }

  .fishydex-caught-placeholder {
    visibility: hidden;
  }

  .fishydex-card-main {
    display: grid;
    height: 100%;
    align-content: center;
    justify-items: center;
    gap: 0.75rem;
    min-height: 0;
    padding: 0.35rem 0.25rem 0.15rem;
    transition: transform 120ms ease;
  }

  .fishydex-card:hover .fishydex-card-main,
  .fishydex-card:focus-within .fishydex-card-main {
    transform: translateY(-2px);
  }

  .fishydex-card-open:active + .fishydex-card-content {
    transform: translateY(1px);
  }

  .fishydex-card-open:active + .fishydex-card-content .fishydex-card-main {
    transform: translateY(0);
  }

  .fishydex-icon-wrap {
    display: grid;
    place-items: center;
    width: 4.75rem;
    height: 4.75rem;
    border-radius: 34%;
    border: 1px solid color-mix(in oklab, var(--color-base-content, #1f2937) 18%, var(--dex-line) 82%);
    background: var(--dex-surface-strong);
  }

  .fishydex-icon-wrap.grade-red,
  .fishydex-details-icon-wrap.grade-red {
    border-color: color-mix(in oklab, var(--dex-grade-red) 28%, var(--dex-line) 72%);
  }

  .fishydex-icon-wrap.grade-yellow,
  .fishydex-details-icon-wrap.grade-yellow {
    border-color: color-mix(in oklab, var(--dex-grade-yellow) 28%, var(--dex-line) 72%);
  }

  .fishydex-icon-wrap.grade-blue,
  .fishydex-details-icon-wrap.grade-blue {
    border-color: color-mix(in oklab, var(--dex-grade-blue) 28%, var(--dex-line) 72%);
  }

  .fishydex-icon-wrap.grade-green,
  .fishydex-details-icon-wrap.grade-green {
    border-color: color-mix(in oklab, var(--dex-grade-green) 28%, var(--dex-line) 72%);
  }

  .fishydex-icon-wrap.grade-white,
  .fishydex-details-icon-wrap.grade-white {
    border-color: color-mix(in oklab, var(--dex-grade-white) 22%, var(--dex-line) 78%);
  }

  .fishydex-icon-wrap.grade-unknown,
  .fishydex-details-icon-wrap.grade-unknown {
    border-color: color-mix(in oklab, var(--dex-grade-unknown) 18%, var(--dex-line) 82%);
  }

  .fishydex-icon {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    margin: 0;
    object-fit: contain;
    image-rendering: auto;
  }

  .fishydex-placeholder {
    color: var(--dex-text-muted);
    font-size: 2rem;
  }

  .fishydex-name {
    max-width: 100%;
    font-weight: 800;
    line-height: 1.25;
    text-align: center;
    text-wrap: balance;
  }

  .fishydex-price {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    max-width: 100%;
    color: var(--dex-text-muted);
    font-weight: 700;
    line-height: 1.2;
  }

  .fishydex-card-price {
    align-items: baseline;
    justify-content: center;
    font-size: 0.88rem;
    text-align: center;
    text-wrap: balance;
  }

  .fishydex-details-price {
    font-size: 1rem;
  }

  .fishydex-price-icon {
    display: inline-flex;
    flex: 0 0 auto;
  }

  .fishydex-price-icon .fishy-icon {
    display: block;
    width: 1.1rem;
    height: 1.1rem;
    transform: translateY(0.16em);
  }

  .fishydex-price-value {
    min-width: 0;
  }

  .fishydex-empty {
    color: var(--color-base-content, #1f2937);
    text-align: center;
  }

  @keyframes fishydex-card-in {
    from {
      opacity: 0;
      transform: translateY(0.5rem);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fishydex-caught-stamp {
    0% {
      transform: translateY(0) scale(1) rotate(0deg);
    }

    35% {
      transform: translateY(-0.42rem) scale(1.34) rotate(-13deg);
    }

    72% {
      transform: translateY(0.08rem) scale(0.94) rotate(0deg);
    }

    100% {
      transform: translateY(0) scale(1) rotate(0deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fishydex-card.is-entering {
      animation: none;
    }

    .fishydex-caught-button.is-stamping .fishy-icon,
    .fishydex-favourite-button.is-stamping .fishy-icon {
      animation: none;
    }
  }

  .fishydex-details-modal[hidden] {
    display: none;
  }

  .fishydex-details-modal {
    position: fixed;
    inset: 0;
    z-index: 40;
    display: grid;
    place-items: center;
  }

  .fishydex-details-backdrop {
    appearance: none;
    position: absolute;
    inset: 0;
    border: 0;
    background: color-mix(in srgb, var(--color-base-content, #1f2937) 24%, transparent);
    cursor: pointer;
    margin: 0;
    padding: 0;
  }

  .fishydex-details-panel {
    position: relative;
    z-index: 1;
    max-height: min(90vh, 46rem);
    overflow: auto;
    color: var(--color-base-content, #1f2937);
  }

  .fishydex-details-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: start;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .fishydex-details-header-main {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
    min-width: 0;
  }

  .fishydex-details-title {
    margin: 0;
    font-size: clamp(1.25rem, 2.2vw, 1.85rem);
    font-weight: 700;
  }

  .fishydex-details-title-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem;
  }

  .fishydex-details-close {
    flex: none;
  }

  #fishydex-details-caught-toggle {
    transition: background 120ms ease, outline-color 120ms ease;
  }

  #fishydex-details-caught-toggle[data-caught-state="uncaught"] {
    color: color-mix(in oklab, var(--color-base-content, #1f2937) 60%, transparent);
  }

  #fishydex-details-caught-toggle[data-caught-state="caught"] {
    color: color-mix(in oklab, var(--color-success, #2f855a) 82%, var(--color-base-content, #1f2937) 18%);
  }

  #fishydex-details-favourite-toggle[data-favourite-state="active"] {
    color: color-mix(in oklab, var(--color-error, #d64545) 82%, var(--color-base-content, #1f2937) 18%);
  }

  .fishydex-details-icon-wrap {
    display: grid;
    place-items: center;
    width: 5.5rem;
    height: 5.5rem;
    border-radius: 34%;
    border: 1px solid color-mix(in oklab, var(--color-base-content, #1f2937) 18%, var(--dex-line) 82%);
    background: var(--dex-surface-strong);
  }

  .fishydex-details-icon {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .fishydex-details-copy {
    display: grid;
    gap: 0.75rem;
    min-width: 0;
  }

  .fishydex-details-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .fishydex-details-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
    gap: 0.75rem;
  }

  .fishydex-details-guide {
    margin-bottom: 1rem;
  }

  .fishydex-details-guide-frame {
    display: grid;
    place-items: center;
    min-height: 14rem;
    padding: 1rem;
  }

  .fishydex-details-guide-image {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 16rem;
    object-fit: contain;
  }

  .fishydex-details-meta-card,
  .fishydex-details-section {
    padding: 0.85rem 0.95rem;
  }

  .fishydex-details-meta-card dt {
    margin: 0 0 0.35rem;
    color: var(--dex-text-muted);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .fishydex-details-meta-card dd {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
  }

  .fishydex-details-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--dex-highlight) 52%, transparent);
    text-underline-offset: 0.14em;
  }

  .fishydex-details-link:hover,
  .fishydex-details-link:focus-visible {
    color: var(--color-primary, #e07a5f);
    text-decoration-color: currentColor;
  }

  .fishydex-details-stack {
    display: grid;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .fishydex-details-section h4 {
    margin: 0 0 0.45rem;
    font-size: 1rem;
  }

  .fishydex-details-note {
    margin: 0.6rem 0 0;
    color: var(--dex-text-muted);
    font-size: 0.92rem;
  }

  .fishydex-details-spot-list {
    display: grid;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .fishydex-details-spot {
    display: grid;
    gap: 0.55rem;
    padding: 0.85rem 1rem;
  }

  .fishydex-details-spot-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .fishydex-details-spot-name {
    font-weight: 600;
    line-height: 1.3;
  }

  .fishydex-details-spot-rgb {
    color: var(--dex-text-muted);
    font-size: 0.8rem;
  }

  .fishydex-details-spot-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .fishydex-details-note.is-error {
    color: color-mix(in oklab, var(--color-error, #d64545) 62%, var(--color-base-content, #1f2937) 38%);
  }

  @media (max-width: 900px) {
    .fishydex-details-header {
      grid-template-columns: 1fr;
    }

    .fishydex-details-header-main {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .fishydex-card-grid {
      grid-template-columns: repeat(auto-fill, minmax(9.75rem, 1fr));
    }
  }
</style>

<script src="/js/pages/fishydex.js"></script>

<div id="fishydex-app" class="not-prose"
     data-signals="{
       fish: [],
       revision: '',
       count: 0,
       search_query: '',
       caught_filter: 'all',
       favourite_filter: false,
       grade_filters: [],
       method_filters: [],
       show_dried: false,
       sort_field: 'price',
       sort_direction: 'desc',
       caught_ids: [],
       favourite_ids: [],
       _selected_fish_id: 0,
       _progress_panel_collapsed: false,
       _filter_panel_collapsed: false,
       catalog_count: 0,
       total_count: 0,
       visible_count: 0,
       caught_count: 0,
       completion_percent: 0,
       red_total_count: 0,
       red_caught_count: 0,
       red_completion_percent: 0,
       yellow_total_count: 0,
       yellow_caught_count: 0,
       yellow_completion_percent: 0,
       blue_total_count: 0,
       blue_caught_count: 0,
       blue_completion_percent: 0,
       green_total_count: 0,
       green_caught_count: 0,
       green_completion_percent: 0,
       white_total_count: 0,
       white_caught_count: 0,
       white_completion_percent: 0,
       supports_grade_filter: false,
       supports_method_filter: false,
       supports_dried_filter: false,
       _loading: true,
       _caught_stamp_fish_id: null,
       _favourite_stamp_fish_id: null,
       _fishydex_actions: {
         exportCaughtToken: 0,
         importCaughtToken: 0,
         closeDetailsToken: 0,
       },
       _status_message: '',
       _api_error_message: '',
       _api_error_hint: '',
     }"
     data-indicator:_loading
     data-init="window.Fishydex.restore($); @get(window.Fishydex.fishApiUrl())">
  <div hidden
       data-effect="window.Fishydex.sync($)"></div>

  <section class="fishydex-shell">
    <div class="fishydex-bento">
      <fieldset class="fishydex-stats card card-border bg-base-100">
        <legend class="fishydex-panel-legend fieldset-legend ml-6 px-2">
          <span class="fishydex-panel-label"><svg class="fishy-icon fishy-icon--inline size-5" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-chart-pie-2-fill"></use></svg><span>Progress</span></span>
          <button type="button"
                  class="fishydex-panel-toggle btn btn-ghost btn-xs btn-circle"
                  data-panel-toggle="progress"
                  aria-controls="fishydex-progress-body"
                  data-class:is-collapsed="$_progress_panel_collapsed"
                  data-attr:aria-expanded="(!$_progress_panel_collapsed).toString()"
                  data-attr:aria-label="$_progress_panel_collapsed ? 'Expand progress panel' : 'Collapse progress panel'"
                  data-attr:title="$_progress_panel_collapsed ? 'Expand progress panel' : 'Collapse progress panel'"
                  data-on:click="$_progress_panel_collapsed = !$_progress_panel_collapsed"><svg class="fishy-icon fishy-icon--inline size-4" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-caret-down"></use></svg></button>
        </legend>
        <div id="fishydex-progress-body" class="card-body fishydex-stats-body pt-0" data-show="!$_progress_panel_collapsed">
        <div class="fishydex-progress-overview rounded-box border border-base-300 bg-base-200">
          <div class="fishydex-progress-overview-chart">
            <div class="radial-progress fishydex-progress-pie is-overall"
                 role="progressbar"
                 aria-valuemin="0"
                 aria-valuemax="100"
                 data-attr:style="'--value:' + ($completion_percent || 0) + '; --size:7.5rem; --thickness:0.72rem;'"
                 data-attr:aria-valuenow="String($completion_percent || 0)"
                 data-attr:aria-label="'Catalog completion: ' + ($caught_count || 0) + ' of ' + ($catalog_count || 0) + ' fish caught (' + ($completion_percent || 0) + '%)'">
              <span class="fishydex-progress-pie-value" data-text="($completion_percent || 0) + '%'"></span>
            </div>
          </div>
          <div class="fishydex-progress-overview-copy">
            <span class="fishydex-progress-kicker">Overall</span>
            <span class="fishydex-progress-title">Catalog Completion</span>
            <span class="fishydex-progress-count" data-text="($caught_count || 0) + ' / ' + ($catalog_count || 0)"></span>
            <span class="fishydex-subtle"
                  data-text="($catalog_count || 0) > 0 ? (Math.max(($catalog_count || 0) - ($caught_count || 0), 0) + ' remaining') : 'No catalog entries yet'"></span>
          </div>
        </div>
          <div class="fishydex-grade-stats" data-show="$supports_grade_filter">
            <div class="fishydex-grade-progress-card rounded-box border border-base-300 bg-base-200">
              <div class="radial-progress fishydex-progress-pie grade-red"
                   role="progressbar"
                   aria-valuemin="0"
                   aria-valuemax="100"
                   data-attr:style="'--value:' + ($red_completion_percent || 0) + '; --size:4.85rem; --thickness:0.48rem;'"
                   data-attr:aria-valuenow="String($red_completion_percent || 0)"
                   data-attr:aria-label="'Red completion: ' + ($red_caught_count || 0) + ' of ' + ($red_total_count || 0) + ' fish caught (' + ($red_completion_percent || 0) + '%)'">
                <span class="fishydex-grade-progress-percent" data-text="($red_completion_percent || 0) + '%'"></span>
              </div>
              <div class="fishydex-grade-progress-copy">
                <div class="fishydex-grade-progress-title grade-red">Red</div>
                <div class="fishydex-grade-progress-value" data-text="($red_caught_count || 0) + ' / ' + ($red_total_count || 0)"></div>
                <div class="fishydex-grade-progress-meta"
                     data-text="($red_total_count || 0) > 0 ? (Math.max(($red_total_count || 0) - ($red_caught_count || 0), 0) + ' remaining') : 'No catalog fish'"></div>
              </div>
            </div>
            <div class="fishydex-grade-progress-card rounded-box border border-base-300 bg-base-200">
              <div class="radial-progress fishydex-progress-pie grade-yellow"
                   role="progressbar"
                   aria-valuemin="0"
                   aria-valuemax="100"
                   data-attr:style="'--value:' + ($yellow_completion_percent || 0) + '; --size:4.85rem; --thickness:0.48rem;'"
                   data-attr:aria-valuenow="String($yellow_completion_percent || 0)"
                   data-attr:aria-label="'Yellow completion: ' + ($yellow_caught_count || 0) + ' of ' + ($yellow_total_count || 0) + ' fish caught (' + ($yellow_completion_percent || 0) + '%)'">
                <span class="fishydex-grade-progress-percent" data-text="($yellow_completion_percent || 0) + '%'"></span>
              </div>
              <div class="fishydex-grade-progress-copy">
                <div class="fishydex-grade-progress-title grade-yellow">Yellow</div>
                <div class="fishydex-grade-progress-value" data-text="($yellow_caught_count || 0) + ' / ' + ($yellow_total_count || 0)"></div>
                <div class="fishydex-grade-progress-meta"
                     data-text="($yellow_total_count || 0) > 0 ? (Math.max(($yellow_total_count || 0) - ($yellow_caught_count || 0), 0) + ' remaining') : 'No catalog fish'"></div>
              </div>
            </div>
            <div class="fishydex-grade-progress-card rounded-box border border-base-300 bg-base-200">
              <div class="radial-progress fishydex-progress-pie grade-blue"
                   role="progressbar"
                   aria-valuemin="0"
                   aria-valuemax="100"
                   data-attr:style="'--value:' + ($blue_completion_percent || 0) + '; --size:4.85rem; --thickness:0.48rem;'"
                   data-attr:aria-valuenow="String($blue_completion_percent || 0)"
                   data-attr:aria-label="'Blue completion: ' + ($blue_caught_count || 0) + ' of ' + ($blue_total_count || 0) + ' fish caught (' + ($blue_completion_percent || 0) + '%)'">
                <span class="fishydex-grade-progress-percent" data-text="($blue_completion_percent || 0) + '%'"></span>
              </div>
              <div class="fishydex-grade-progress-copy">
                <div class="fishydex-grade-progress-title grade-blue">Blue</div>
                <div class="fishydex-grade-progress-value" data-text="($blue_caught_count || 0) + ' / ' + ($blue_total_count || 0)"></div>
                <div class="fishydex-grade-progress-meta"
                     data-text="($blue_total_count || 0) > 0 ? (Math.max(($blue_total_count || 0) - ($blue_caught_count || 0), 0) + ' remaining') : 'No catalog fish'"></div>
              </div>
            </div>
            <div class="fishydex-grade-progress-card rounded-box border border-base-300 bg-base-200">
              <div class="radial-progress fishydex-progress-pie grade-green"
                   role="progressbar"
                   aria-valuemin="0"
                   aria-valuemax="100"
                   data-attr:style="'--value:' + ($green_completion_percent || 0) + '; --size:4.85rem; --thickness:0.48rem;'"
                   data-attr:aria-valuenow="String($green_completion_percent || 0)"
                   data-attr:aria-label="'Green completion: ' + ($green_caught_count || 0) + ' of ' + ($green_total_count || 0) + ' fish caught (' + ($green_completion_percent || 0) + '%)'">
                <span class="fishydex-grade-progress-percent" data-text="($green_completion_percent || 0) + '%'"></span>
              </div>
              <div class="fishydex-grade-progress-copy">
                <div class="fishydex-grade-progress-title grade-green">Green</div>
                <div class="fishydex-grade-progress-value" data-text="($green_caught_count || 0) + ' / ' + ($green_total_count || 0)"></div>
                <div class="fishydex-grade-progress-meta"
                     data-text="($green_total_count || 0) > 0 ? (Math.max(($green_total_count || 0) - ($green_caught_count || 0), 0) + ' remaining') : 'No catalog fish'"></div>
              </div>
            </div>
            <div class="fishydex-grade-progress-card rounded-box border border-base-300 bg-base-200">
              <div class="radial-progress fishydex-progress-pie grade-white"
                   role="progressbar"
                   aria-valuemin="0"
                   aria-valuemax="100"
                   data-attr:style="'--value:' + ($white_completion_percent || 0) + '; --size:4.85rem; --thickness:0.48rem;'"
                   data-attr:aria-valuenow="String($white_completion_percent || 0)"
                   data-attr:aria-label="'White completion: ' + ($white_caught_count || 0) + ' of ' + ($white_total_count || 0) + ' fish caught (' + ($white_completion_percent || 0) + '%)'">
                <span class="fishydex-grade-progress-percent" data-text="($white_completion_percent || 0) + '%'"></span>
              </div>
              <div class="fishydex-grade-progress-copy">
                <div class="fishydex-grade-progress-title grade-white">White</div>
                <div class="fishydex-grade-progress-value" data-text="($white_caught_count || 0) + ' / ' + ($white_total_count || 0)"></div>
                <div class="fishydex-grade-progress-meta"
                     data-text="($white_total_count || 0) > 0 ? (Math.max(($white_total_count || 0) - ($white_caught_count || 0), 0) + ' remaining') : 'No catalog fish'"></div>
              </div>
            </div>
          </div>
        <div class="fishydex-actions">
          <button type="button"
                  class="btn btn-sm btn-soft btn-primary fishydex-button"
                  data-on:click="$_fishydex_actions.exportCaughtToken = ($_fishydex_actions.exportCaughtToken || 0) + 1">Export</button>
          <button type="button"
                  class="btn btn-sm btn-outline fishydex-button"
                  data-on:click="$_fishydex_actions.importCaughtToken = ($_fishydex_actions.importCaughtToken || 0) + 1">Import</button>
        </div>
        </div>
      </fieldset>

      <fieldset class="fishydex-screen card card-border bg-base-100">
        <legend class="fishydex-panel-legend fieldset-legend ml-6 px-2">
          <span class="fishydex-panel-label"><svg class="fishy-icon fishy-icon--inline size-5" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-filter-2-fill"></use></svg><span>Filter</span></span>
          <button type="button"
                  class="fishydex-panel-toggle btn btn-ghost btn-xs btn-circle"
                  data-panel-toggle="filter"
                  aria-controls="fishydex-filter-body"
                  data-class:is-collapsed="$_filter_panel_collapsed"
                  data-attr:aria-expanded="(!$_filter_panel_collapsed).toString()"
                  data-attr:aria-label="$_filter_panel_collapsed ? 'Expand filter panel' : 'Collapse filter panel'"
                  data-attr:title="$_filter_panel_collapsed ? 'Expand filter panel' : 'Collapse filter panel'"
                  data-on:click="$_filter_panel_collapsed = !$_filter_panel_collapsed"><svg class="fishy-icon fishy-icon--inline size-4" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-caret-down"></use></svg></button>
        </legend>
        <div id="fishydex-filter-body" class="card-body fishydex-panel-body pt-0" data-show="!$_filter_panel_collapsed">
        <div class="fishydex-controls">
          <fieldset class="fishydex-filter-group fieldset rounded-box border border-base-300 bg-base-200 p-4">
            <legend class="fieldset-legend">Search</legend>
            <label class="fishydex-search-field input input-bordered">
              <svg class="fishy-icon fishy-icon--inline h-[1em] opacity-50" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-search-field"></use></svg>
              <span class="sr-only">Search fish</span>
              <input class="fishydex-search"
                     type="search"
                     autocomplete="off"
                     placeholder="Search by fish name or ID"
                     data-bind:search_query>
            </label>
          </fieldset>

          <div class="fishydex-filter-stack">
            <fieldset class="fishydex-filter-group fieldset rounded-box border border-base-300 bg-base-200 p-4">
              <legend class="fieldset-legend">Status</legend>
              <div class="fishydex-filter-chips" role="group" aria-label="Status filters">
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip"
                        data-class:is-active="$caught_filter === 'all'"
                        data-class:btn-active="$caught_filter === 'all'"
                        data-attr:aria-pressed="($caught_filter === 'all').toString()"
                        data-on:click="$caught_filter = 'all'">All</button>
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip filter-caught"
                        data-class:is-active="$caught_filter === 'caught'"
                        data-class:btn-active="$caught_filter === 'caught'"
                        data-attr:aria-pressed="($caught_filter === 'caught').toString()"
                        data-on:click="$caught_filter = 'caught'"><svg class="fishy-icon fishy-icon--inline size-5" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-check-badge-solid"></use></svg><span>Caught</span></button>
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip filter-missing"
                        data-class:is-active="$caught_filter === 'missing'"
                        data-class:btn-active="$caught_filter === 'missing'"
                        data-attr:aria-pressed="($caught_filter === 'missing').toString()"
                        data-on:click="$caught_filter = 'missing'"><svg class="fishy-icon fishy-icon--inline size-5" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-check-circle-dash-fill"></use></svg><span>Missing</span></button>
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip filter-favourite"
                        data-class:is-active="$favourite_filter"
                        data-class:btn-active="$favourite_filter"
                        data-attr:aria-pressed="$favourite_filter.toString()"
                        data-on:click="$favourite_filter = !$favourite_filter"><svg class="fishy-icon fishy-icon--inline size-5" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-heart-fill"></use></svg><span>Favourite</span></button>
              </div>
            </fieldset>

            <fieldset class="fishydex-filter-group fieldset rounded-box border border-base-300 bg-base-200 p-4"
                      data-show="$supports_grade_filter">
              <legend class="fieldset-legend">Grade</legend>
              <div class="fishydex-filter-chips" role="group" aria-label="Grade color filters">
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip grade-red"
                        data-class:is-active="($grade_filters || []).includes('red')"
                        data-class:btn-active="($grade_filters || []).includes('red')"
                        data-attr:aria-pressed="(($grade_filters || []).includes('red')).toString()"
                        data-on:click="$grade_filters = window.__fishystuffDatastarState.toggleOrderedValue($grade_filters, 'red', ['red', 'yellow', 'blue', 'green', 'white'])">Red</button>
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip grade-yellow"
                        data-class:is-active="($grade_filters || []).includes('yellow')"
                        data-class:btn-active="($grade_filters || []).includes('yellow')"
                        data-attr:aria-pressed="(($grade_filters || []).includes('yellow')).toString()"
                        data-on:click="$grade_filters = window.__fishystuffDatastarState.toggleOrderedValue($grade_filters, 'yellow', ['red', 'yellow', 'blue', 'green', 'white'])">Yellow</button>
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip grade-blue"
                        data-class:is-active="($grade_filters || []).includes('blue')"
                        data-class:btn-active="($grade_filters || []).includes('blue')"
                        data-attr:aria-pressed="(($grade_filters || []).includes('blue')).toString()"
                        data-on:click="$grade_filters = window.__fishystuffDatastarState.toggleOrderedValue($grade_filters, 'blue', ['red', 'yellow', 'blue', 'green', 'white'])">Blue</button>
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip grade-green"
                        data-class:is-active="($grade_filters || []).includes('green')"
                        data-class:btn-active="($grade_filters || []).includes('green')"
                        data-attr:aria-pressed="(($grade_filters || []).includes('green')).toString()"
                        data-on:click="$grade_filters = window.__fishystuffDatastarState.toggleOrderedValue($grade_filters, 'green', ['red', 'yellow', 'blue', 'green', 'white'])">Green</button>
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip grade-white"
                        data-class:is-active="($grade_filters || []).includes('white')"
                        data-class:btn-active="($grade_filters || []).includes('white')"
                        data-attr:aria-pressed="(($grade_filters || []).includes('white')).toString()"
                        data-on:click="$grade_filters = window.__fishystuffDatastarState.toggleOrderedValue($grade_filters, 'white', ['red', 'yellow', 'blue', 'green', 'white'])">White</button>
              </div>
            </fieldset>

            <fieldset class="fishydex-filter-group fieldset rounded-box border border-base-300 bg-base-200 p-4"
                      data-show="$supports_method_filter || $supports_dried_filter">
              <legend class="fieldset-legend">Method</legend>
              <div class="fishydex-filter-chips" role="group" aria-label="Catch method and dried filters">
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip"
                        data-show="$supports_method_filter"
                        data-class:is-active="($method_filters || []).length === 0"
                        data-class:btn-active="($method_filters || []).length === 0"
                        data-attr:aria-pressed="(($method_filters || []).length === 0).toString()"
                        data-on:click="$method_filters = []">All</button>
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip filter-rod"
                        data-show="$supports_method_filter"
                        data-class:is-active="($method_filters || []).includes('rod')"
                        data-class:btn-active="($method_filters || []).includes('rod')"
                        data-attr:aria-pressed="(($method_filters || []).includes('rod')).toString()"
                        data-on:click="$method_filters = window.__fishystuffDatastarState.toggleOrderedValue($method_filters, 'rod', ['rod', 'harpoon'])">Rod</button>
                <button type="button"
                        class="btn btn-sm btn-outline fishydex-filter-chip filter-harpoon"
                        data-show="$supports_method_filter"
                        data-class:is-active="($method_filters || []).includes('harpoon')"
                        data-class:btn-active="($method_filters || []).includes('harpoon')"
                        data-attr:aria-pressed="(($method_filters || []).includes('harpoon')).toString()"
                        data-on:click="$method_filters = window.__fishystuffDatastarState.toggleOrderedValue($method_filters, 'harpoon', ['rod', 'harpoon'])">Harpoon</button>
                <button type="button"
                        data-show="$supports_dried_filter"
                        class="btn btn-sm btn-outline fishydex-filter-chip filter-show-dried"
                        data-class:is-active="$show_dried"
                        data-class:btn-active="$show_dried"
                        data-attr:aria-pressed="$show_dried.toString()"
                        data-on:click="$show_dried = !$show_dried">Show Dried</button>
              </div>
            </fieldset>

            <div class="fishydex-filter-meta">
              <span class="fishydex-filter-count"
                    data-text="'Showing ' + ($visible_count || 0) + '/' + ($catalog_count || 0) + ' matches'"></span>
              <button type="button"
                      class="btn btn-sm btn-soft fishydex-filter-clear"
                      data-on:click="$search_query = ''; $caught_filter = 'all'; $favourite_filter = false; $grade_filters = []; $method_filters = []; $show_dried = false">Clear filters</button>
            </div>
          </div>

          <div class="fishydex-status" data-show="($_status_message || '').length > 0">
            <strong>Status:</strong>
            <span data-text="$_status_message"></span>
          </div>

          <div class="fishydex-error" data-show="($_api_error_message || '').length > 0">
            <strong data-text="$_api_error_message"></strong>
            <div class="fishydex-subtle" data-show="($_api_error_hint || '').length > 0" data-text="$_api_error_hint"></div>
          </div>
        </div>
        </div>
      </fieldset>
    </div>

    <fieldset class="fishydex-grid-shell card card-border bg-base-100">
      <legend class="fishydex-panel-legend fieldset-legend ml-6 px-2">
        <span class="fishydex-panel-label"><svg class="fishy-icon fishy-icon--inline size-5" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-nav-dex"></use></svg><span>Catalog</span></span>
        <span class="fishydex-panel-controls" role="group" aria-label="Catalog sort controls">
          <button type="button"
                  class="btn btn-sm btn-ghost fishydex-sort-button"
                  data-class:is-active="$sort_field === 'price'"
                  data-attr:aria-pressed="($sort_field === 'price').toString()"
                  data-attr:aria-label="$sort_field === 'price' ? 'Toggle price sort direction. Current: ' + ($sort_direction === 'desc' ? 'descending.' : 'ascending.') : 'Sort catalog by price ascending.'"
                  data-on:click="$sort_direction = $sort_field === 'price' ? ($sort_direction === 'desc' ? 'asc' : 'desc') : 'asc'; $sort_field = 'price'"><span class="fishydex-sort-price-icon" aria-hidden="true"><svg class="fishy-icon fishy-icon--inline size-5" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-coin-2-fill"></use></svg><span class="fishydex-sort-price-arrow"><span data-show="$sort_field === 'price' ? $sort_direction === 'asc' : true" style="display: none;"><svg class="fishy-icon fishy-icon--inline size-4" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-arrow-up-fill"></use></svg></span><span data-show="$sort_field === 'price' && $sort_direction === 'desc'" style="display: none;"><svg class="fishy-icon fishy-icon--inline size-4" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-arrow-down-fill"></use></svg></span></span></span><span>Price</span></button>
          <button type="button"
                  class="btn btn-sm btn-ghost fishydex-sort-button"
                  data-class:is-active="$sort_field === 'name'"
                  data-attr:aria-pressed="($sort_field === 'name').toString()"
                  data-attr:aria-label="$sort_field === 'name' ? 'Toggle name sort direction. Current: ' + ($sort_direction === 'desc' ? 'descending.' : 'ascending.') : 'Sort catalog by name ascending.'"
                  data-on:click="$sort_direction = $sort_field === 'name' ? ($sort_direction === 'desc' ? 'asc' : 'desc') : 'asc'; $sort_field = 'name'"><span data-show="$sort_field === 'name' ? $sort_direction === 'asc' : true" style="display: none;"><svg class="fishy-icon fishy-icon--inline size-5" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-az-sort-ascending-letters-fill"></use></svg></span><span data-show="$sort_field === 'name' && $sort_direction === 'desc'" style="display: none;"><svg class="fishy-icon fishy-icon--inline size-5" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-za-sort-descending-letters-fill"></use></svg></span><span>Name</span></button>
          <span class="loading loading-spinner loading-xs fishydex-panel-spinner" data-show="$_loading"></span>
        </span>
      </legend>
      <div class="card-body fishydex-grid-body">
      <div id="fishydex-grid" class="fishydex-groups"></div>
      </div>
    </fieldset>
  </section>

  <div id="fishydex-details" class="fishydex-details-modal modal" hidden>
    <section class="fishydex-details-panel modal-box card card-border bg-base-100 w-11/12 max-w-5xl"
             role="dialog"
             aria-modal="true"
             aria-labelledby="fishydex-details-title">
      <div class="fishydex-details-header">
        <div class="fishydex-details-header-main">
          <div id="fishydex-details-icon-frame" class="fishydex-details-icon-wrap grade-unknown">
            <img id="fishydex-details-icon" class="fishydex-details-icon" hidden>
            <div id="fishydex-details-placeholder" class="fishydex-placeholder">?</div>
          </div>

          <div class="fishydex-details-copy">
            <div class="fishydex-details-title-row">
              <h3 id="fishydex-details-title" class="fishydex-details-title">Fish</h3>
              <button type="button"
                      id="fishydex-details-favourite-toggle"
                      class="fishydex-favourite-button btn btn-sm btn-circle btn-ghost"
                      data-action="toggle-favourite-details"
                      aria-pressed="false"
                      aria-label="Mark fish as favourite"></button>
              <button type="button"
                      id="fishydex-details-caught-toggle"
                      class="fishydex-caught-button btn btn-sm btn-circle btn-ghost"
                      data-action="toggle-caught-details"
                      aria-pressed="false"
                      aria-label="Mark fish as caught"></button>
            </div>

            <div class="fishydex-details-badges">
              <span id="fishydex-details-favourite" class="badge badge-soft badge-error" hidden>Favourite</span>
              <span id="fishydex-details-caught" class="fishydex-caught badge badge-soft badge-success">Caught</span>
              <span id="fishydex-details-grade" class="fishydex-grade badge badge-soft grade-unknown">Unknown</span>
              <span id="fishydex-details-method-rod" class="fishydex-method badge badge-soft method-rod" hidden>Rod</span>
              <span id="fishydex-details-method-harpoon" class="fishydex-method badge badge-soft method-harpoon" hidden>Harpoon</span>
              <span id="fishydex-details-dried-badge" class="fishydex-method badge badge-soft method-dried" hidden>Dried</span>
            </div>
          </div>
        </div>
        <button type="button"
                class="btn btn-sm btn-circle btn-ghost fishydex-details-close"
                data-on:click="$_fishydex_actions.closeDetailsToken = ($_fishydex_actions.closeDetailsToken || 0) + 1"
                aria-label="Close fish details"
                title="Close fish details"><svg class="fishy-icon fishy-icon--inline size-5" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260326-6#fishy-x-circle"></use></svg><span class="sr-only">Close</span></button>
      </div>

      <div class="fishydex-details-guide">
        <div class="fishydex-details-guide-frame rounded-box border border-base-300 bg-base-200">
          <img id="fishydex-details-guide-image" class="fishydex-details-guide-image" hidden>
          <div id="fishydex-details-guide-placeholder" class="fishydex-placeholder">?</div>
        </div>
      </div>

      <dl class="fishydex-details-meta">
        <div class="fishydex-details-meta-card card card-border bg-base-200">
          <dt>Item Key</dt>
          <dd id="fishydex-details-item-key"></dd>
        </div>
        <div class="fishydex-details-meta-card card card-border bg-base-200">
          <dt>Vendor Price</dt>
          <dd id="fishydex-details-vendor-price"></dd>
        </div>
      </dl>

      <div class="fishydex-details-stack">
        <section class="fishydex-details-section card card-border bg-base-200">
          <h4>Best Spots</h4>
          <p id="fishydex-details-spots-note" class="fishydex-details-note"></p>
          <div id="fishydex-details-spots-list" class="fishydex-details-spot-list"></div>
        </section>
      </div>
    </section>
    <button type="button"
            class="fishydex-details-backdrop modal-backdrop"
            data-on:click="$_fishydex_actions.closeDetailsToken = ($_fishydex_actions.closeDetailsToken || 0) + 1"
            aria-label="Close fish details"></button>
  </div>
</div>
```
