.title = "Fishing Calculator",
.date = @date("2025-03-23T00:00:00"),
.author = "Karpfen",
.layout = "calculator.shtml",
.draft = false,
.tags = ["calculator", "AFR", "DRR"],
---

## Fishing Calculator

```=html
<script>
    const ICON_SPRITE_URL = "/img/icons.svg?v=20260325-2";
    const CALCULATOR_STORAGE_KEY = "calculator";
    const calculatorLang = document.documentElement.lang?.trim().toLowerCase().startsWith("ko")
        ? "ko"
        : "en";

    const urlParams = new URLSearchParams(window.location.search);
    const presetQueryParam = urlParams.get("preset");

    const createEmptySignals = () => ({
        level: 5,
        lifeskill_level: "100",
        zone: "240,74,74",
        resources: 0,
        rod: "item:16162",
        float: "",
        chair: "item:705539",
        lightstone_set: "effect:blacksmith-s-blessing",
        backpack: "item:830150",
        outfit: [
            "effect:8-piece-outfit-set-effect",
            "effect:awakening-weapon-outfit",
            "effect:mainhand-weapon-outfit",
        ],
        food: ["item:9359"],
        buff: ["", "item:721092"],
        pet1: {
            tier: "5",
            special: "auto_fishing_time_reduction",
            talent: "durability_reduction_resistance",
            skills: ["fishing_exp"],
        },
        pet2: {
            tier: "4",
            special: "",
            talent: "durability_reduction_resistance",
            skills: ["fishing_exp"],
        },
        pet3: {
            tier: "4",
            special: "",
            talent: "durability_reduction_resistance",
            skills: ["fishing_exp"],
        },
        pet4: {
            tier: "4",
            special: "",
            talent: "durability_reduction_resistance",
            skills: ["fishing_exp"],
        },
        pet5: {
            tier: "4",
            special: "",
            talent: "durability_reduction_resistance",
            skills: ["fishing_exp"],
        },
        catchTimeActive: 17.5,
        catchTimeAfk: 6.5,
        timespanAmount: 8,
        timespanUnit: "hours",
        brand: true,
        active: false,
        debug: false,
        _loading: false,
        _calc: {
            zone_name: "",
            abundance_label: "",
            zone_bite_min: "",
            zone_bite_max: "",
            effective_bite_min: "",
            effective_bite_max: "",
            total_time: "",
            bite_time: "",
            auto_fish_time: "",
            auto_fish_time_reduction_text: "",
            casts_title: "",
            casts_average: "",
            durability_reduction_resistance_text: "",
            chance_to_consume_durability_text: "",
            durability_loss_title: "",
            durability_loss_average: "",
            timespan_text: "",
            bite_time_title: "",
            auto_fish_time_title: "",
            catch_time_title: "",
            unoptimized_time_title: "",
            show_auto_fishing: false,
            percent_bite: "0.00",
            percent_af: "0.00",
            percent_catch: "0.00",
            debug_json: "",
        },
    });

    const cloneSignals = (signals) => JSON.parse(JSON.stringify(signals));

    const publicCalculatorSignals = (signals) =>
        Object.fromEntries(
            Object.entries(signals ?? {}).filter(([key]) => !key.startsWith("_"))
        );

    const presetURL = (signals) => {
        const payload = JSON.stringify(publicCalculatorSignals(signals));
        return (
            window.location.origin +
            window.location.pathname +
            "?preset=" +
            LZString.compressToEncodedURIComponent(payload)
        );
    };

    const clearSignals = () => {
        localStorage.removeItem(CALCULATOR_STORAGE_KEY);
        window.location.reload();
    };

    const loadStoredSignals = () => {
        const raw = localStorage.getItem(CALCULATOR_STORAGE_KEY);
        if (!raw) {
            return null;
        }
        try {
            const parsed = JSON.parse(raw);
            return parsed && typeof parsed === "object" ? parsed : null;
        } catch (error) {
            console.error("Error parsing stored calculator state:", error);
            return null;
        }
    };

    const mergeWithEmptySignals = (source) => {
        const defaults = createEmptySignals();
        if (!source || typeof source !== "object") {
            return defaults;
        }
        const merged = { ...defaults };
        for (const key of Object.keys(defaults)) {
            if (!(key in source)) {
                continue;
            }
            if (key === "_calc" || key === "_loading") {
                continue;
            }
            if (key.startsWith("pet")) {
                merged[key] = {
                    ...defaults[key],
                    ...(source[key] && typeof source[key] === "object" ? source[key] : {}),
                };
                continue;
            }
            merged[key] = source[key];
        }
        return merged;
    };

    const bootstrapSignals = loadStoredSignals();
    const initialSignals = () => mergeWithEmptySignals(bootstrapSignals);
    const initialCalculatorSignals = initialSignals();

    if (presetQueryParam) {
        try {
            const jsonString = LZString.decompressFromEncodedURIComponent(presetQueryParam);
            JSON.parse(jsonString);
            localStorage.setItem(CALCULATOR_STORAGE_KEY, jsonString);

            urlParams.delete("preset");
            const newQueryString = urlParams.toString();
            const newUrl =
                window.location.origin +
                window.location.pathname +
                (newQueryString ? "?" + newQueryString : "");
            window.location.replace(newUrl);
        } catch (error) {
            console.error("Error importing preset:", error);
        }
    }

    window.__fishystuffCalculator = {
        iconSpriteUrl: ICON_SPRITE_URL,
        lang: calculatorLang,
        initUrl() {
            const url = new URL(
                window.__fishystuffResolveApiUrl(`/api/v1/calculator/datastar/init?lang=${this.lang}`),
                window.location.origin,
            );
            if (bootstrapSignals && typeof bootstrapSignals === "object") {
                url.searchParams.set(
                    "datastar",
                    JSON.stringify(publicCalculatorSignals(bootstrapSignals)),
                );
            }
            return url.toString();
        },
        evalUrl() {
            return window.__fishystuffResolveApiUrl(
                `/api/v1/calculator/datastar/eval?lang=${this.lang}`,
            );
        },
        presetUrl(signals) {
            return presetURL(signals);
        },
        shareText(signals) {
            const current = signals ?? {};
            const calc = current._calc ?? {};
            const lead = current.active
                ? "Active | "
                : `${calc.auto_fish_time_reduction_text ?? "0%"} AFR | `;
            return (
                `[FishyStuff Calculator Preset | ${lead}${calc.durability_reduction_resistance_text ?? "0%"} DRR | ${calc.zone_name ?? current.zone}](` +
                this.presetUrl(current) +
                ")"
            );
        },
        clear() {
            clearSignals();
        },
        initialSignals() {
            return cloneSignals(initialCalculatorSignals);
        },
        persist(signals) {
            const payload = publicCalculatorSignals(signals);
            localStorage.setItem(CALCULATOR_STORAGE_KEY, JSON.stringify(payload));
        },
        sync(runtimeCtx) {
            this.persist(runtimeCtx.signals.values());
            return runtimeCtx.actions.post.fn(runtimeCtx, this.evalUrl());
        },
    };
</script>

<div id="calculator"
     class="not-prose grid gap-6"
     data-signals="window.__fishystuffCalculator.initialSignals()"
     data-on-input__debounce.150ms="window.__fishystuffCalculator.sync(ctx)"
     data-on-change__debounce.150ms="window.__fishystuffCalculator.sync(ctx)">

    <div class="hidden"
         data-indicator-_loading
         data-on-load="@get(window.__fishystuffCalculator.initUrl())"></div>

    <section class="card card-border bg-base-100">
        <div class="card-body gap-5">
            <div class="flex flex-col gap-3 xl:flex-row xl:items-start xl:justify-between">
                <div class="flex flex-wrap gap-3">
                    <label class="label cursor-pointer justify-start gap-3 rounded-box border border-base-300 bg-base-200 px-4 py-3 font-medium">
                        <input data-bind-active type="checkbox" class="checkbox checkbox-primary">
                        <span>Active Fishing</span>
                    </label>
                    <label class="label cursor-pointer justify-start gap-3 rounded-box border border-base-300 bg-base-200 px-4 py-3 font-medium">
                        <input data-bind-debug type="checkbox" class="checkbox checkbox-primary">
                        <span>Debug</span>
                    </label>
                </div>

                <div class="flex flex-wrap gap-2">
                    <button class="btn btn-soft btn-secondary"
                            data-on-click="window.__fishystuffToast.copyText(window.__fishystuffCalculator.presetUrl(ctx.signals.values()), { success: 'Preset URL copied.' })">
                        <svg class="fishy-icon size-6" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260325-2#fishy-link"></use></svg>
                        Copy URL
                    </button>
                    <button class="btn btn-soft btn-secondary"
                            data-on-click="window.__fishystuffToast.copyText(window.__fishystuffCalculator.shareText(ctx.signals.values()), { success: 'Share text copied.' })">
                        <svg class="fishy-icon size-6" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260325-2#fishy-share-nodes"></use></svg>
                        Copy Share
                    </button>
                    <button class="btn btn-dash btn-error"
                            data-on-click="window.__fishystuffCalculator.clear(); window.__fishystuffToast.info('Calculator cleared.')">
                        <svg class="fishy-icon size-6" viewBox="0 0 24 24" aria-hidden="true"><use width="100%" height="100%" href="/img/icons.svg?v=20260325-2#fishy-x-circle"></use></svg>
                        Clear
                    </button>
                </div>
            </div>

            <div class="rounded-box border border-base-300 bg-base-200 p-4">
                <div id="fishing-timeline">
                    <div data-attr-title="$_calc.bite_time_title"
                         data-attr="{style: 'flex-basis:' + ($_calc.percent_bite || '0.00') + '%;'}"
                         class="slider slider-bitetime"></div>
                    <div data-show="$_calc.show_auto_fishing"
                         data-attr-title="$_calc.auto_fish_time_title"
                         data-attr="{style: 'flex-basis:' + ($_calc.percent_af || '0.00') + '%;'}"
                         class="slider slider-aftime"></div>
                    <div data-attr-title="$_calc.catch_time_title"
                         data-attr="{style: 'flex-basis:' + ($_calc.percent_catch || '0.00') + '%;'}"
                         class="slider slider-catchtime"></div>
                    <div data-attr-title="$_calc.unoptimized_time_title" class="slider slider-empty"></div>
                </div>
            </div>

            <div class="grid gap-4">
                <div class="stats stats-vertical rounded-box border border-base-300 bg-base-100 xl:stats-horizontal">
                    <div class="stat">
                        <div class="stat-title">Average Total Fishing Time</div>
                        <div class="stat-value text-2xl" data-text="$_calc.total_time"></div>
                        <div class="stat-desc">seconds</div>
                    </div>
                    <div class="stat">
                        <div class="stat-title">Average Bite Time</div>
                        <div class="stat-value text-2xl" data-text="$_calc.bite_time"></div>
                        <div class="stat-desc">seconds</div>
                    </div>
                    <div data-show="$_calc.show_auto_fishing" class="stat">
                        <div class="stat-title">Auto-Fishing Time (AFT)</div>
                        <div class="stat-value text-2xl" data-text="$_calc.auto_fish_time"></div>
                        <div class="stat-desc">seconds</div>
                    </div>
                    <div data-show="$_calc.show_auto_fishing" class="stat">
                        <div class="stat-title">Auto-Fishing Time Reduction (AFR)</div>
                        <div class="stat-value text-2xl" data-text="$_calc.auto_fish_time_reduction_text"></div>
                    </div>
                </div>

                <div class="stats stats-vertical rounded-box border border-base-300 bg-base-100 xl:stats-horizontal">
                    <div class="stat">
                        <div class="stat-title whitespace-normal leading-snug" data-text="$_calc.casts_title"></div>
                        <div class="stat-value text-2xl" data-text="$_calc.casts_average"></div>
                    </div>
                    <div class="stat">
                        <div class="stat-title">Durability Reduction Resistance (DRR)</div>
                        <div class="stat-value text-2xl" data-text="$_calc.durability_reduction_resistance_text"></div>
                    </div>
                    <div class="stat">
                        <div class="stat-title">Chance to consume Durability</div>
                        <div class="stat-value text-2xl" data-text="$_calc.chance_to_consume_durability_text"></div>
                    </div>
                    <div class="stat">
                        <div class="stat-title whitespace-normal leading-snug" data-text="$_calc.durability_loss_title"></div>
                        <div class="stat-value text-2xl" data-text="$_calc.durability_loss_average"></div>
                    </div>
                </div>
            </div>

            <code data-show="$debug" class="rounded-box border border-base-300 bg-base-200 p-4 text-sm">
                <pre class="overflow-x-auto whitespace-pre-wrap break-all" data-text="$_calc.debug_json"></pre>
            </code>
        </div>
    </section>

    <div class="grid gap-6 xl:grid-cols-2">
        <fieldset class="card card-border bg-base-100">
            <legend class="fieldset-legend ml-6 px-2">Zone</legend>
            <div class="card-body gap-4 pt-0">
                <div class="grid gap-4">
                    <select class="select w-full" id="zone" data-bind-zone>
                        <button class="w-full justify-between"><div><selectedcontent></selectedcontent></div></button>
                    </select>
                    <div class="stats stats-horizontal rounded-box border border-base-300 bg-base-100 shadow-none">
                        <div class="stat px-4 py-3">
                            <div class="stat-title">Min</div>
                            <div class="stat-value text-lg" data-text="$_calc.zone_bite_min"></div>
                            <div class="stat-desc">raw seconds</div>
                        </div>
                        <div class="stat px-4 py-3">
                            <div class="stat-title">Max</div>
                            <div class="stat-value text-lg" data-text="$_calc.zone_bite_max"></div>
                            <div class="stat-desc">raw seconds</div>
                        </div>
                    </div>
                </div>
            </div>
        </fieldset>

        <fieldset class="card card-border bg-base-100">
            <legend class="fieldset-legend ml-6 px-2">Bite Time</legend>
            <div class="card-body gap-4 pt-0">
                <div class="grid gap-4">
                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Fishing Level</legend>
                        <select class="select w-full" id="level" data-bind-level>
                            <button class="w-full justify-between"><div><selectedcontent></selectedcontent></div></button>
                        </select>
                    </fieldset>
                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Fishing Resources</legend>
                        <input data-bind-resources type="range" class="range-xs range-secondary w-full" min="0" max="100">
                        <span class="label text-sm font-medium" data-text="$resources + '% (' + ($_calc.abundance_label || 'Exhausted') + ')'"></span>
                    </fieldset>
                    <div class="stats stats-horizontal rounded-box border border-base-300 bg-base-100 shadow-none">
                        <div class="stat px-4 py-3">
                            <div class="stat-title">Effective Min</div>
                            <div class="stat-value text-lg" data-text="$_calc.effective_bite_min"></div>
                            <div class="stat-desc">seconds</div>
                        </div>
                        <div class="stat px-4 py-3">
                            <div class="stat-title">Effective Max</div>
                            <div class="stat-value text-lg" data-text="$_calc.effective_bite_max"></div>
                            <div class="stat-desc">seconds</div>
                        </div>
                    </div>
                </div>
            </div>
        </fieldset>

        <fieldset class="card card-border bg-base-100">
            <legend class="fieldset-legend ml-6 px-2">Catch Time</legend>
            <div class="card-body gap-4 pt-0">
                <div class="grid gap-3 sm:grid-cols-2">
                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Active</legend>
                        <input type="number" min="0" step="any" class="input input-sm w-full" data-bind="catchTimeActive">
                        <span class="label text-xs">seconds</span>
                    </fieldset>
                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">AFK</legend>
                        <input type="number" min="0" step="any" class="input input-sm w-full" data-bind="catchTimeAfk">
                        <span class="label text-xs">seconds</span>
                    </fieldset>
                </div>
            </div>
        </fieldset>

        <fieldset class="card card-border bg-base-100">
            <legend class="fieldset-legend ml-6 px-2">Session (<span data-text="$_calc.timespan_text || '8 hours'"></span>)</legend>
            <div class="card-body gap-3 pt-0">
                <div class="grid gap-3">
                    <div class="grid grid-cols-2 gap-3">
                        <fieldset class="fieldset">
                            <legend class="fieldset-legend">Amount</legend>
                            <input type="number" min="0" step="any" class="input input-sm w-full" id="timespan_amount" data-bind="timespanAmount" name="timespan_amount">
                        </fieldset>
                        <fieldset class="fieldset">
                            <legend class="fieldset-legend">Unit</legend>
                            <select class="select select-sm w-full" id="timespan_unit" data-bind="timespanUnit">
                                <button class="w-full justify-between"><div><selectedcontent></selectedcontent></div></button>
                            </select>
                        </fieldset>
                    </div>

                    <div id="session_presets" class="join join-vertical sm:join-horizontal"></div>
                </div>
            </div>
        </fieldset>

        <fieldset class="card card-border bg-base-100 xl:col-span-2">
            <legend class="fieldset-legend ml-6 px-2">Gear</legend>
            <div class="card-body pt-0">
                <div id="items" class="grid gap-4 md:grid-cols-2">
                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Lifeskill Level</legend>
                        <select class="select w-full" id="lifeskill_level" data-bind-lifeskill_level>
                            <button class="w-full justify-between"><div><selectedcontent></selectedcontent></div></button>
                        </select>
                    </fieldset>
                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Fishing Rod</legend>
                        <select class="select w-full" id="rods" data-bind-rod>
                            <button class="w-full justify-between"><div><selectedcontent></selectedcontent></div></button>
                        </select>
                    </fieldset>
                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Brand</legend>
                        <label class="label cursor-pointer justify-start gap-3 rounded-box border border-base-300 bg-base-200 px-3 py-3 font-medium">
                            <input data-bind-brand type="checkbox" class="checkbox checkbox-primary">
                        </label>
                    </fieldset>
                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Float</legend>
                        <select class="select w-full" id="floats" data-bind-float>
                            <button class="w-full justify-between"><div><selectedcontent></selectedcontent></div></button>
                        </select>
                    </fieldset>
                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Chair</legend>
                        <select class="select w-full" id="chairs" data-bind-chair>
                            <button class="w-full justify-between"><div><selectedcontent></selectedcontent></div></button>
                        </select>
                    </fieldset>
                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Lightstone Set</legend>
                        <select class="select w-full" id="lightstone_sets" data-bind-lightstone_set>
                            <button class="w-full justify-between"><div><selectedcontent></selectedcontent></div></button>
                        </select>
                    </fieldset>
                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Backpack</legend>
                        <select class="select w-full" id="backpacks" data-bind-backpack>
                            <button class="w-full justify-between"><div><selectedcontent></selectedcontent></div></button>
                        </select>
                    </fieldset>
                    <fieldset class="fieldset rounded-box border border-base-300 bg-base-200 p-4 md:col-span-2">
                        <legend class="fieldset-legend">Outfit</legend>
                        <div id="outfits" class="grid gap-2 sm:grid-cols-2"></div>
                    </fieldset>
                    <fieldset class="fieldset rounded-box border border-base-300 bg-base-200 p-4 md:col-span-2">
                        <legend class="fieldset-legend">Food</legend>
                        <div id="foods" class="grid gap-2 sm:grid-cols-2"></div>
                    </fieldset>
                    <fieldset class="fieldset rounded-box border border-base-300 bg-base-200 p-4 md:col-span-2">
                        <legend class="fieldset-legend">Buffs</legend>
                        <div id="buffs" class="grid gap-2 sm:grid-cols-2"></div>
                    </fieldset>
                </div>
            </div>
        </fieldset>

        <fieldset class="card card-border bg-base-100 xl:col-span-2">
            <legend class="fieldset-legend ml-6 px-2">Pets</legend>
            <div class="card-body pt-0">
                <div id="pets" class="grid gap-4 md:grid-cols-2"></div>
            </div>
        </fieldset>
    </div>
</div>

<style>
    @supports (appearance: base-select) {
        select {
            &, &::picker(select) {
                appearance: base-select;
            }

            selectedcontent {
                display: flex;
                align-items: center;
                gap: .5ch;
            }

            option {
                display: grid;
                grid-template-columns: [icon] auto [content] 1fr [mark] auto;

                &::checkmark {
                    display: none;
                }

                padding-block: 0.25rem;

                &:checked {
                    background: #61afef;
                }
            }
        }
    }

    @layer support {
        html {
            color-scheme: dark light;
        }
    }

    .item-icon {
        width: 30px;
        height: 30px;
    }

    #fishing-timeline {
        width: 100%;
        display: flex;
        position: relative;
        margin: 0 auto;
        height: 0.875rem;
        overflow: hidden;
        background-color: var(--color-base-300);
        border: 1px solid color-mix(in srgb, var(--color-base-content) 10%, transparent);
        border-radius: 8px;

        .slider {
            border-radius: 8px;
            height: 100%;
        }

        .slider-bitetime {
            background-color: #46d2a7;
        }

        .slider-catchtime {
            background-color: #d27746;
        }

        .slider-aftime {
            background-color: #4e7296;
        }

        .slider-empty {
            flex-grow: 1;
        }
    }
</style>
```
