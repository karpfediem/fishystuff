# Build-only site tasks. Repo-root dev watch/serve flow lives in `../Justfile`.
build-tailwind:
    bun run tailwind:build

build-release-no-tailwind:
    mkdir -p .out-builds; \
    build_dir=$(mktemp -d .out-builds/build.XXXXXX); \
    trap 'rm -rf "$build_dir" .out.next' EXIT; \
    bun run datastar:build; \
    bun run images:build; \
    bun run fonts:build; \
    zine release --output "$build_dir"; \
    bun run ./scripts/write-runtime-config.mjs --out "$build_dir/runtime-config.js"; \
    ln -sfn "$build_dir" .out.next; \
    if [ -L .out ]; then \
      mv -Tf .out.next .out; \
    else \
      rm -rf .out.prev; \
      if [ -e .out ]; then mv .out .out.prev; fi; \
      mv -Tf .out.next .out; \
      rm -rf .out.prev; \
    fi; \
    current_target=$(readlink .out); \
    find .out-builds -mindepth 1 -maxdepth 1 -type d ! -path "$current_target" -exec rm -rf {} +; \
    trap - EXIT

# one-off release
build-release:
    just build-tailwind
    just build-release-no-tailwind

release: build-release
