
# one-off release
build-release:
    rm -rf .out
    zine release --install .out

release: build-release

# rebuild site whenever sources change (ignore .out)
watch-release:
    watchexec -r \
      -w content -w layouts -w assets -w zine.ziggy \
      --exts smd,shtml,ziggy,css,js \
      -- bash -lc 'just build-release'

serve-release:
    bun run ./scripts/serve-release.mjs --root .out --port 1990

# tailwind watch (builds to assets/css/site.css)
watch-tailwind:
    bunx @tailwindcss/cli -i tailwind.input.css -o assets/css/site.css --watch

# dev: run both watchers concurrently
watch:
    just build-release
    just watch-release & \
    just watch-tailwind & \
    just serve-release & \
    wait
